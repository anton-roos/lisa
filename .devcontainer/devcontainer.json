{
  "name": "Lisa DevContainer",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "../docker-compose.override.yml"
  ],
  "service": "app",
  "workspaceFolder": "/src",
  "forwardPorts": [8080, 5432],
  "portsAttributes": {
    "8080": {
      "label": "Lisa Web App",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "dotnet restore && dotnet tool install --global dotnet-ef || echo \"dotnet-ef already installed\"",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true,
        "editor.tabSize": 4
      },
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "remoteEnv": {
    "ASPNETCORE_ENVIRONMENT": "Development"
  },
  "remoteUser": "root"
}
