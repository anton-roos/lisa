{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Lisa (DevContainer)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Lisa",
      "program": "${workspaceFolder}/Lisa/bin/Debug/net9.0/Lisa.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Lisa",
      "stopAtEntry": false,
      "serverReadyAction": {
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "sourceFileMap": {
        "/src": "${workspaceFolder}"
      }
    }
  ]
}