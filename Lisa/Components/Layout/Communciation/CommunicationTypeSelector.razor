@using Lisa.Enums
@inherits ComponentBase

<div class="mb-3">
    <label class="form-label"><strong>Send Communication Per:</strong></label>
    <div class="btn-group" role="group">
        <input type="radio" class="btn-check" name="communicationTarget" id="schoolOption"
            value="@CommunicationTarget.School" @onchange="HandleChange"
            checked="@(SelectedTarget == CommunicationTarget.School)">
        <label class="btn btn-outline-secondary" for="schoolOption">School</label>

        <input type="radio" class="btn-check" name="communicationTarget" id="gradeOption"
            value="@CommunicationTarget.SchoolGrade" @onchange="HandleChange"
            checked="@(SelectedTarget == CommunicationTarget.SchoolGrade)">
        <label class="btn btn-outline-secondary" for="gradeOption">Grade</label>

        <input type="radio" class="btn-check" name="communicationTarget" id="subjectOption"
            value="@CommunicationTarget.Subject" @onchange="HandleChange"
            checked="@(SelectedTarget == CommunicationTarget.Subject)">
        <label class="btn btn-outline-secondary" for="subjectOption">Subject</label>

        <input type="radio" class="btn-check" name="communicationTarget" id="learnerOption"
            value="@CommunicationTarget.Learner" @onchange="HandleChange"
            checked="@(SelectedTarget == CommunicationTarget.Learner)">
        <label class="btn btn-outline-secondary" for="learnerOption">Learner</label>
    </div>
</div>

@code {
    /// <summary>
    /// The currently selected communication target.
    /// </summary>
    [Parameter]
    public CommunicationTarget SelectedTarget { get; set; }

    /// <summary>
    /// Event callback to notify when the target selection changes.
    /// </summary>
    [Parameter]
    public EventCallback<CommunicationTarget> OnTargetChanged { get; set; }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (Enum.TryParse(e.Value?.ToString(), out CommunicationTarget newTarget))
        {
            await OnTargetChanged.InvokeAsync(newTarget);
        }
    }
}
