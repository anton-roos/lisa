@using Lisa.Models.Entities
@inherits ComponentBase

<div class="mb-3">
    <label for="gradeSelect">Select Grade</label>
    <InputSelect id="gradeSelect" class="form-select" @bind-Value="SelectedGradeId" @onchange="HandleGradeChange">
        <option value="">-- Select Grade --</option>
        @if (Grades != null)
        {
            foreach (var grade in Grades)
            {
                <option value="@grade.Id">@grade.Name</option>
            }
        }
    </InputSelect>
</div>

@code {
    /// <summary>
    /// The list of grades to display.
    /// </summary>
    [Parameter]
    public IEnumerable<SchoolGrades> SchoolGrades { get; set; } = Enumerable.Empty<SchoolGrades>();

    /// <summary>
    /// The currently selected grade ID.
    /// </summary>
    [Parameter]
    public Guid? SelectedGradeId { get; set; }

    /// <summary>
    /// Event callback that is triggered when the selected grade changes.
    /// </summary>
    [Parameter]
    public EventCallback<Guid?> OnGradeSelected { get; set; }

    /// <summary>
    /// Handles the change event for the grade selection and notifies the parent component.
    /// </summary>
    private async Task HandleGradeChange(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var gradeId))
        {
            SelectedGradeId = gradeId;
        }
        else
        {
            SelectedGradeId = null;
        }
        await OnGradeSelected.InvokeAsync(SelectedGradeId);
    }
}
