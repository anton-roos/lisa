@using Lisa.Models.Entities
@inherits ComponentBase
@inject ILogger<LearnerSearch> Logger



@code {
    /// <summary>
    /// The current search term entered by the user.
    /// </summary>
    private string? _searchTerm;
    [Parameter]
    public string? SearchTerm
    {
        get => _searchTerm;
        set
        {
            if (_searchTerm != value)
            {
                _searchTerm = value;
                _ = PerformSearch();
            }
        }
    }

    /// <summary>
    /// Event callback triggered when the search term changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnSearchTermChanged { get; set; }

    /// <summary>
    /// The list of learners to display.
    /// </summary>
    [Parameter]
    public IEnumerable<Learner> Learners { get; set; } = Enumerable.Empty<Learner>();

    /// <summary>
    /// Event callback triggered when the user clicks "Send Communication" for a learner.
    /// </summary>
    [Parameter]
    public EventCallback<Learner> OnSend { get; set; }



    /// <summary>
    /// Triggers the search immediately when the user types.
    /// </summary>
    private async Task PerformSearch()
    {
        IsLoading = true;
        await OnSearchTermChanged.InvokeAsync(SearchTerm);
        IsLoading = false;
    }

    /// <summary>
    /// Sends communication to the selected learner.
    /// </summary>
    private async Task SendCommunication(Learner learner)
    {
        try
        {
            IsSending = true;
            await OnSend.InvokeAsync(learner);
        }
        catch (Exception ex)
        {
            Logger.LogError("Error sending communication: {ex.Message}", ex.Message);
        }
        finally
        {
            IsSending = false;
        }
    }
}
