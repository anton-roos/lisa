@inherits ComponentBase

<div class="mb-3">
    <label for="audienceSelect">Select Audience</label>
    <InputSelect id="audienceSelect" class="form-select" TValue="string"
        ValueChanged="@(async (id) => await AudienceChanged(id))" ValueExpression="(() => SelectedAudienceId)">
        <option value="">-- Select Audience --</option>
        @foreach (var audience in AudienceOptions)
        {
            <option value="@audience.Key">@audience.Value</option>
        }
    </InputSelect>
</div>

@code {
    /// <summary>
    /// The currently selected audience ID.
    /// </summary>
    private string? SelectedAudienceId { get; set; }

    /// <summary>
    /// Event callback to notify when the audience selection changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> OnAudienceSelected { get; set; }

    [Parameter]
    public string? SelectedAudience { get; set; }

    /// <summary>
    /// Available audience options.
    /// </summary>
    private readonly Dictionary<string, string> AudienceOptions = new()
{
{ "Parents", "Parents" },
{ "Staff", "Staff" },
{ "LearnersAndStaff", "Learners and Staff" }
};

    /// <summary>
    /// Called when the user selects a new audience.
    /// </summary>
    private async Task AudienceChanged(string? audienceId)
    {
        SelectedAudienceId = audienceId;
        await OnAudienceSelected.InvokeAsync(SelectedAudienceId);
    }
}
