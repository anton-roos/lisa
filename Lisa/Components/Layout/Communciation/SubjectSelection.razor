@using Lisa.Models.Entities
@inherits ComponentBase


@code {
    /// <summary>
    /// The list of subjects to display.
    /// </summary>
    [Parameter]
    public IEnumerable<Subject> Subjects { get; set; } = Enumerable.Empty<Subject>();

    /// <summary>
    /// The currently selected subject ID.
    /// </summary>
    [Parameter]
    public int SelectedSubjectId { get; set; }

    /// <summary>
    /// Event callback that is triggered when the selected subject changes.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnSubjectSelected { get; set; }

    /// <summary>
    /// Handles the change event for the subject selection and notifies the parent component.
    /// </summary>
    private async Task HandleSubjectChange(ChangeEventArgs e)
    {
        SelectedSubjectId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        await OnSubjectSelected.InvokeAsync(SelectedSubjectId);
    }
}
