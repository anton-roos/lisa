@using Lisa.Models.Entities
@inject EmailTemplateService EmailTemplateService

<div class="mb-3">
    <label for="templateSelect">Select Template</label>
    <InputSelect id="templateSelect" class="form-select" TValue="Guid?"
        ValueChanged="@(async (id) => await TemplateChanged(id))" ValueExpression="(() => SelectedTemplateId)">
        <option value="">-- Select Template --</option>
        @if (Templates != null)
        {
            @foreach (var template in Templates)
            {
                <option value="@template.Id">@template.Name</option>
            }
        }
    </InputSelect>
</div>

@code {
    /// <summary>
    /// The currently selected template ID.
    /// </summary>
    private Guid? SelectedTemplateId { get; set; }

    /// <summary>
    /// Callback to notify when the template selection changes.
    /// </summary>
    [Parameter]
    public EventCallback<EmailTemplate?> OnTemplateSelected { get; set; }

    /// <summary>
    /// The list of available email templates.
    /// </summary>
    private List<EmailTemplate> Templates = new();

    /// <summary>
    /// Loads all email templates on component initialization.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        Templates = await EmailTemplateService.GetAllTemplatesAsync();
    }

    /// <summary>
    /// Invoked when the user selects a new template.
    /// </summary>
    private async Task TemplateChanged(Guid? templateId)
    {
        SelectedTemplateId = templateId;

        // Find the selected template by its ID
        var selectedTemplate = Templates.FirstOrDefault(t => t.Id == templateId);
        await OnTemplateSelected.InvokeAsync(selectedTemplate);
    }
}
