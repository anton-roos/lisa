@inject NavigationManager NavigationManager

<div class="d-flex flex-column align-items-center justify-content-center 50pxtext-center">
    <div class="card shadow-lg" style="max-width: 500px; border-radius: 15px;">
        <div class="card-body">
            <h1 class="text-warning display-4"><i class="bi bi-person-x-fill"></i></h1>
            <h3 class="mt-3">Please Log In</h3>
            <p class="text-muted mt-2">
                You need to log in to access this page.
            </p>
            <button class="btn btn-primary mt-3" @onclick="GoToLogin">
                <i class="bi bi-box-arrow-in-right me-2"></i>Log In
            </button>
        </div>
    </div>
</div>

@code {
    private void GoToLogin()
    {
        NavigationManager.NavigateTo("/login");
    }
}
