@page "/attendance/management"
@using Lisa.Components.Shared

<PageTitle>Attendance Management</PageTitle>

<AuthorizeView Context="_" Roles="@($"{Roles.SystemAdministrator},{Roles.Attendance}")">
    <Authorized>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <h1>Attendance Management Dashboard</h1>
                    <p class="text-muted">Manage daily attendance check-ins and check-outs</p>
                    
                    <AttendanceComponent />
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <Unauthenticated />
    </NotAuthorized>
</AuthorizeView>

@code {
    // Logic is handled in AttendanceComponent
}
