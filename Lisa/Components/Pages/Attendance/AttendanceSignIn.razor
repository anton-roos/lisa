@page "/attendance/sign-in"
@page "/attendance/sign-in/{AttendanceId:guid}"
@using Lisa.Models.Entities
@inject SchoolService SchoolService
@inject RegisterClassService RegisterClassService
@inject LearnerService LearnerService
@inject AttendanceService AttendanceService
@inject AttendanceRecordService AttendanceRecordService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@using System.Security.Claims
@using Lisa.Enums

@inherits EventAwareComponentBase

<PageTitle>Attendance Sign In</PageTitle>

<AuthorizeView Context="_" Roles="@($"{Roles.SystemAdministrator},{Roles.Attendance}")">
    <Authorized>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h2>Sign In</h2>
                    <p>@DateTime.UtcNow.ToString("dd/M")</p>

                    @if (_selectedSchool == null)
                    {
                        <div class="alert alert-warning mb-3">
                            <h4><i class="oi oi-warning"></i> No School Selected</h4>
                            <p>Please select a school from the dropdown at the top of the page before proceeding.</p>
                        </div>
                    }
                    else
                    {
                        <div class="input-group mb-3">
                            <input type="time" class="form-control" @bind="_startTimeOnly"/>
                            <button class="btn btn-primary" @onclick="ConfirmStartTime"
                                    disabled="@_isStartTimeConfirmed">Confirm
                            </button>
                        </div>
                        <div class="mb-3">
                            <small class="text-muted">Start time: @_startTimeOnly.ToString("HH:mm")</small>
                        </div>

                        @if (_isStartTimeConfirmed)
                        {
                            <div class="d-flex mb-3">
                                @foreach (var filter in _registerClassFilters)
                                {
                                    <button
                                        class="btn @(filter == _selectedFilter ? "btn-primary" : "btn-secondary") me-2"
                                        @onclick="() => FilterByRegisterClass(filter)">
                                        @filter
                                    </button>
                                }
                            </div>

                            <div class="mb-3">
                                <input type="text" class="form-control" @bind-value="_searchText"
                                       @bind-value:event="oninput"
                                       placeholder="Search Learner"/>
                            </div>

                            @if (_registerClassLearners.Any())
                            {
                                @foreach (var registerClass in _registerClassLearners.Keys)
                                {
                                    @if (_selectedFilter == "All" || _selectedFilter == registerClass)
                                    {
                                        <div class="mb-4">
                                            <h4>Gr @registerClass</h4>
                                            <div class="d-flex flex-column">
                                                @foreach (var learner in _registerClassLearners[registerClass]
                                                                  .Where(l => string.IsNullOrEmpty(_searchText) ||
                                                                              $"{l.Name} {l.Surname}".ToLower().Contains(_searchText.ToLower())))
                                                {
                                                    <div class="d-flex align-items-center mb-2">
                                                        <div class="me-3"
                                                             style="min-width: 150px;">@learner.Name @learner.Surname</div>
                                                        <div @onclick="() => ToggleAttendance(learner, registerClass)">
                                                            @{
                                                                var pillColor = GetPillColor(learner);
                                                                var pillClass = $"pill {pillColor}";
                                                            }
                                                            <div class="@pillClass">
                                                                @if (pillColor == "absent")
                                                                {
                                                                    <span>Absent</span>
                                                                }
                                                                else
                                                                {
                                                                    @_attendanceData[learner.Id].SignInTime.ToString("HH:mm")
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <p>No learners found.</p>
                            }
                        }
                    }
                </div>
            </div>
        </div>

        <style>
            .pill {
                padding: 5px 15px;
                border-radius: 20px;
                display: inline-block;
                min-width: 100px;
                text-align: center;
                cursor: pointer;
                font-weight: bold;
            }

            .on-time {
                background-color: #4CAF50;
                color: white;
            }

            .late {
                background-color: white;
                color: black;
                border: 2px solid #f44336;
            }

            .absent {
                background-color: #f44336;
                color: white;
            }
        </style>
    </Authorized>
    <NotAuthorized>
        <Unauthenticated/>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public Guid? AttendanceId { get; set; }

    private School? _selectedSchool;
    private List<RegisterClass> _registerClasses = [];
    private Dictionary<string, List<Learner>> _registerClassLearners = new();
    private Dictionary<Guid, AttendanceData> _attendanceData = new();
    private DateTime _startTime;
    private TimeOnly _startTimeOnly = new TimeOnly(7, 0);
    private bool _isStartTimeConfirmed = false;
    private DateTime _startTimeDateTime;
    private List<string> _registerClassFilters = ["All"];
    private string _selectedFilter = "All";
    private string _searchText = "";
    private Dictionary<string, Guid> _registerClassNameToIdMap = new();
    private Guid? _currentUserId;
    private Attendance? _currentSession;

    private class AttendanceData
    {
        public bool IsPresent { get; set; } = false;
        public DateTime SignInTime { get; set; }
        public bool IsLate(DateTime startTimeDateTime) => SignInTime > startTimeDateTime;
        public Guid? AttendanceId { get; set; } // Store the attendance record ID
    }

    protected override async Task OnInitializedAsync()
    {
        // Make sure TimeOnly is properly initialized
        _startTime = DateTime.UtcNow.AddHours(7);
        _startTimeOnly = new TimeOnly(7, 0);

        _selectedSchool = await SchoolService.GetSelectedSchoolAsync();
        SubscribeToEvent(UiEvents.SchoolSelected);

        // Get the current user ID
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated ?? false)
        {
            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                _currentUserId = Guid.Parse(userId);
            }
        }

        if (_selectedSchool != null)
        {
            await LoadRegisterClasses();
            await CheckForExistingSession();
        }
    }

    // Add this method to properly handle school selection events
    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        if (eventName == UiEvents.SchoolSelected && payload is School school)
        {
            // Log selection to help debug
            Console.WriteLine($"School selected: {school.LongName} (ID: {school.Id})");

            // Update selected school
            _selectedSchool = school;

            // Reset state when school changes
            _isStartTimeConfirmed = false;
            _currentSession = null;
            _registerClassLearners.Clear();
            _attendanceData.Clear();

            // _startTime will be set from _startTimeOnly when they click Confirm

            await LoadRegisterClasses();
            await CheckForExistingSession();

            // Force UI update
            await InvokeAsync(StateHasChanged);
        }

        await base.HandleEventAsync(eventName, payload);
    }

    private async Task LoadRegisterClasses()
    {
        if (_selectedSchool == null) return;
        _registerClasses = await RegisterClassService.GetBySchoolIdAsync(_selectedSchool.Id);
    }

    protected override async Task OnParametersSetAsync()
    {
        // If we have an AttendanceId, load that session
        if (AttendanceId.HasValue)
        {
            await LoadAttendanceSession(AttendanceId.Value);
        }
        else if (_selectedSchool != null)
        {
            // Otherwise check if there's an existing session for today
            await CheckForExistingSession();
        }
    }

    private async Task CheckForExistingSession()
    {
        if (_selectedSchool == null) return;

        var existingSession = await AttendanceService.GetTodaysAttendanceAsync(_selectedSchool.Id);

        if (existingSession != null)
        {
            NavigationManager.NavigateTo($"/attendance/sign-in/{existingSession.Id}");
        }
    }

    private async Task LoadAttendanceSession(Guid sessionId)
    {
        _currentSession = await AttendanceService.GetAsync(sessionId);

        if (_currentSession == null)
        {
            NavigationManager.NavigateTo("/attendance/sign-in");
            return;
        }

        _startTime = _currentSession.Start;
        _startTimeOnly = TimeOnly.FromDateTime(_startTime);
        _startTimeDateTime = _startTime;
        _isStartTimeConfirmed = true;

        if (_selectedSchool?.Id != _currentSession.SchoolId)
        {
            _selectedSchool = await SchoolService.GetSchoolAsync(_currentSession.SchoolId);
            await LoadRegisterClasses();
        }

        await LoadLearners();
        await LoadAttendanceData();
    }

    private async Task LoadAttendanceData()
    {
        if (_currentSession == null) return;

        var sessionWithRecords = await AttendanceService.GetAsync(_currentSession.Id);

        if (sessionWithRecords?.AttendanceRecords != null)
        {
            foreach (var record in sessionWithRecords.AttendanceRecords)
            {
                if (!_attendanceData.ContainsKey(record.LearnerId))
                {
                    _attendanceData[record.LearnerId] = new AttendanceData
                    {
                        SignInTime = record.Start.HasValue ? record.Start.Value.ToLocalTime() : DateTime.UtcNow,
                        AttendanceId = record.Id,
                        IsPresent = record.Start.HasValue
                    };
                }
                else
                {
                    var data = _attendanceData[record.LearnerId];
                    data.SignInTime = record.Start.HasValue ? record.Start.Value.ToLocalTime() : data.SignInTime;
                    data.AttendanceId = record.Id;
                    data.IsPresent = record.Start.HasValue;
                }
            }
        }
    }

    private async Task ConfirmStartTime()
    {
        if (_selectedSchool == null) return;

        _startTime = DateTime.UtcNow.Date.Add(_startTimeOnly.ToTimeSpan());
        _startTimeDateTime = _startTime;
        _isStartTimeConfirmed = true;

        _currentSession = await AttendanceService.CreateAttendanceAsync(
            _selectedSchool.Id,
            _startTime
        );

        await CreateInitialAttendanceAsync();
        await LoadLearners();

        NavigationManager.NavigateTo($"/attendance/sign-in/{_currentSession.Id}");
    }

    private async Task LoadLearners()
    {
        if (_selectedSchool == null) return;

        _registerClassLearners.Clear();
        _attendanceData.Clear();
        _registerClassFilters = ["All"];
        _registerClassNameToIdMap.Clear();
        
        // Sort register classes by SystemGrade sequence number
        var sortedRegisterClasses = _registerClasses
            .Where(rc => rc?.SchoolGrade?.SystemGrade != null)
            .OrderBy(rc => rc.SchoolGrade.SystemGrade.SequenceNumber)
            .ToList();

        foreach (var registerClass in sortedRegisterClasses)
        {
            if (registerClass?.SchoolGrade?.SystemGrade?.Name == null) continue;
            var className = registerClass.SchoolGrade.SystemGrade.Name;

            if (!_registerClassFilters.Contains(className))
            {
                _registerClassFilters.Add(className);
            }

            var learners = await LearnerService.GetByRegisterClassAsync(registerClass.Id);

            if (!learners.Any()) continue;
            
            // Sort learners by surname then by name
            _registerClassLearners[className] = learners
                .OrderBy(l => l.Surname)
                .ThenBy(l => l.Name)
                .ToList();
                
            _registerClassNameToIdMap[className] = registerClass.Id;

            foreach (var learner in learners)
            {
                _attendanceData[learner.Id] = new AttendanceData();
            }
        }

        StateHasChanged();
    }

    private void FilterByRegisterClass(string filter)
    {
        _selectedFilter = filter;
    }

    private async Task ToggleAttendance(Learner learner, string registerClassName)
    {
        if (_currentSession == null) return;

        if (!_attendanceData.ContainsKey(learner.Id))
        {
            _attendanceData[learner.Id] = new AttendanceData();
        }

        var data = _attendanceData[learner.Id];
        data.IsPresent = !data.IsPresent;

        if (data.IsPresent)
        {
            data.SignInTime = DateTime.UtcNow;
        }

        if (_registerClassNameToIdMap.TryGetValue(registerClassName, out var registerClassId))
        {
            if (data.AttendanceId.HasValue)
            {
                await UpdateAttendanceStatus(data.AttendanceId.Value, data.IsPresent);
            }
            else
            {
                await SaveAttendanceRecord(learner.Id);
            }
        }
    }

    private async Task SaveAttendanceRecord(Guid learnerId)
    {
        if (_selectedSchool == null || _currentSession == null) return;

        var attendanceRecord = new AttendanceRecord()
        {
            Start = DateTime.UtcNow,
            End = null,
            AttendanceType = AttendanceType.CheckIn,
            LearnerId = learnerId,
            AttendanceId = AttendanceId!.Value
        };

        await AttendanceRecordService.CreateAsync(attendanceRecord);
    }

    private async Task UpdateAttendanceStatus(Guid attendanceId, bool isPresent)
    {
        var notes = isPresent
            ? $"Updated to present at {DateTime.UtcNow:HH:mm}"
            : "Updated to absent";
    }

    private string GetPillColor(Learner learner)
    {
        if (!_attendanceData.ContainsKey(learner.Id) || !_attendanceData[learner.Id].IsPresent)
        {
            return "absent";
        }

        return _attendanceData[learner.Id].IsLate(_startTimeDateTime) ? "late" : "on-time";
    }

    private async Task CreateInitialAttendanceAsync()
    {
        if (_selectedSchool == null || _currentSession == null) return;

        foreach (var registerClassGroup in _registerClassLearners)
        {
            var className = registerClassGroup.Key;
            if (!_registerClassNameToIdMap.TryGetValue(className, out var registerClassId)) continue;
            foreach (var learner in registerClassGroup.Value)
            {
                var attendance = await AttendanceService.CreateAttendanceAsync(
                    schoolId: _selectedSchool.Id,
                    start: _startTime
                );

                // Store the attendance ID for later updates
                if (!_attendanceData.ContainsKey(learner.Id))
                {
                    _attendanceData[learner.Id] = new AttendanceData();
                }

                // We'll update this with the proper ID when we load attendance data
            }
        }

        // Refresh attendance data to get the IDs
        await LoadAttendanceData();
    }
}
