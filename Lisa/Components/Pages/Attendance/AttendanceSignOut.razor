@page "/attendance/sign-out"
@page "/attendance/sign-out/{AttendanceSessionId:guid}"
@using Lisa.Models.Entities
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@inject SchoolService SchoolService
@inject RegisterClassService RegisterClassService
@inject LearnerService LearnerService
@inject IJSRuntime JSRuntime
@inject AttendanceService AttendanceService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@using System.Security.Claims

@inherits EventAwareComponentBase

<PageTitle>Attendance Sign Out</PageTitle>

<AuthorizeView Context="_" Roles="@($"{Roles.SystemAdministrator},{Roles.Attendance}")">
    <Authorized>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h2>Sign Out</h2>
                    <p>@DateTime.Now.ToString("dd/M")</p>
                    
                    @if (_selectedSchool == null)
                    {
                        <div class="alert alert-warning mb-3">
                            <h4><i class="oi oi-warning"></i> No School Selected</h4>
                            <p>Please select a school from the dropdown at the top of the page before proceeding.</p>
                        </div>
                    }
                    else
                    {
                        <div class="input-group mb-3">
                            <input type="time" class="form-control" @bind="_endTimeOnly" />
                            <button class="btn btn-primary" @onclick="ConfirmEndTime" disabled="@_isEndTimeConfirmed">Confirm</button>
                        </div>
                        <div class="mb-3">
                            <small class="text-muted">End time: @_endTimeOnly.ToString("HH:mm")</small>
                        </div>
                        
                        @if (_isEndTimeConfirmed)
                        {
                            <div class="d-flex mb-3">
                                @foreach (var filter in _registerClassFilters)
                                {
                                    <button class="btn @(filter == _selectedFilter ? "btn-primary" : "btn-secondary") me-2"
                                            @onclick="() => FilterByRegisterClass(filter)">
                                        @filter
                                    </button>
                                }
                            </div>
                            
                            <div class="mb-3">
                                <input type="text" class="form-control" @bind-value="_searchText" 
                                    @bind-value:event="oninput" placeholder="Search Learner" />
                            </div>
                            
                            @if (_registerClassLearners.Any())
                            {
                                @foreach (var registerClass in _registerClassLearners.Keys)
                                {
                                    @if (_selectedFilter == "All" || _selectedFilter == registerClass)
                                    {
                                        <div class="mb-4">
                                            <h4>Gr @registerClass</h4>
                                            <div class="d-flex flex-column">
                                                @foreach (var learner in _registerClassLearners[registerClass]
                                                    .Where(l => string.IsNullOrEmpty(_searchText) || 
                                                        $"{l.Name} {l.Surname}".ToLower().Contains(_searchText.ToLower())))
                                                {
                                                    <div class="d-flex align-items-center mb-2">
                                                        <div class="me-3" style="min-width: 150px;">@learner.Name @learner.Surname</div>
                                                        <div @onclick="() => ToggleAttendance(learner, registerClass)">
                                                            @{
                                                                string pillColor = GetPillColor(learner);
                                                                string pillClass = $"pill {pillColor}";
                                                            }
                                                            <div class="@pillClass">
                                                                @if (pillColor == "present")
                                                                {
                                                                    <span>Present</span>
                                                                }
                                                                else if (pillColor == "early-leave")
                                                                {
                                                                    @_attendanceData[learner.Id].SignOutTime.ToString("HH:mm")
                                                                }
                                                                else
                                                                {
                                                                    @_attendanceData[learner.Id].SignOutTime.ToString("HH:mm")
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <p>No learners found.</p>
                            }
                        }
                    }
                </div>
            </div>
        </div>

        <style>
            .pill {
                padding: 5px 15px;
                border-radius: 20px;
                display: inline-block;
                min-width: 100px;
                text-align: center;
                cursor: pointer;
                font-weight: bold;
            }
            
            .present {
                background-color: #4CAF50;
                color: white;
            }
            
            .early-leave {
                background-color: white;
                color: black;
                border: 2px solid #f44336;
            }
            
            .left {
                background-color: #2196F3;
                color: white;
            }
        </style>
    </Authorized>
    <NotAuthorized>
        <Unauthenticated />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public Guid? AttendanceSessionId { get; set; }
    
    private School? _selectedSchool;
    private List<RegisterClass> _registerClasses = new();
    private Dictionary<string, List<Learner>> _registerClassLearners = new();
    private Dictionary<Guid, AttendanceData> _attendanceData = new();
    private DateTime _endTime = DateTime.Today.AddHours(14); // Default to 2:00 PM
    private TimeOnly _endTimeOnly = new TimeOnly(14, 0); // Default to 2:00 PM for the input
    private bool _isEndTimeConfirmed = false;
    private DateTime _endTimeDateTime;
    private List<string> _registerClassFilters = new() { "All" };
    private string _selectedFilter = "All";
    private string _searchText = "";
    private Dictionary<string, Guid> _registerClassNameToIdMap = new();
    private Guid? _currentUserId;
    private AttendanceSession? _currentSession;

    private class AttendanceData
    {
        public bool HasLeft { get; set; } = false;
        public DateTime SignOutTime { get; set; }
        public bool IsEarlyLeave(DateTime endTimeDateTime) => SignOutTime < endTimeDateTime;
        public Guid? AttendanceId { get; set; } // Store the attendance record ID
    }

    protected override async Task OnInitializedAsync()
    {
        _selectedSchool = await SchoolService.GetSelectedSchoolAsync();
        SubscribeToEvent(UiEvents.SchoolSelected);

        // Get the current user ID
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated ?? false)
        {
            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                _currentUserId = Guid.Parse(userId);
            }
        }

        if (_selectedSchool != null)
        {
            await LoadRegisterClasses();
            await CheckForExistingSession();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // If we have an AttendanceSessionId, load that session
        if (AttendanceSessionId.HasValue)
        {
            await LoadAttendanceSession(AttendanceSessionId.Value);
        }
        else if (_selectedSchool != null)
        {
            // Otherwise check if there's an existing session for today
            await CheckForExistingSession();
        }
    }

    private async Task CheckForExistingSession()
    {
        if (_selectedSchool == null) return;

        // First check for any active session for today for this school
        var activeSession = await AttendanceService.GetActiveSessionForSchoolAsync(
            _selectedSchool.Id, 
            DateTime.SpecifyKind(DateTime.Today, DateTimeKind.Utc));
        
        if (activeSession != null)
        {
            // Redirect to that session - this is the same session that was created during sign-in
            NavigationManager.NavigateTo($"/attendance/sign-out/{activeSession.Id}");
            return;
        }

        // Also check if there's already a completed session for today
        var completedSession = await AttendanceService.GetCompletedSessionForSchoolAsync(
            _selectedSchool.Id,
            DateTime.SpecifyKind(DateTime.Today, DateTimeKind.Utc));

        if (completedSession != null)
        {
            // Redirect to the existing completed session
            NavigationManager.NavigateTo($"/attendance/sign-out/{completedSession.Id}");
        }
    }

    private async Task LoadAttendanceSession(Guid sessionId)
    {
        _currentSession = await AttendanceService.GetAttendanceSessionAsync(sessionId);
        
        if (_currentSession == null)
        {
            // Session not found, go back to main page
            NavigationManager.NavigateTo("/attendance/sign-out");
            return;
        }

        // Use end time from session if available, otherwise use default
        if (_currentSession.EndTime.HasValue)
        {
            _endTime = _currentSession.EndTime.Value.ToLocalTime();
            _endTimeOnly = TimeOnly.FromDateTime(_endTime); // Update the time input control
            _endTimeDateTime = _endTime;
            _isEndTimeConfirmed = true;
        }
        else
        {
            // Default end time 
            _endTime = DateTime.Today.AddHours(14);
            _endTimeOnly = new TimeOnly(14, 0);
        }
        
        // If school changed, update it
        if (_selectedSchool?.Id != _currentSession.SchoolId)
        {
            _selectedSchool = await SchoolService.GetSchoolAsync(_currentSession.SchoolId);
            await LoadRegisterClasses();
        }
        
        // Load students and attendance data
        await LoadLearners();
        await LoadAttendanceData();
    }

    private async Task LoadAttendanceData()
    {
        if (_currentSession == null) return;
        
        // Load attendance data for this session
        var attendances = await AttendanceService.GetAttendancesForSessionAsync(_currentSession.Id);
        
        foreach (var attendance in attendances)
        {
            if (_attendanceData.ContainsKey(attendance.LearnerId))
            {
                // Only update sign-out data if it exists
                if (attendance.SignOutTime.HasValue)
                {
                    _attendanceData[attendance.LearnerId].HasLeft = true;
                    _attendanceData[attendance.LearnerId].SignOutTime = attendance.SignOutTime.Value.ToLocalTime();
                }
                
                // Store the attendance ID for later updates
                _attendanceData[attendance.LearnerId].AttendanceId = attendance.Id;
            }
        }
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        if (eventName == UiEvents.SchoolSelected && payload is School school)
        {
            // Log selection to help debug
            Console.WriteLine($"School selected: {school.LongName} (ID: {school.Id})");
            
            // Update selected school
            _selectedSchool = school;
            
            // Reset state when school changes
            _isEndTimeConfirmed = false;
            _currentSession = null;
            _registerClassLearners.Clear();
            _attendanceData.Clear();
            
            // Keep the current time selection (don't reset it)
            
            // Load new data for selected school
            await LoadRegisterClasses();
            await CheckForExistingSession();
            
            // Force UI update
            await InvokeAsync(StateHasChanged);
        }
        
        await base.HandleEventAsync(eventName, payload);
    }

    private async Task LoadRegisterClasses()
    {
        if (_selectedSchool == null) return;

        _registerClasses = await RegisterClassService.GetBySchoolIdAsync(_selectedSchool.Id);
        
        // Reset everything when school changes
        _registerClassLearners.Clear();
        _attendanceData.Clear();
        _registerClassFilters = new() { "All" };
        _registerClassNameToIdMap.Clear();
        _isEndTimeConfirmed = false;
    }

    private async Task ConfirmEndTime()
    {
        if (_selectedSchool == null) return;
        
        // Convert TimeOnly to DateTime for our application logic
        _endTime = DateTime.Today.Add(_endTimeOnly.ToTimeSpan());
        _endTimeDateTime = _endTime;
        _isEndTimeConfirmed = true;
        
        // Create or update attendance session
        if (_currentSession == null)
        {
            // Check both active and completed sessions
            _currentSession = await AttendanceService.GetActiveSessionForSchoolAsync(
                _selectedSchool.Id, 
                DateTime.SpecifyKind(DateTime.Today, DateTimeKind.Utc)
            );
            
            if (_currentSession == null)
            {
                // Check for completed session as well
                _currentSession = await AttendanceService.GetCompletedSessionForSchoolAsync(
                    _selectedSchool.Id,
                    DateTime.SpecifyKind(DateTime.Today, DateTimeKind.Utc)
                );
                
                if (_currentSession == null)
                {
                    // No session exists at all, create one with both start and end time
                    _currentSession = await AttendanceService.CreateAttendanceSessionAsync(
                        _selectedSchool.Id,
                        DateTime.Today.AddHours(7).ToUniversalTime(), // Default start time if creating from sign-out
                        _currentUserId
                    );
                }
            }
            
            // Update with end time
            await AttendanceService.UpdateSessionEndTimeAsync(
                _currentSession.Id,
                _endTime.ToUniversalTime()
            );
        }
        else
        {
            // Update existing session with new end time
            await AttendanceService.UpdateSessionEndTimeAsync(
                _currentSession.Id,
                _endTime.ToUniversalTime()
            );
        }
        
        // Navigate to the session URL
        NavigationManager.NavigateTo($"/attendance/sign-out/{_currentSession.Id}");
        
        // Load students for this session
        await LoadLearners();
    }

    private async Task LoadLearners()
    {
        if (_selectedSchool == null) return;

        _registerClassLearners.Clear();
        _attendanceData.Clear();
        _registerClassFilters = new() { "All" };
        _registerClassNameToIdMap.Clear();

        foreach (var registerClass in _registerClasses)
        {
            if (registerClass?.SchoolGrade?.SystemGrade?.Name != null)
            {
                var className = registerClass.SchoolGrade.SystemGrade.Name;
                
                if (!_registerClassFilters.Contains(className))
                {
                    _registerClassFilters.Add(className);
                }
                
                var learners = await LearnerService.GetByRegisterClassAsync(registerClass.Id);
                
                if (learners.Any())
                {
                    _registerClassLearners[className] = learners;
                    _registerClassNameToIdMap[className] = registerClass.Id;
                    
                    // Initialize attendance data for all learners as present (since they haven't left yet)
                    foreach (var learner in learners)
                    {
                        _attendanceData[learner.Id] = new AttendanceData();
                    }
                }
            }
        }
        
        StateHasChanged();
    }

    private void FilterByRegisterClass(string filter)
    {
        _selectedFilter = filter;
    }

    private async Task ToggleAttendance(Learner learner, string registerClassName)
    {
        if (!_attendanceData.ContainsKey(learner.Id))
        {
            _attendanceData[learner.Id] = new AttendanceData();
        }
        
        var data = _attendanceData[learner.Id];
        data.HasLeft = !data.HasLeft;
        
        if (data.HasLeft)
        {
            data.SignOutTime = DateTime.Now;
            
            // Get the register class ID
            if (_registerClassNameToIdMap.TryGetValue(registerClassName, out var registerClassId))
            {
                bool isEarlyLeave = data.IsEarlyLeave(_endTimeDateTime);
                
                // If it's an early leave, redirect to the Leave Early page
                if (isEarlyLeave)
                {
                    NavigationManager.NavigateTo($"/leave-early/{learner.Id}");
                    return;
                }
                
                // Otherwise, save the attendance to the database
                await SaveSignOut(learner.Id, registerClassId, isEarlyLeave);
            }
        }
        else
        {
            // If toggling back to not left, remove the sign-out time
            if (data.AttendanceId.HasValue)
            {
                await AttendanceService.ClearSignOutAsync(data.AttendanceId.Value);
            }
        }
    }

    private async Task SaveSignOut(Guid learnerId, Guid registerClassId, bool isEarlyLeave)
    {
        if (_selectedSchool == null || _currentSession == null) return;
        
        // Check if we already have an attendance record for this learner
        if (_attendanceData[learnerId].AttendanceId.HasValue)
        {
            // Update existing record with sign-out time
            await AttendanceService.RecordSignOutAsync(
                _attendanceData[learnerId].AttendanceId.Value, 
                isEarlyLeave,
                $"Signed out at {DateTime.Now:HH:mm}{(isEarlyLeave ? " (early)" : "")}"
            );
        }
        else
        {
            // Create a new attendance record with sign-out info
            var attendance = await AttendanceService.RecordAttendanceAsync(
                learnerId,
                _selectedSchool.Id,
                registerClassId,
                true, // Assume they were present if they're signing out
                isEarlyLeave ? "Early leave" : "Regular sign out",
                _currentUserId,
                _currentSession.Id
            );
            
            // Store the ID and update with sign-out info
            _attendanceData[learnerId].AttendanceId = attendance.Id;
            await AttendanceService.RecordSignOutAsync(
                attendance.Id,
                isEarlyLeave,
                $"Signed out at {DateTime.Now:HH:mm}{(isEarlyLeave ? " (early)" : "")}"
            );
        }

        // Optionally show a success message
        await JSRuntime.InvokeVoidAsync("console.log", $"Sign-out saved for {learnerId}");
    }

    private string GetPillColor(Learner learner)
    {
        if (!_attendanceData.ContainsKey(learner.Id) || !_attendanceData[learner.Id].HasLeft)
        {
            return "present";
        }
        
        return _attendanceData[learner.Id].IsEarlyLeave(_endTimeDateTime) ? "early-leave" : "left";
    }
}