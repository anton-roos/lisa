    private class AttendanceData
    {
        public bool HasLeft { get; set; } = false;
        public DateTime SignOutTime { get; set; }
        public bool IsEarlyLeave(DateTime endTimeDateTime) => SignOutTime < endTimeDateTime;
        public Guid? AttendanceId { get; set; } // Store the attendance record ID
    }

    protected override async Task OnInitializedAsync()
    {
        _endTime = DateTime.UtcNow.Date.AddHours(14);
        _endTimeOnly = new TimeOnly(14, 0);

        _selectedSchool = await SchoolService.GetSelectedSchoolAsync();
        SubscribeToEvent(UiEvents.SchoolSelected);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated ?? false)
        {
            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                _currentUserId = Guid.Parse(userId);
            }
        }

        if (_selectedSchool != null)
        {
            await LoadRegisterClasses();
            await CheckForExistingSession();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (AttendanceSessionId.HasValue)
        {
            await LoadAttendanceSession(AttendanceSessionId.Value);
        }
        else if (_selectedSchool != null)
        {
            await CheckForExistingSession();
        }
    }

    private async Task CheckForExistingSession()
    {
        if (_selectedSchool == null) return;

        // First check for any active session for today for this school
        var activeSession = await AttendanceService.GetActiveAttendanceAsync(
            _selectedSchool.Id,
            DateTime.UtcNow.Date);

        if (activeSession != null)
        {
            // Redirect to that session - this is the same session that was created during sign-in
            NavigationManager.NavigateTo($"/attendance/sign-out/{activeSession.Id}");
            return;
        }

        // Also check if there's already a completed session for today
        var completedSession = await AttendanceService.GetCompletedSessionForSchoolAsync(
            _selectedSchool.Id,
            DateTime.UtcNow);

        if (completedSession != null)
        {
            // Redirect to the existing completed session
            //NavigationManager.NavigateTo($"/attendance/sign-out/{completedSession.}");
        }
    }

    private async Task LoadAttendanceSession(Guid sessionId)
    {
        _currentSession = await AttendanceService.GetAsync(sessionId);

        if (_currentSession == null)
        {
            // Session not found, go back to main page
            NavigationManager.NavigateTo("/attendance/sign-out");
            return;
        }

        // Use end time from session if available, otherwise use default
        if (_currentSession.End.HasValue)
        {
            _endTimeOnly = TimeOnly.FromDateTime(_currentSession.End.Value);
            _endTimeDateTime = _currentSession.End.Value;
            _isEndTimeConfirmed = true;
        }
        else
        {
            // Default end time 
            _endTime = DateTime.UtcNow.Date.AddHours(14);
            _endTimeOnly = new TimeOnly(14, 0);
        }

        // If school changed, update it
        if (_selectedSchool?.Id != _currentSession.SchoolId)
        {
            _selectedSchool = await SchoolService.GetSchoolAsync(_currentSession.SchoolId);
            await LoadRegisterClasses();
        }

        await LoadLearners();
        await LoadAttendanceData();
    }

    private async Task LoadAttendanceData()
    {
        if (_currentSession == null) return;

        // Load attendance data for this session
        var sessionWithRecords = await AttendanceService.GetAsync(_currentSession.Id);

        if (sessionWithRecords?.AttendanceRecords != null)
        {
            foreach (var learner in _registerClassLearners.SelectMany(rc => rc.Value))
            {
                var record = sessionWithRecords.AttendanceRecords.FirstOrDefault(r => r.LearnerId == learner.Id);

                if (record != null)
                {
                    _attendanceData[learner.Id] = new AttendanceData
                    {
                        SignOutTime = record.End.HasValue ? record.End.Value.ToLocalTime() : DateTime.UtcNow,
                        AttendanceId = record.Id,
                        HasLeft = record.End.HasValue
                    };
                }
                else
                {
                    _attendanceData[learner.Id] = new AttendanceData
                    {
                        HasLeft = false,
                        SignOutTime = DateTime.MinValue // Default value for "Not at School"
                    };
                }
            }
        }
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        if (eventName == UiEvents.SchoolSelected && payload is School school)
        {
            // Log selection to help debug
            Console.WriteLine($"School selected: {school.LongName} (ID: {school.Id})");

            // Update selected school
            _selectedSchool = school;

            // Reset state when school changes
            _isEndTimeConfirmed = false;
            _currentSession = null;
            _registerClassLearners.Clear();
            _attendanceData.Clear();

            // Keep the current time selection (don't reset it)

            // Load new data for selected school
            await LoadRegisterClasses();
            await CheckForExistingSession();

            // Force UI update
            await InvokeAsync(StateHasChanged);
        }

        await base.HandleEventAsync(eventName, payload);
    }

    private async Task LoadRegisterClasses()
    {
        if (_selectedSchool == null) return;

        _registerClasses = await RegisterClassService.GetBySchoolIdAsync(_selectedSchool.Id);

        // Reset everything when school changes
        _registerClassLearners.Clear();
        _attendanceData.Clear();
        _registerClassFilters = ["All"];
        _registerClassNameToIdMap.Clear();
        _isEndTimeConfirmed = false;
    }

    private async Task ConfirmEndTime()
    {
        if (_selectedSchool == null) return;

        // Convert TimeOnly to DateTime for our application logic
        _endTime = DateTime.UtcNow.Date.Add(_endTimeOnly.ToTimeSpan());
        _endTimeDateTime = _endTime;
        _isEndTimeConfirmed = true;

        // Create or update attendance session
        if (_currentSession == null)
        {
            // Check both active and completed sessions
            _currentSession = await AttendanceService.GetActiveAttendanceAsync(
                _selectedSchool.Id,
               DateTime.UtcNow
            );

            if (_currentSession == null)
            {
               
                if (_currentSession == null)
                {
                
                }
            }

            await AttendanceService.UpdateAttendanceEndTimeAsync(
                _currentSession!.Id,
                _endTime
            );
        }
        else
        {
            // Update existing session with new end time
            await AttendanceService.UpdateAttendanceEndTimeAsync(
                _currentSession.Id,
                _endTime
            );
        }

        NavigationManager.NavigateTo($"/attendance/sign-out/{_currentSession.Id}");

        await LoadLearners();

        // Create or confirm attendance records for all learners with confirmed end time
        //await EnsureAttendanceRecordsExistAsync();
    }

    private async Task LoadLearners()
    {
        if (_selectedSchool == null) return;

        _registerClassLearners.Clear();
        _attendanceData.Clear();
        _registerClassFilters = ["All"];
        _registerClassNameToIdMap.Clear();

        foreach (var registerClass in _registerClasses)
        {
            if (registerClass?.SchoolGrade?.SystemGrade?.Name != null)
            {
                var className = registerClass.SchoolGrade.SystemGrade.Name;

                if (!_registerClassFilters.Contains(className))
                {
                    _registerClassFilters.Add(className);
                }

                var learners = await LearnerService.GetByRegisterClassAsync(registerClass.Id);

                if (learners.Any())
                {
                    _registerClassLearners[className] = learners;
                    _registerClassNameToIdMap[className] = registerClass.Id;

                    // Initialize attendance data for all learners as present (since they haven't left yet)
                    foreach (var learner in learners)
                    {
                        _attendanceData[learner.Id] = new AttendanceData();
                    }
                }
            }
        }

        StateHasChanged();
    }

    private void FilterByRegisterClass(string filter)
    {
        _selectedFilter = filter;
    }

