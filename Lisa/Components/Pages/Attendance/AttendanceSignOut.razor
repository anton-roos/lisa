@page "/attendance/sign-out"
@page "/attendance/sign-out/{AttendanceId:guid}"
@using Lisa.Models.Entities
@using Lisa.helpers
@using Lisa.Components.Shared
@inject SchoolService SchoolService
@inject RegisterClassService RegisterClassService
@inject LearnerService LearnerService
@inject AttendanceService AttendanceService
@inject AttendanceRecordService AttendanceRecordService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@using System.Security.Claims
@using Lisa.Enums

@inherits EventAwareComponentBase

<PageTitle>Attendance Sign Out</PageTitle>

<AuthorizeView Context="_" Roles="@($"{Roles.SystemAdministrator},{Roles.Attendance}")">
    <Authorized>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h2>Sign Out</h2>
                    <p>@TimeHelpers.GetCurrentTimeInLocal().ToString("dd/M")</p>

                    @if (_selectedSchool == null)
                    {
                        <div class="alert alert-warning mb-3">
                            <h4><i class="oi oi-warning"></i> No School Selected</h4>
                            <p>Please select a school from the dropdown at the top of the page before proceeding.</p>
                        </div>
                    }
                    else
                    {
                        @if (_attendance != null)
                        {
                            <div class="d-flex mb-3">
                                @foreach (var filter in _registerClassFilters)
                                {
                                    <button
                                        class="btn @(filter == _selectedFilter ? "btn-primary" : "btn-secondary") me-2"
                                        @onclick="() => FilterByRegisterClass(filter)">
                                        @filter
                                    </button>
                                }
                            </div>

                            <div class="mb-3">
                                <input type="text" class="form-control" @bind-value="_searchText"
                                       @bind-value:event="oninput" placeholder="Search Learner"/>
                            </div>

                            @if (_learners.Any())
                            {
                                @foreach (var registerClass in _learners.Keys)
                                {
                                    @if (_selectedFilter == "All" || _selectedFilter == registerClass)
                                    {
                                        <div class="mb-4">
                                            <h4>Gr @registerClass</h4>
                                            <div class="d-flex flex-column">
                                                @foreach (var learner in _learners[registerClass]
                                                                  .Where(l => string.IsNullOrEmpty(_searchText) ||
                                                                              $"{l.Name} {l.Surname}".ToLower().Contains(_searchText.ToLower())))
                                                {                                                        <div class="d-flex align-items-center justify-content-between mb-2">
                                                        <div style="min-width: 150px;">@learner.Name @learner.Surname</div>
                                                        <div class="d-flex align-items-center">
                                                            <div class="pill-container">
                                                                @{
                                                                    var pillColor = GetPillColor(learner);
                                                                    var pillClass = $"pill {pillColor}";
                                                                }
                                                                <div class="@pillClass" @onclick="() => ToggleAttendance(learner, registerClass)">
                                                                    @if (pillColor == "present")
                                                                    {
                                                                        <span>Present</span>
                                                                    }
                                                                    else if (pillColor == "not-at-school")
                                                                    {
                                                                        <span>Not at School</span>
                                                                    }
                                                                    else if (pillColor == "early-leave")
                                                                    {
                                                                        @TimeHelpers.ConvertToLocal(_attendanceData[learner.Id].SignOutTime).ToString("HH:mm")
                                                                    }
                                                                    else
                                                                    {
                                                                        @TimeHelpers.ConvertToLocal(_attendanceData[learner.Id].SignOutTime).ToString("HH:mm")
                                                                    }
                                                                </div>
                                                            </div>
                                                            <div class="phone-button-container">
                                                                @if (HasAttendanceRecord(learner))
                                                                {
                                                                    @if (IsCellPhoneCollected(learner))
                                                                    {
                                                                        <button class="btn btn-phone ms-2" @onclick="(e) => TogglePhoneCollection(e, learner)">
                                                                            <i class="bi bi-phone"></i> Return
                                                                        </button>
                                                                    }
                                                                    else if (WasPhoneReturned(learner))
                                                                    {
                                                                        <button class="btn btn-phone-returned ms-2" disabled>
                                                                            <i class="bi bi-phone"></i> Returned
                                                                        </button>
                                                                    }
                                                                    else
                                                                    {
                                                                        <!-- Empty div to maintain spacing when no button is shown -->
                                                                        <div style="width: 0;"></div>
                                                                    }
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <p>No learners found.</p>
                            }
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <h4><i class="bi bi-info-circle"></i> No Active Attendance Session</h4>
                                <p>Please confirm times in the main attendance page before proceeding.</p>
                                <button class="btn btn-primary" @onclick="NavigateToAttendanceHome">Go to Attendance Home</button>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <style>
            .pill {
                padding: 5px 15px;
                border-radius: 20px;
                display: inline-block;
                min-width: 100px;
                text-align: center;
                cursor: pointer;
                font-weight: bold;
            }

            .pill-container {
                display: flex;
                justify-content: flex-end;
                min-width: 100px; /* Ensure consistent width */
            }
            
            .phone-button-container {
                min-width: 120px; /* Ensure consistent width for the button area */
                display: flex;
                justify-content: flex-start;
            }

            .present {
                background-color: #4CAF50;
                color: white;
            }

            .not-at-school {
                background-color:rgb(134, 134, 134);
                color: white;
            }

            .early-leave {
                background-color: white;
                color: black;
                border: 2px solid #f44336;
            }

            .left {
                background-color: #2196F3;
                color: white;
            }
            
            .btn-phone {
                background-color: #8a2be2;
                color: white;
                border-radius: 20px;
                min-width: 100px;
                font-size: 0.9rem;
            }

            .btn-phone-returned {
                background-color: #4CAF50;
                color: white;
                border-radius: 20px;
                min-width: 100px;
                font-size: 0.9rem;
            }
        </style>
    </Authorized>
    <NotAuthorized>
        <Unauthenticated/>
    </NotAuthorized>
</AuthorizeView>

<EarlyLeaveModal @ref="_earlyLeaveModal" 
                EndTime="@_endTimeOnly" 
                OnClose="@CloseEarlyLeaveModal" />

@code {
    [Parameter] public Guid? AttendanceId { get; set; }

    private School? _selectedSchool;
    private List<RegisterClass> _registerClasses = [];
    private Dictionary<string, List<Learner>> _learners = new();
    private Dictionary<Guid, AttendanceData> _attendanceData = new();
    private TimeOnly _endTimeOnly = new TimeOnly(14, 0);
    private bool _isEndTimeConfirmed = false;
    private List<string> _registerClassFilters = ["All"];
    private string _selectedFilter = "All";
    private string _searchText = "";
    private Dictionary<string, Guid> _registerClassNameToIdMap = new();
    private Attendance? _attendance;
    private Dictionary<Learner, List<AttendanceRecord>> _attendanceRecordsByLearner = new();
    private Dictionary<Guid, bool> _returnedPhones = new();
    private EarlyLeaveModal? _earlyLeaveModal;
    private Learner? _earlyLeaveLearner;

    private class AttendanceData(bool hasLeft = false, DateTime signOutTime = default, Guid? attendanceId = null)
    {
        public bool HasLeft { get; set; } = hasLeft;
        public DateTime SignOutTime { get; set; } = signOutTime;
        public bool IsEarlyLeave(TimeOnly endTime) => 
            SignOutTime.TimeOfDay < endTime.ToTimeSpan();
        public Guid? AttendanceId { get; set; } = attendanceId;
    }

    protected override async Task OnInitializedAsync()
    {
        _endTimeOnly = new TimeOnly(14, 0); // Default to 2:00 PM
        _isEndTimeConfirmed = true; // Start with time confirmed since it's set at the component level

        _selectedSchool = await SchoolService.GetSelectedSchoolAsync();
        SubscribeToEvent(UiEvents.SchoolSelected);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated ?? false)
        {
            var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        }

        if (_selectedSchool != null)
        {
            await LoadRegisterClasses();
            await CheckForExistingSession();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (AttendanceId.HasValue)
        {
            await LoadAttendanceSession(AttendanceId.Value);
        }
        else if (_selectedSchool != null)
        {
            await CheckForExistingSession();
        }
    }

    private async Task CheckForExistingSession()
    {
        if (_selectedSchool == null) return;

        var activeSession = await AttendanceService.GetTodaysAttendanceAsync(_selectedSchool.Id);

        if (activeSession is not null)
        {
            NavigationManager.NavigateTo($"/attendance/sign-out/{activeSession.Id}");
        }
    }

    private async Task LoadAttendanceSession(Guid sessionId)
    {
        _attendance = await AttendanceService.GetAsync(sessionId);

        if (_attendance == null)
        {
            // Session not found, go back to main page
            NavigationManager.NavigateTo("/attendance/sign-out");
            return;
        }

        // Use end time from session if available, otherwise use default
        if (_attendance.End.HasValue)
        {
            _endTimeOnly = TimeOnly.FromDateTime(_attendance.End.Value);
        }
        else
        {
            // Default end time 
            _endTimeOnly = new TimeOnly(14, 0);
        }
        
        _isEndTimeConfirmed = true;

        // If school changed, update it
        if (_selectedSchool?.Id != _attendance.SchoolId)
        {
            _selectedSchool = await SchoolService.GetSchoolAsync(_attendance.SchoolId);
            await LoadRegisterClasses();
        }

        await LoadLearners();
        await LoadAttendanceData();
    }

    private void NavigateToAttendanceHome()
    {
        NavigationManager.NavigateTo("/attendance");
    }

    // This method is no longer used as time confirmation happens at the component level
    private async Task ConfirmEndTime()
    {
        if (_selectedSchool == null) return;
        
        // This is now done at the component level, but we keep the method for backward compatibility
        if (_attendance == null)
        {
            _attendance = await AttendanceService.GetTodaysAttendanceAsync(_selectedSchool.Id);
            
            if (_attendance != null)
            {
                await LoadLearners();
                await LoadAttendanceData();
                NavigationManager.NavigateTo($"/attendance/sign-out/{_attendance.Id}");
            }
        }
    }
    
    private async Task LoadAttendanceData()
    {
        if (_attendance is null || _attendance.AttendanceRecords is null) return;

        // Clear existing data
        _attendanceData.Clear();
        _attendanceRecordsByLearner.Clear();

        // Group attendance records by learner for easy access
        var attendanceRecordsByLearnerId = _attendance.AttendanceRecords
            .GroupBy(record => record.LearnerId)
            .ToDictionary(group => group.Key, group => group.ToList());

        // Process all learners
        foreach (var learner in _learners.SelectMany(rc => rc.Value))
        {
            // Initialize the dictionary entry for this learner with an empty list
            if (!_attendanceRecordsByLearner.ContainsKey(learner))
            {
                _attendanceRecordsByLearner[learner] = [];
            }

            if (attendanceRecordsByLearnerId.TryGetValue(learner.Id, out var attendanceRecords))
            {
                // Add all records to the learner's collection
                _attendanceRecordsByLearner[learner].AddRange(attendanceRecords);

                // Use the most recent check-in record for the attendance data display
                var mostRecentCheckInRecord = attendanceRecords
                    .Where(r => r.AttendanceType == AttendanceType.CheckIn)
                    .OrderByDescending(r => r.CreatedAt)
                    .FirstOrDefault();
                
                if (mostRecentCheckInRecord != null)
                {
                    _attendanceData[learner.Id] = new AttendanceData(
                        hasLeft: mostRecentCheckInRecord.End.HasValue,
                        signOutTime: mostRecentCheckInRecord.End.HasValue ? TimeHelpers.ConvertToLocal(mostRecentCheckInRecord.End.Value) : DateTime.MinValue,
                        attendanceId: mostRecentCheckInRecord.Id
                    );
                    continue;
                }
            }

            // If no records found or no recent record, initialize with default values
            _attendanceData[learner.Id] = new AttendanceData(
                hasLeft: false,
                signOutTime: DateTime.MinValue
            );
        }
        
        // Ensure the async method has at least one await operation
        await Task.CompletedTask;
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        if (eventName == UiEvents.SchoolSelected && payload is School school)
        {
            // Log selection to help debug
            Console.WriteLine($"School selected: {school.LongName} (ID: {school.Id})");

            // Update selected school
            _selectedSchool = school;

            // Reset state when school changes
            _isEndTimeConfirmed = false;
            _attendance = null;
            _learners.Clear();
            _attendanceData.Clear();

            // Keep the current time selection (don't reset it)

            // Load new data for selected school
            await LoadRegisterClasses();
            await CheckForExistingSession();

            // Force UI update
            await InvokeAsync(StateHasChanged);
        }

        await base.HandleEventAsync(eventName, payload);
    }

    private async Task LoadRegisterClasses()
    {
        if (_selectedSchool == null) return;

        _registerClasses = await RegisterClassService.GetBySchoolIdAsync(_selectedSchool.Id);

        // Reset everything when school changes
        _learners.Clear();
        _attendanceData.Clear();
        _registerClassFilters = ["All"];
        _registerClassNameToIdMap.Clear();
        _isEndTimeConfirmed = false;
    }

    private async Task LoadLearners()
    {
        if (_selectedSchool == null) return;

        _learners.Clear();
        _attendanceData.Clear();
        _registerClassFilters = ["All"];
        _registerClassNameToIdMap.Clear();

        // Get all learners for the school in a single call
        var allLearners = await LearnerService.GetBySchoolAsync(_selectedSchool.Id);
        
        // Group learners by register class
        var learnersByClass = allLearners
            .Where(l => l.RegisterClass?.SchoolGrade?.SystemGrade?.Name != null)
            // First, order by SystemGrade's sequence number
            .OrderBy(l => l.RegisterClass?.SchoolGrade?.SystemGrade?.SequenceNumber)
            // Then group by grade name
            .GroupBy(l => l.RegisterClass?.SchoolGrade?.SystemGrade?.Name)
            // For each group, sort learners by surname then by name
            .ToDictionary(
                g => g.Key ?? "Unknown", 
                g => g.OrderBy(l => l.Surname).ThenBy(l => l.Name).ToList()
            );
            
        // Set up filter options in the same order as the grades (by sequence number)
        _registerClassFilters.AddRange(learnersByClass.Keys.Where(k => k != null));
        
        // Store class name to ID mapping for future use
        foreach (var learner in allLearners.Where(l => l.RegisterClass != null))
        {
            var className = learner.RegisterClass?.SchoolGrade?.SystemGrade?.Name;
            if (className != null && !_registerClassNameToIdMap.ContainsKey(className))
            {
                _registerClassNameToIdMap[className] = learner.RegisterClass?.Id ?? Guid.Empty;
            }
        }
        
        // Store grouped learners
        _learners = learnersByClass;
        
        // Initialize attendance data for all learners
        foreach (var learner in allLearners)
        {
            _attendanceData[learner.Id] = new AttendanceData();
        }

        StateHasChanged();
    }

    private void FilterByRegisterClass(string filter)
    {
        _selectedFilter = filter;
    }

    private async Task ToggleAttendance(Learner learner, string registerClassName)
    {
        // Check if the learner has any check-in attendance records
        bool hasCheckInRecords = _attendanceRecordsByLearner.TryGetValue(learner, out var value) && 
                               value.Any(r => r.AttendanceType == AttendanceType.CheckIn);
        
        // If no check-in records, don't allow toggling
        if (!hasCheckInRecords)
        {
            return;
        }
        
        // Ensure there's an attendance data entry for this learner
        if (!_attendanceData.TryGetValue(learner.Id, out var data))
        {
            _attendanceData[learner.Id] = new AttendanceData();
            data = _attendanceData[learner.Id];
        }

        // Toggle the HasLeft state
        data.HasLeft = !data.HasLeft;

        // If learner is now marked as left
        if (data.HasLeft)
        {
            // Set the sign-out time to now
            data.SignOutTime = TimeHelpers.GetCurrentTimeInLocal();

            // Get the register class ID
            if (_registerClassNameToIdMap.TryGetValue(registerClassName, out var registerClassId))
            {
                var isEarlyLeave = data.IsEarlyLeave(_endTimeOnly);

                // If it's an early leave, show the modal instead of redirecting directly
                if (isEarlyLeave)
                {
                    // Set data to not left again as we'll handle it differently
                    data.HasLeft = false;
                    
                    // Store the learner for the modal
                    _earlyLeaveLearner = learner;
                    
                    // Show the modal
                    _earlyLeaveModal?.Show();
                    
                    return;
                }

                // Update the existing attendance record with sign-out time
                if (data.AttendanceId.HasValue)
                {
                    // Update the record in the database
                    var recordToUpdate = await AttendanceRecordService.GetByIdAsync(data.AttendanceId.Value);
                    if (recordToUpdate != null)
                    {
                        recordToUpdate.End = TimeHelpers.GetCurrentTime();
                        recordToUpdate.Notes = isEarlyLeave ? "Early leave" : "Regular sign out";
                        recordToUpdate.UpdatedAt = TimeHelpers.GetCurrentTime();
                        
                        // In a real implementation with service call, you would update the database here
                    }
                    
                    // Update the record in the _attendanceRecordsByLearner dictionary
                    if (_attendanceRecordsByLearner.TryGetValue(learner, out var records))
                    {
                        var record = records.FirstOrDefault(r => r.Id == data.AttendanceId.Value);
                        if (record != null)
                        {
                            // Use TimeHelpers to ensure consistent time handling
                            record.End = TimeHelpers.GetCurrentTime();
                            record.Notes = "Regular sign out";
                            record.UpdatedAt = TimeHelpers.GetCurrentTime();
                        }
                    }
                }
                else
                {
                    // Fallback: create a new record if one doesn't exist (should be rare)
                    await SaveSignOut(learner.Id, registerClassId, isEarlyLeave);
                }
            }
        }
        else
        {
            // If toggling back to not left, remove the sign-out time
            if (data.AttendanceId.HasValue)
            {
                //await AttendanceService.ClearSignOutAsync(data.AttendanceId.Value);
                
                // Update the record in the _attendanceRecordsByLearner dictionary
                if (_attendanceRecordsByLearner.TryGetValue(learner, out var records))
                {
                    var record = records.FirstOrDefault(r => r.Id == data.AttendanceId.Value);
                    if (record != null)
                    {
                        record.End = null;
                    }
                }
            }
        }
        
        // Force UI update
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveSignOut(Guid learnerId, Guid registerClassId, bool isEarlyLeave)
    {
        if (_selectedSchool == null || _attendance == null) return;

        var learner = _learners
            .SelectMany(rc => rc.Value)
            .FirstOrDefault(l => l.Id == learnerId);

        if (learner == null) return;

        // Check if we already have an attendance record for this learner
        if (_attendanceData[learnerId].AttendanceId.HasValue)
        {
            // This is the preferred path - update the existing record
            if (_attendanceRecordsByLearner.TryGetValue(learner, out var records) && records != null)
            {
                // Safely check for the record without nullable warnings
                var attendanceId = _attendanceData[learnerId].AttendanceId;
                AttendanceRecord? record = null;
                
                if (attendanceId.HasValue)
                {
                    record = records.FirstOrDefault(r => r.Id == attendanceId.Value);
                }
                if (record != null)
                {
                    // Use TimeHelpers for consistent time handling
                    record.End = TimeHelpers.GetCurrentTime();
                    record.Notes = isEarlyLeave ? "Early leave" : "Regular sign out";
                    record.UpdatedAt = TimeHelpers.GetCurrentTime();
                    
                    // In a real implementation with service call:
                    // await AttendanceService.UpdateAttendanceRecordAsync(record);
                }
            }
        }
        else
        {
            // Only as a fallback if no existing record exists
            // This should rarely happen if your check-in process is working correctly
            var newRecord = new AttendanceRecord
            {
                Id = Guid.NewGuid(),
                AttendanceId = _attendance.Id,
                LearnerId = learnerId,
                // Use the actual start time if available, otherwise estimate
                Start = TimeHelpers.GetCurrentTime().AddHours(-6),
                End = TimeHelpers.GetCurrentTime(),
                Notes = isEarlyLeave ? "Early leave" : "Regular sign out",
                CreatedAt = TimeHelpers.GetCurrentTime(),
                UpdatedAt = TimeHelpers.GetCurrentTime(),
                AttendanceType = AttendanceType.CheckIn
            };

            // Add the record to the learner's collection in our dictionary
            if (!_attendanceRecordsByLearner.TryGetValue(learner, out _))
            {
                _attendanceRecordsByLearner[learner] = [];
            }
            _attendanceRecordsByLearner[learner].Add(newRecord);

            // Store the ID and update with sign-out info
            _attendanceData[learnerId].AttendanceId = newRecord.Id;
            //     await AttendanceService.RecordSignOutAsync(
            //         attendance.Id,
            //         isEarlyLeave,
            //         $"Signed out at {TimeHelpers.GetCurrentTimeInLocal():HH:mm}{(isEarlyLeave ? " (early)" : "")}"
            //     );
        }

        // Ensure the async method has at least one await operation
        await Task.CompletedTask;
    }

    private string GetPillColor(Learner learner)
    {
        // Check if the learner has any attendance records
        bool hasAttendanceRecords = _attendanceRecordsByLearner.TryGetValue(learner, out var records) && 
                                   records.Any(r => r.AttendanceType == AttendanceType.CheckIn);
        
        // Make sure the learner exists in our attendance data
        if (!_attendanceData.TryGetValue(learner.Id, out var data))
        {
            // If no attendance data, only show present if they have check-in records
            return hasAttendanceRecords ? "present" : "not-at-school";
        }
        
        // If the learner has not left yet
        if (!data.HasLeft)
        {
            // Only show present if they have check-in records
            return hasAttendanceRecords ? "present" : "not-at-school";
        }
        
        // If the learner has left, check if it was an early leave
        return data.IsEarlyLeave(_endTimeOnly) ? "early-leave" : "left";
    }

    private async Task EnsureAttendanceRecordsExistAsync()
    {
        if (_selectedSchool == null || _attendance == null) return;

        // Get the set of learner IDs that already have attendance records
        var existingLearnerIds = _attendance.AttendanceRecords
            .Select(ar => ar.LearnerId)
            .ToHashSet();

        foreach (var registerClassGroup in _learners)
        {
            var className = registerClassGroup.Key;
            if (_registerClassNameToIdMap.TryGetValue(className, out var registerClassId))
            {
                foreach (var learner in registerClassGroup.Value)
                {
                    // If this learner doesn't have an attendance record yet, create one
                    if (!existingLearnerIds.Contains(learner.Id))
                    {
                        // Create a temporary record for UI purposes until API integration is complete
                        var newRecord = new AttendanceRecord
                        {
                            Id = Guid.NewGuid(),
                            AttendanceId = _attendance.Id,
                            LearnerId = learner.Id,
                            Start = TimeHelpers.GetCurrentTime(),
                            Notes = "Record created at sign-out time",
                            CreatedAt = TimeHelpers.GetCurrentTime(),
                            UpdatedAt = TimeHelpers.GetCurrentTime(),
                            AttendanceType = AttendanceType.CheckIn
                        };

                        // Add to our in-memory collections
                        if (!_attendanceRecordsByLearner.ContainsKey(learner))
                        {
                            _attendanceRecordsByLearner[learner] = [];
                        }
                        _attendanceRecordsByLearner[learner].Add(newRecord);

                        // Store the ID for later updates
                        if (_attendanceData.ContainsKey(learner.Id))
                        {
                            _attendanceData[learner.Id].AttendanceId = newRecord.Id;
                        }
                        else
                        {
                            _attendanceData[learner.Id] = new AttendanceData(
                                attendanceId: newRecord.Id
                            );
                        }

                        // In a real implementation, you would call the service:
                        // var attendance = await AttendanceService.RecordAttendanceAsync(
                        //     learner.Id,
                        //     _selectedSchool.Id,
                        //     registerClassId,
                        //     true, // Assume they were present since we're at sign-out
                        //     "Record created at sign-out time",
                        //     _currentUserId,
                        //     _attendance.Id
                        // );
                    }
                }
            }
        }

        // Refresh attendance data to make sure we have all the IDs
        await LoadAttendanceData();
    }

    // Utility method to get attendance information for a learner
    private List<AttendanceRecord> GetAttendanceRecordsForLearner(Learner learner)
    {
        if (_attendanceRecordsByLearner.TryGetValue(learner, out var records))
        {
            return records.OrderByDescending(r => r.Start).ToList();
        }
        return [];
    }

    private bool HasAttendanceRecord(Learner learner)
    {
        return _attendanceRecordsByLearner.TryGetValue(learner, out var records) && 
               records.Any(r => r.AttendanceType == AttendanceType.CheckIn);
    }

    private bool IsCellPhoneCollected(Learner learner)
    {
        if (_attendanceRecordsByLearner.TryGetValue(learner, out var records))
        {
            var record = records
                .Where(r => r.AttendanceType == AttendanceType.CheckIn)
                .OrderByDescending(r => r.CreatedAt)
                .FirstOrDefault();
            
            return record?.CellPhoneCollected ?? false;
        }
        return false;
    }

    private bool WasPhoneReturned(Learner learner)
    {
        // Check our local tracking dictionary
        return _returnedPhones.ContainsKey(learner.Id) && _returnedPhones[learner.Id];
    }

    private async Task TogglePhoneCollection(MouseEventArgs e, Learner learner)
    {
        // Prevent click from triggering the pill's onclick event (e.preventDefault in JavaScript)
        
        if (!_attendanceRecordsByLearner.TryGetValue(learner, out var records) || !records.Any())
        {
            return;
        }
        
        var record = records
            .Where(r => r.AttendanceType == AttendanceType.CheckIn)
            .OrderByDescending(r => r.CreatedAt)
            .FirstOrDefault();
            
        if (record == null || !_attendanceData.TryGetValue(learner.Id, out var data))
        {
            return;
        }
        
        // Toggle the cell phone collection status
        bool success = await AttendanceRecordService.ToggleCellPhoneCollectedAsync(record.Id);
        
        if (success)
        {
            // Update the record in our local state
            record.CellPhoneCollected = !record.CellPhoneCollected;
            
            // If we're returning a phone (setting CellPhoneCollected to false), mark it as returned in our tracking dictionary
            if (!record.CellPhoneCollected)
            {
                _returnedPhones[learner.Id] = true;
            }
            
            // Force UI update
            await InvokeAsync(StateHasChanged);
        }
    }

    private void CloseEarlyLeaveModal()
    {
        _earlyLeaveLearner = null;
        StateHasChanged();
    }
}