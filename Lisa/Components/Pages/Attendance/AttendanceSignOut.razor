@page "/attendance/sign-out"
@page "/attendance/sign-out/{AttendanceSessionId:guid}"
@using Lisa.Models.Entities
@inject SchoolService SchoolService
@inject RegisterClassService RegisterClassService
@inject LearnerService LearnerService
@inject AttendanceService AttendanceService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@using System.Security.Claims

@inherits EventAwareComponentBase

<PageTitle>Attendance Sign Out</PageTitle>

<AuthorizeView Context="_" Roles="@($"{Roles.SystemAdministrator},{Roles.Attendance}")">
    <Authorized>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h2>Sign Out</h2>
                    <p>@DateTime.UtcNow.ToString("dd/M")</p>

                    @if (_selectedSchool == null)
                    {
                        <div class="alert alert-warning mb-3">
                            <h4><i class="oi oi-warning"></i> No School Selected</h4>
                            <p>Please select a school from the dropdown at the top of the page before proceeding.</p>
                        </div>
                    }
                    else
                    {
                        <div class="input-group mb-3">
                            <input type="time" class="form-control" @bind="_endTimeOnly"/>
                            <button class="btn btn-primary" @onclick="ConfirmEndTime" disabled="@_isEndTimeConfirmed">
                                Confirm
                            </button>
                        </div>
                        <div class="mb-3">
                            <small class="text-muted">End time: @_endTimeOnly.ToString("HH:mm")</small>
                        </div>

                        @if (_isEndTimeConfirmed)
                        {
                            <div class="d-flex mb-3">
                                @foreach (var filter in _registerClassFilters)
                                {
                                    <button
                                        class="btn @(filter == _selectedFilter ? "btn-primary" : "btn-secondary") me-2"
                                        @onclick="() => FilterByRegisterClass(filter)">
                                        @filter
                                    </button>
                                }
                            </div>

                            <div class="mb-3">
                                <input type="text" class="form-control" @bind-value="_searchText"
                                       @bind-value:event="oninput" placeholder="Search Learner"/>
                            </div>

                            @if (_registerClassLearners.Any())
                            {
                                @foreach (var registerClass in _registerClassLearners.Keys)
                                {
                                    @if (_selectedFilter == "All" || _selectedFilter == registerClass)
                                    {
                                        <div class="mb-4">
                                            <h4>Gr @registerClass</h4>
                                            <div class="d-flex flex-column">
                                                @foreach (var learner in _registerClassLearners[registerClass]
                                                                  .Where(l => string.IsNullOrEmpty(_searchText) ||
                                                                              $"{l.Name} {l.Surname}".ToLower().Contains(_searchText.ToLower())))
                                                {
                                                    <div class="d-flex align-items-center mb-2">
                                                        <div class="me-3"
                                                             style="min-width: 150px;">@learner.Name @learner.Surname</div>
                                                        <div @onclick="() => ToggleAttendance(learner, registerClass)">
                                                            @{
                                                                var pillColor = GetPillColor(learner);
                                                                var pillClass = $"pill {pillColor}";
                                                            }
                                                            <div class="@pillClass">
                                                                @if (pillColor == "present")
                                                                {
                                                                    <span>Present</span>
                                                                }
                                                                else if (pillColor == "early-leave")
                                                                {
                                                                    @_attendanceData[learner.Id].SignOutTime.ToString("HH:mm")
                                                                }
                                                                else
                                                                {
                                                                    @_attendanceData[learner.Id].SignOutTime.ToString("HH:mm")
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <p>No learners found.</p>
                            }
                        }
                    }
                </div>
            </div>
        </div>

        <style>
            .pill {
                padding: 5px 15px;
                border-radius: 20px;
                display: inline-block;
                min-width: 100px;
                text-align: center;
                cursor: pointer;
                font-weight: bold;
            }

            .present {
                background-color: #4CAF50;
                color: white;
            }

            .early-leave {
                background-color: white;
                color: black;
                border: 2px solid #f44336;
            }

            .left {
                background-color: #2196F3;
                color: white;
            }
        </style>
    </Authorized>
    <NotAuthorized>
        <Unauthenticated/>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public Guid? AttendanceSessionId { get; set; }

    private School? _selectedSchool;
    private List<RegisterClass> _registerClasses = [];
    private Dictionary<string, List<Learner>> _registerClassLearners = new();
    private Dictionary<Guid, AttendanceData> _attendanceData = new();
    private DateTime _endTime = DateTime.UtcNow.Date.AddHours(14); // Default to 2:00 PM
    private TimeOnly _endTimeOnly = new TimeOnly(14, 0); // Default to 2:00 PM for the input
    private bool _isEndTimeConfirmed = false;
    private DateTime _endTimeDateTime;
    private List<string> _registerClassFilters = ["All"];
    private string _selectedFilter = "All";
    private string _searchText = "";
    private Dictionary<string, Guid> _registerClassNameToIdMap = new();
    private Guid? _currentUserId;
