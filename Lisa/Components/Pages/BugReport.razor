@page "/bug-report"
@inject BugReportService BugReportService
@inject IJSRuntime JSRuntime

<PageTitle>Bug Reports</PageTitle>

<h3>Bug Reports</h3>

@if (isLoading)
{
    <p>Loading bug reports...</p>
}
else if (!bugReports.Any())
{
    <p>No bug reports found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Description</th>
                <th>Page URL</th>
                <th>Version</th>
                <th>Reported By</th>
                <th>Reported At</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var bug in bugReports)
            {
                <tr>
                    <td>@bug.Id</td>
                    <td>@bug.Description</td>
                    <td>
                        <a href="@bug.PageUrl" target="_blank">@bug.PageUrl</a>
                    </td>
                    <td>@bug.Version</td>
                    <td>@bug.ReportedBy</td>
                    <td>@bug.ReportedAt.ToString("g")</td>
                    <td>
                        <InputSelect class="form-select" id="SelectedSchoolId" TValue="string" Value="@SelectedSchoolId"
                            ValueChanged="UpdateBugStatusAsync" ValueExpression="@(() => SelectedSchoolId)">
                            <option value="">-- Select School --</option>
                            @foreach (var school in schools!)
                            {
                                <option value="@school.Id.ToString()">@school.ShortName</option>
                            }
                        </InputSelect>
                        <select @bind="bug.Status" @onchange="(e) => UpdateBugStatusAsync(bug)">
                            <option value="Open">Open</option>
                            <option value="Resolved">Resolved</option>
                            <option value="Closed">Closed</option>
                        </select>
                    </td>
                    <td>
                        <button class="btn btn-danger" @onclick="() => DeleteBugAsync(bug.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<BugReport> bugReports = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            bugReports = await BugReportService.GetAllAsync();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error loading bug reports: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateBugStatusAsync(BugReport bug)
    {
        try
        {
            await BugReportService.UpdateStatusAsync(bug.Id, bug.Status);
            await JSRuntime.InvokeVoidAsync("alert", "Bug status updated successfully!");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error updating bug status: {ex.Message}");
        }
    }

    private async Task DeleteBugAsync(Guid bugId)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this bug report?"))
        {
            return;
        }

        try
        {
            await BugReportService.DeleteBugAsync(bugId);
            bugReports = bugReports.Where(b => b.Id != bugId).ToList();
            await JSRuntime.InvokeVoidAsync("alert", "Bug report deleted successfully!");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error deleting bug report: {ex.Message}");
        }
    }
}
