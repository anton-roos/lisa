@page "/bug-reports/details/{BugId:guid}"
@using Lisa.Models.Entities
@inject BugReportService BugReportService
@inject NavigationManager NavigationManager
@inject ILogger<BugReportDetails> Logger

<PageTitle>Bug Report Details</PageTitle>
<AuthorizeView Context="_" Roles="@($"{Roles.SystemAdministrator}")">
    <Authorized>
        @if (_isLoading)
        {
            <p>Loading bug details...</p>
        }
        else if (_bug == null)
        {
            <p class="text-danger">Unable to load bug details. Please try again later.</p>
        }
        else
        {
            <div class="card">
                <div class="card-header">
                    <h3>Bug Report Details</h3>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Bug ID:</dt>
                        <dd class="col-sm-9">@_bug.Id</dd>

                        <dt class="col-sm-3">Reported At:</dt>
                        <dd class="col-sm-9">@_bug.ReportedAt.ToString("g")</dd>

                        <dt class="col-sm-3">Page URL:</dt>
                        <dd class="col-sm-9">
                            <a href="@_bug.PageUrl" target="_blank">@_bug.PageUrl</a>
                        </dd>

                        <dt class="col-sm-3">Version:</dt>
                        <dd class="col-sm-9">@_bug.Version</dd>

                        <dt class="col-sm-3">Reported By:</dt>
                        <dd class="col-sm-9">@_bug.ReportedBy</dd>

                        <dt class="col-sm-3">User Authenticated:</dt>
                        <dd class="col-sm-9">@_bug.UserAuthenticated</dd>

                        <dt class="col-sm-3">Action:</dt>
                        <dd class="col-sm-9">@_bug.WhatTried</dd>

                        <dt class="col-sm-3">Incident:</dt>
                        <dd class="col-sm-9">@_bug.WhatHappened</dd>

                        <dt class="col-sm-3">Status:</dt>
                        <dd class="col-sm-9">@_bug.Status</dd>

                        <dt class="col-sm-3">Resolved At:</dt>
                        <dd class="col-sm-9">@(_bug.ResolvedAt?.ToString("g") ?? "N/A")</dd>

                        <dt class="col-sm-3">Closed At:</dt>
                        <dd class="col-sm-9">@(_bug.ClosedAt?.ToString("g") ?? "N/A")</dd>
                    </dl>
                    <button class="btn btn-secondary" @onclick="NavigateBack">Back to Bug List</button>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <Unauthorized />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public Guid BugId { get; set; }

    private BugReport? _bug;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Fetch the bug details based on the BugId
            _bug = await BugReportService.GetAsync(BugId);
        }
        catch (Exception ex)
        {
           Logger.LogError("Error fetching bug details: {ex.Message}", ex.Message);
            _bug = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/bug-reports");
    }
}
