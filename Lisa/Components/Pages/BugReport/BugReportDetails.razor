@page "/bug-reports/{BugId:guid}"
@using Lisa.Models.Entities
@inject BugReportService BugReportService
@inject NavigationManager NavigationManager

@if (isLoading)
{
    <p>Loading bug details...</p>
}
else if (bug == null)
{
    <p class="text-danger">Unable to load bug details. Please try again later.</p>
}
else
{
    <div class="card">
        <div class="card-header">
            <h3>Bug Report Details</h3>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Bug ID:</dt>
                <dd class="col-sm-9">@bug.Id</dd>

                <dt class="col-sm-3">Reported At:</dt>
                <dd class="col-sm-9">@bug.ReportedAt.ToString("g")</dd>

                <dt class="col-sm-3">Page URL:</dt>
                <dd class="col-sm-9">
                    <a href="@bug.PageUrl" target="_blank">@bug.PageUrl</a>
                </dd>

                <dt class="col-sm-3">Version:</dt>
                <dd class="col-sm-9">@bug.Version</dd>

                <dt class="col-sm-3">Reported By:</dt>
                <dd class="col-sm-9">@bug.ReportedBy</dd>

                <dt class="col-sm-3">User Authenticated:</dt>
                <dd class="col-sm-9">@bug.UserAuthenticated</dd>

                <dt class="col-sm-3">Action:</dt>
                <dd class="col-sm-9">@bug.WhatTried</dd>
                
                <dt class="col-sm-3">Incident:</dt>
                <dd class="col-sm-9">@bug.WhatHappened</dd>

                <dt class="col-sm-3">Status:</dt>
                <dd class="col-sm-9">@bug.Status</dd>

                <dt class="col-sm-3">Is Resolved:</dt>
                <dd class="col-sm-9">@bug.IsResolved</dd>

                <dt class="col-sm-3">Resolved At:</dt>
                <dd class="col-sm-9">@bug.ResolvedAt?.ToString("g") ?? "N/A"</dd>
            </dl>
            <button class="btn btn-secondary" @onclick="NavigateBack">Back to Bug List</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid BugId { get; set; }

    private BugReport? bug;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Fetch the bug details based on the BugId
            bug = await BugReportService.GetAsync(BugId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching bug details: {ex.Message}");
            bug = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/bug-reports");
    }
}