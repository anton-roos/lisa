@page "/combinations"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject CombinationService CombinationService
@inject GradeService GradeService
@inherits EventAwareComponentBase
@inject SchoolService SchoolService

<AuthorizeView Context="authContext" Roles="@Roles.SystemAdministrator">
    <Authorized>

        @if (SelectedSchool == null)
        {
            <div class="alert alert-info">
                Please select a school to view subject combinations.
            </div>
        }
        else if (SubjectCombinations == null)
        {
            <p>Loading...</p>
        }
        else if (Grades == null || !Grades.Any())
        {
            <h3>Combinations</h3>
            <button class="btn btn-primary mb-3" @onclick="AddCombination">Add Combination</button>
            <div class="alert alert-warning">
                No Grades found. Please add a grade first before adding Subject combination.
            </div>
        }
        else if (!SubjectCombinations.Any())
        {
            <h3>Combinations</h3>
            <button class="btn btn-primary mb-3" @onclick="AddCombination">Add Combination</button>
            <div class="alert alert-info">
                No Subject Combinations found.
            </div>
        }
        else
        {
            <h3>Combinations</h3>
            <button class="btn btn-primary mb-3" @onclick="AddCombination">Add Combination</button>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Grade</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var combination in SubjectCombinations)
                    {
                        <tr>
                            <td>@combination.Name</td>
                            <td>@combination.Grade?.Name</td>
                            <ActionButtons TEntity="Combination" Entity="combination" OnView="ViewCombination"
                                OnEdit="EditCombination" OnDelete="DeleteCombination" />
                        </tr>
                    }
                </tbody>
            </table>
        }
    </Authorized>
    <NotAuthorized>
        <Unauthorized />
    </NotAuthorized>
</AuthorizeView>

@code {
    private IEnumerable<Combination>? SubjectCombinations;
    private IEnumerable<Grade>? Grades;
    private School? SelectedSchool;

    protected override async Task OnInitializedAsync()
    {
        SubscribeToEvent(UiEvents.SchoolSelected);
        await LoadCombinations();
    }

    public async Task LoadCombinations()
    {
        SelectedSchool = SchoolService.GetSelectedSchool();
        if (SelectedSchool != null)
        {
            Grades = await GradeService.GetGradesForSchool(SelectedSchool.Id);
            SubjectCombinations = await CombinationService.GetSubjectCombinationsForSchool(SelectedSchool);
        }
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                SelectedSchool = payload as School;
                await LoadCombinations();
                break;
        }

        await base.HandleEventAsync(eventName, payload);
    }

    private void AddCombination()
    {
        Navigation.NavigateTo("/combinations/add");
    }

    private void ViewCombination(Combination combination)
    {
        Navigation.NavigateTo($"/combinations/details/{combination.Id}");
    }

    private void EditCombination(Combination combination)
    {
        Navigation.NavigateTo($"/combinations/edit/{combination.Id}");
    }

    private async Task DeleteCombination(Combination combination)
    {
        var Combination = await CombinationService.GetByIdAsync(combination.Id);
        if (Combination != null)
        {
            await CombinationService.DeleteAsync(Combination.Id);
            await LoadCombinations();
            await InvokeAsync(StateHasChanged);
        }
    }
}
