@page "/communication"
@using Lisa.Enums
@using Lisa.Models.Entities
@using Lisa.Models.EmailModels
@using Lisa.Components.Layout.Communciation
@inject SchoolService SchoolService
@inject SchoolGradeService SchoolGradeService
@inject SubjectService SubjectService
@inject LearnerService LearnerService
@inject CommunicationService CommunicationService
@inject EmailRendererService RendererService
@inject NavigationManager NavigationManager

@inherits EventAwareComponentBase

<PageTitle>Send Communication</PageTitle>
<AuthorizeView Context="_" Roles="@($"{Roles.SystemAdministrator},{Roles.Principal},{Roles.SchoolManagement}")">
    <Authorized>
        @if (SelectedSchool == null)
        {
            <div class="alert alert-info">
                Please select a school to send communication.
            </div>
        }
        else
        {
            <h3>Send Communication</h3>
            <CommunicationTypeSelector SelectedTarget="@SelectedTarget" OnTargetChanged="OnOptionChanged" />

            @switch (SelectedTarget)
            {
                case CommunicationTarget.School:
                    <div class="mb-3">
                        <label for="audienceSelect">Select Audience</label>
                        <InputSelect id="audienceSelect" class="form-select" TValue="string"
                            ValueChanged="@(async (id) => await AudienceChanged(id))" ValueExpression="(() => SelectedAudienceId)">
                            <option value="@string.Empty">-- Select Audience --</option>
                            @foreach (var audience in _audiences)
                            {
                                <option value="@audience.Key">@audience.Value</option>
                            }
                        </InputSelect>
                    </div>
                    break;

                case CommunicationTarget.SchoolGrade:
                    <div class="mb-3">
                        <label for="gradeSelect">Select Grade</label>
                        <InputSelect id="gradeSelect" class="form-select" @bind-Value="SelectedGradeId"
                            @onchange="HandleGradeChange">
                            <option value="@string.Empty">-- Select Grade --</option>
                            @foreach (var grade in _schoolGrades)
                            {
                                <option value="@grade.Id">@grade.SystemGrade.Name</option>
                            }
                        </InputSelect>
                    </div>
                    break;

                case CommunicationTarget.Subject:
                    <div class="mb-3">
                        <label for="subjectSelect">Select Subject</label>
                        <InputSelect id="subjectSelect" class="form-select" @bind-Value="SelectedSubjectId"
                            @onchange="@(async (e) => OnSubjectSelected((int)e.Value))">
                            <option value="@string.Empty">-- Select Subject --</option>
                            @foreach (var subject in _subjects)
                            {
                                <option value="@subject.Id">@subject.Name</option>
                            }
                        </InputSelect>
                    </div>

                    break;

                case CommunicationTarget.Learner:
                    <div class="mb-3">
                        <label for="learnerSearch">Search by Name:</label>
                        <input id="learnerSearch" type="text" class="form-control" placeholder="Enter learner name..."
                            @bind="SearchTerm" @bind:event="oninput" />
                    </div>

                    @if (IsLoading)
                    {
                        <div class="text-center">
                            <i class="bi bi-hourglass-split text-primary"></i> Loading...
                        </div>
                    }
                    else if (!Learners.Any())
                    {
                        <div class="text-center text-muted">No learners found.</div>
                    }
                    else
                    {
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Grade</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var learner in Learners)
                                {
                                    <tr>
                                        <td>@learner.Surname @learner.Name</td>
                                        <td>@learner.RegisterClass?.SchoolGrade?.SystemGrade.Name</td>
                                        <td>
                                            <button class="btn btn-primary btn-sm" @onclick="() => SendCommunication(learner)"
                                                disabled="@IsSending">
                                                <i class="bi bi-envelope-fill"></i> Send Communication
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    break;
            }

            <!-- Template selection integrated from the Template module -->
            <TemplateSelection OnTemplateSelected="OnTemplateSelected" />

            <!-- Optional preview button -->
            @if (SelectedTemplate != null)
            {
                <button class="btn btn-secondary btn-sm mt-2" @onclick="PreviewTemplate">
                    <i class="bi bi-eye"></i> Preview Template
                </button>
            }

            <button type="button" class="btn btn-primary btn-sm mt-2" @onclick="SendCommunication"
                disabled="@(IsSendDisabled || IsSending)">
                @if (IsSending)
                {
                    <i class="bi bi-hourglass-split">Sending...</i>
                }
                else
                {
                    <i class="bi bi-envelope-arrow-up">Send Communication</i>
                }
            </button>

            @if (!string.IsNullOrEmpty(StatusMessage))
            {
                <div class="alert alert-info mt-2">@StatusMessage</div>
            }

            @if (!string.IsNullOrEmpty(PreviewHtml))
            {
                <div class="card mt-3">
                    <div class="card-header">Template Preview</div>
                    <div class="card-body">
                        @((MarkupString)PreviewHtml)
                    </div>
                </div>
            }
        }
    </Authorized>
    <NotAuthorized>
        <Unauthorized />
    </NotAuthorized>
</AuthorizeView>

@code {
    private CommunicationTarget SelectedTarget { get; set; } = CommunicationTarget.School;
    private string? SearchTerm { get; set; }
    private List<Learner> _learners = new();
    private IEnumerable<Learner> FilteredLearners => ApplyFilters();
    private School? SelectedSchool { get; set; }
    private Guid? SelectedGradeId { get; set; }
    private string? SelectedSchoolAudienceId { get; set; }
    private List<SchoolGrade> _schoolGrades = new();
    private List<Subject> _subjects = new();
    private int SelectedSubjectId { get; set; }
    private EmailTemplate? SelectedTemplate { get; set; }
    private bool IsSendDisabled => SelectedTemplate == null;
    private bool IsSending { get; set; }
    private string? StatusMessage { get; set; }
    private string PreviewHtml { get; set; } = string.Empty;
    private bool IsLoading { get; set; } = false;
    public IEnumerable<Learner> Learners { get; set; } = Enumerable.Empty<Learner>();

    protected override async Task OnInitializedAsync()
    {
        SelectedSchool = await SchoolService.GetSelectedSchoolAsync();
        SubscribeToEvent(UiEvents.SchoolSelected);
        await LoadData();
        await base.OnInitializedAsync();
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        if (eventName == UiEvents.SchoolSelected && payload is School school)
        {
            if (SelectedSchool?.Id != school.Id)
            {
                SelectedSchool = school;
                await LoadData();
            }
        }

        await base.HandleEventAsync(eventName, payload);
    }

    private async Task LoadData()
    {
        if (SelectedSchool == null) return;

        _learners = await LearnerService.GetLearnersBySchoolAsync(SelectedSchool.Id);
        _schoolGrades = await SchoolGradeService.GetGradesForSchool(SelectedSchool.Id);
        _subjects = await SubjectService.GetAllAsync();
    }

    private void OnGradeSelected(Guid? selectedGradeId)
    {
        SelectedGradeId = selectedGradeId;
    }

    private void OnSubjectSelected(int selectedSubjectId)
    {
        SelectedSubjectId = selectedSubjectId;
    }

    private void OnOptionChanged(CommunicationTarget target)
    {
        SelectedTarget = target;
    }

    private void OnSearchTermChanged(string? searchTerm)
    {
        SearchTerm = searchTerm;
    }

    private IEnumerable<Learner> ApplyFilters()
    {
        if (!_learners.Any()) return Enumerable.Empty<Learner>();

        var query = _learners.AsEnumerable();

        if (SelectedGradeId.HasValue)
            query = query.Where(l => l.RegisterClass?.SchoolGrade?.Id == SelectedGradeId);

        if (!string.IsNullOrEmpty(SearchTerm))
        {
            var term = SearchTerm.Trim().ToLower();
            query = query.Where(l => $"{l.Surname} {l.Name}".ToLower().Contains(term));
        }

        return query;
    }

    private async Task SendCommunication()
    {
        if (SelectedTemplate == null || SelectedSchool == null)
        {
            StatusMessage = "Error: Please select a template and school!";
            return;
        }

        IsSending = true;
        StatusMessage = "Sending communication...";

        try
        {
            EmailCampaign? result;
            switch (SelectedTarget)
            {
                case CommunicationTarget.School:
                    if (string.IsNullOrWhiteSpace(SelectedSchoolAudienceId))
                    {
                        StatusMessage = "Error: Please select an audience!";
                        return;
                    }
                    result = await SendToSchoolAudience();
                    break;

                case CommunicationTarget.SchoolGrade:
                    if (!SelectedGradeId.HasValue)
                    {
                        StatusMessage = "Error: Please select a grade!";
                        return;
                    }
                    result = await CommunicationService.SendToGradeAsync(SelectedGradeId.Value, SelectedTemplate);
                    break;

                case CommunicationTarget.Subject:
                    if (SelectedSubjectId <= 0)
                    {
                        StatusMessage = "Error: Please select a subject!";
                        return;
                    }
                    result = await CommunicationService.SendToSubjectAsync(SelectedSubjectId, SelectedTemplate);
                    break;

                case CommunicationTarget.Learner:
                default:
                    StatusMessage = "Invalid communication target!";
                    return;
            }

            if (result is { Id: not null })
            {
                StatusMessage = "Communication sent successfully!";
                NavigateToCampaign(result.Id.Value);
            }
            else
                StatusMessage = "Error: No recipients found!";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsSending = false;
        }
    }

    private async Task<EmailCampaign?> SendToSchoolAudience()
    {
        return SelectedSchoolAudienceId switch
        {
            "Parents" => await CommunicationService.SendCommunicationAsync(SelectedSchool, SelectedTemplate),
            "Staff" => await CommunicationService.SendToStaffAsync(SelectedSchool, SelectedTemplate),
            "LearnersAndStaff" => await CommunicationService.SendToLearnersAndStaffAsync(SelectedSchool, SelectedTemplate),
            _ => null
        };
    }

    private async Task SendCommunicationForLearner(Learner learner)
    {
        if (SelectedTemplate == null)
        {
            StatusMessage = "No template selected!";
            return;
        }

        IsSending = true;
        StatusMessage = $"Sending communication to {learner.Name}...";

        try
        {
            if (SelectedSchool != null)
            {
                var result = await CommunicationService.SendToLearnerAsync(SelectedSchool, SelectedTemplate, learner);
                StatusMessage = result != null ? "Communication sent successfully!" : "Error sending communication!";
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsSending = false;
        }
    }

    private void NavigateToCampaign(Guid campaignId)
    {
        NavigationManager.NavigateTo($"/email-campaign/{campaignId}");
    }

    private async Task OnTemplateSelected(EmailTemplate? template)
    {
        SelectedTemplate = template;
        // Optionally, auto-preview when a template is selected.
        if (SelectedTemplate != null)
        {
            await PreviewTemplate();
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnSchoolAudienceSelected(string? audienceId)
    {
        SelectedSchoolAudienceId = audienceId;
        await InvokeAsync(StateHasChanged);
    }

    // New method to preview the selected template.
    private async Task PreviewTemplate()
    {
        if (SelectedTemplate == null)
            return;

        // For demonstration, if the template expects a ProgressReportModel,
        // create a sample instance with custom JSON values.
        if (SelectedTemplate.ModelType == typeof(ProgressReportModel).FullName)
        {
            var previewModel = new ProgressReportModel
            {
                ParentName = "Doe",
                ChildName = "Jane Doe",
                Results = new List<Result>
{
new Result { Score = 95, Learner = new Learner { Surname = "Roos" } },
new Result { Score = 87, Learner = new Learner { Surname = "Smith" } }
}
            };

            PreviewHtml = await RendererService.RenderTemplateAsync(
            "preview-" + SelectedTemplate.Id, SelectedTemplate.Content, previewModel);
        }
        else
        {
            // For other model types, you can create default test data or handle accordingly.
            PreviewHtml = "No preview available for this model type.";
        }
    }


    private async Task SendCommunication()
    {
        if (SelectedTemplate == null || SelectedSchool == null)
        {
            StatusMessage = "Error: Please select a template and school!";
            return;
        }

        var request = new CommunicationRequest
        {
            Target = SelectedTarget,
            Audience = SelectedSchoolAudienceId,
            GradeId = SelectedGradeId,
            SubjectId = SelectedSubjectId,
            TemplateId = SelectedTemplate.Id,
            SchoolId = SelectedSchool.Id
        };

        IsSending = true;
        StatusMessage = "Sending communication...";

        try
        {
            var result = await CommunicationService.SendCommunicationAsync(request);
            if (result is { Id: not null })
            {
                StatusMessage = "Communication sent successfully!";
                NavigateToCampaign(result.Id.Value);
            }
            else
            {
                StatusMessage = "Error: No recipients found!";
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsSending = false;
        }
    }

    private async Task AudienceChanged(string? audienceId)
    {
        SelectedAudienceId = audienceId;
        await OnAudienceSelected.InvokeAsync(SelectedAudienceId);
    }

    private async Task HandleGradeChange(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var gradeId))
        {
            SelectedGradeId = gradeId;
        }
        else
        {
            SelectedGradeId = null;
        }
        await OnGradeSelected.InvokeAsync(SelectedGradeId);
    }
}
