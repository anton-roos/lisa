@page "/communication/email-templates"
@using Lisa.Models.Entities
@inject EmailTemplateService EmailTemplateService
@inject NavigationManager NavigationManager

<h3>Email Templates</h3>

<button class="btn btn-primary mb-3" @onclick="CreateNewTemplate">Create New Template</button>

@if (emailTemplates == null)
{
    <p><em>Loading templates...</em></p>
}
else if (!emailTemplates.Any())
{
    <p>No email templates found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Subject</th>
                <th>Created At</th>
                <th>Updated At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var template in emailTemplates)
            {
                <tr>
                    <td>@template.Name</td>
                    <td>@template.Subject</td>
                    <td>@template.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@template.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <ActionButtons
                        TEntity="EmailTemplate"
                        Entity="template"
                        OnView="ViewTemplate"
                        OnEdit="EditTemplate"
                        OnDelete="ConfirmDelete"
                    />
                </tr>
            }
        </tbody>
    </table>
}

<div class="modal fade show" tabindex="-1" role="dialog" style="display: @(showModal ? "block" : "none");" aria-hidden="@(showModal ? "false" : "true")">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the template <strong>@selectedTemplate?.Name</strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button type="button" class="btn btn-danger" @onclick="DeleteConfirmed">Delete</button>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show" style="display: @(showModal ? "block" : "none");"></div>
</div>

@code {
    private List<EmailTemplate>? emailTemplates;
    private EmailTemplate? selectedTemplate;
    private bool showModal = false;

    protected override async Task OnInitializedAsync()
    {
        emailTemplates = await EmailTemplateService.GetAllTemplatesAsync();
    }

    private void ViewTemplate(EmailTemplate template)
    {
        NavigationManager.NavigateTo($"/communication/email-template/details/{template.Id}");
    }

    private void EditTemplate(EmailTemplate template)
    {
        NavigationManager.NavigateTo($"/communication/email-template/edit/{template.Id}");
    }

    private async Task DeleteTemplate(EmailTemplate template)
    {
        await EmailTemplateService.DeleteTemplateAsync(template.Id);
        emailTemplates = await EmailTemplateService.GetAllTemplatesAsync();
    }

    private void CreateNewTemplate()
    {
        NavigationManager.NavigateTo("/communication/email-template/add");
    }

    private void ConfirmDelete(EmailTemplate template)
    {
        selectedTemplate = template;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task DeleteConfirmed()
    {
        if (selectedTemplate != null)
        {
            await DeleteTemplate(selectedTemplate);
            selectedTemplate = null;
            showModal = false;
        }
    }
}
