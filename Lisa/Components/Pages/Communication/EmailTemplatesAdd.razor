@page "/communication/email-templates/add"
@inject EmailTemplateService EmailTemplateService
@inject NavigationManager NavigationManager
@using Blazored.TextEditor

<h3>Email Template Editor</h3>

<div class="mb-3">
    <label for="templateName">Template Name</label>
    <input type="text" id="templateName" @bind="TemplateName" class="form-control" placeholder="Enter template name" />
</div>

<div class="mb-3">
    <label for="templateSubject">Subject</label>
    <input type="text" id="templateSubject" @bind="TemplateSubject" class="form-control" placeholder="Enter subject" />
</div>

<BlazoredTextEditor @ref="TextEditor" />

<button class="btn btn-success mt-3" @onclick="SaveTemplate">Save Template</button>

@if (SuccessMessage != null)
{
    <div class="alert alert-success mt-3">@SuccessMessage</div>
}

@code {
    private BlazoredTextEditor? TextEditor;
    private string TemplateName = string.Empty;
    private string TemplateSubject = string.Empty;
    private string? SuccessMessage;

    private async Task SaveTemplate()
    {
        if (TextEditor != null)
        {
            string content = await TextEditor.GetHTML();

            if (string.IsNullOrWhiteSpace(TemplateName))
            {
                SuccessMessage = "Template Name cannot be empty.";
                return;
            }

            await EmailTemplateService.SaveTemplateAsync(TemplateName, TemplateSubject, content);

            SuccessMessage = "Template saved successfully!";
        }
    }
}
