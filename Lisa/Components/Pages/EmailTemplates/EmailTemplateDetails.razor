@page "/email-template-details/{TemplateId:guid}"
@using Lisa.Models.Entities
@inject Lisa.Services.EmailTemplateService TemplateService
@inject Lisa.Services.EmailRendererService RendererService

<h3>Template Details</h3>

@if (template == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card">
        <div class="card-header">
            <strong>@template.Name</strong> - @template.Subject
        </div>
        <div class="card-body">
            <h5>Template Content</h5>
            <pre>@template.Content</pre>
        </div>
    </div>

    <hr />

    <h4>Test Render</h4>
    <div class="mb-3">
        <label>Example Value for SomeVariable:</label>
        <InputText @bind-Value="testModel.SomeVariable" class="form-control" />
    </div>
    <button class="btn btn-primary" @onclick="RenderTestTemplate">Render Template</button>

    @if (!string.IsNullOrEmpty(renderedOutput))
    {
        <hr />
        <h5>Rendered Output</h5>
        <div class="border p-3" style="background-color:#f8f9fa;">
            @((MarkupString)renderedOutput)
        </div>
    }
}

@code {
    [Parameter]
    public Guid TemplateId { get; set; }

    private EmailTemplate? template;
    private string renderedOutput = string.Empty;

    // This is our test model. Add more properties if your template expects them.
    private TestModel testModel = new() { SomeVariable = "TestValue" };

    protected override async Task OnInitializedAsync()
    {
        template = await TemplateService.GetTemplateByIdAsync(TemplateId);
    }

    private async Task RenderTestTemplate()
    {
        if (template != null)
        {
            // Use the template's Id as the cache key.
            renderedOutput = await RendererService.RenderTemplateAsync("template-" + template.Id, template.Content, testModel);
        }
    }

    // Define a simple test model with properties matching your template placeholders.
    public class TestModel
    {
        public string SomeVariable { get; set; } = string.Empty;
    }
}
