@page "/email-template-details/{TemplateId:guid}"
@using Lisa.Models.EmailModels
@using Lisa.Models.Entities
@inject Lisa.Services.EmailTemplateService TemplateService
@inject Lisa.Services.EmailRendererService RendererService

<h3>Template Details</h3>

@if (template == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card">
        <div class="card-header">
            <strong>@template.Name</strong> - @template.Subject
        </div>
        <div class="card-body">
            <h5>Template Content</h5>
            <pre>@template.Content</pre>
        </div>
    </div>

    <hr />

    <h4>Test Render</h4>

    @if (testValues.Any())
    {
        @foreach (var field in testValues)
        {
            <div class="mb-3">
                <label>@field.Key:</label>
                @if (testFieldTypes.TryGetValue(field.Key, out var fieldType))
                {
                    if (fieldType == typeof(string))
                    {
                        <!-- Simple text input for string -->
                        <input type="text" value="@testValues[field.Key]" @onchange="(e) => testValues[field.Key] = e.Value?.ToString()"
                            class="form-control" />
                    }
                    else if (fieldType.IsGenericType && fieldType.GetGenericTypeDefinition() == typeof(List<>))
                    {
                        <!-- Textarea for JSON editing of a list -->
                        <textarea class="form-control"
                            @onchange="(e) => testValues[field.Key] = e.Value?.ToString()">@testValues[field.Key]</textarea>
                    }
                    else
                    {
                        <!-- Fallback to text input -->
                        <input type="text" value="@testValues[field.Key]" @onchange="(e) => testValues[field.Key] = e.Value?.ToString()"
                            class="form-control" />
                    }
                }
            </div>
        }
    }
    else
    {
        <p>No test fields available for this model.</p>
    }

    <button class="btn btn-primary" @onclick="RenderTestTemplate">Render Template</button>

    @if (!string.IsNullOrEmpty(renderedOutput))
    {
        <hr />
        <h5>Rendered Output</h5>
        <div class="border p-3" style="background-color:#f8f9fa;">
            @((MarkupString)renderedOutput)
        </div>
    }
}

@code {
    [Parameter]
    public Guid TemplateId { get; set; }

    private EmailTemplate? template;
    private string renderedOutput = string.Empty;

    // Dictionary to store test input values (property name => value)
    private Dictionary<string, string> testValues = new();
    // Dictionary to store property types so we can choose the right UI element.
    private Dictionary<string, Type> testFieldTypes = new();

    protected override async Task OnInitializedAsync()
    {
        template = await TemplateService.GetTemplateByIdAsync(TemplateId);
        if (template != null && !string.IsNullOrWhiteSpace(template.ModelType))
        {
            var modelType = Type.GetType(template.ModelType);
            if (modelType != null)
            {
                // Create a dummy instance of the model.
                var dummyInstance = Activator.CreateInstance(modelType);
                foreach (var prop in modelType.GetProperties(System.Reflection.BindingFlags.Public |
                System.Reflection.BindingFlags.Instance))
                {
                    testFieldTypes[prop.Name] = prop.PropertyType;
                    if (prop.PropertyType == typeof(string))
                    {
                        // Initialize as empty string.
                        testValues[prop.Name] = string.Empty;
                    }
                    else if (prop.PropertyType.IsGenericType && prop.PropertyType.GetGenericTypeDefinition() == typeof(List<>))
                    {
                        // For a list property, check if we want custom JSON.
                        if (modelType == typeof(ProgressFeedback) && prop.Name == "Results")
                        {
                            // Set your custom JSON here for ProgressFeedback's Results property.
                            testValues[prop.Name] = @"[
                                    {
                                    ""Score"": 95,
                                    ""Learner"": { ""Surname"": ""Roos"" }
                                    },
                                    {
                                    ""Score"": 87,
                                    ""Learner"": { ""Surname"": ""Doe"" }
                                    }
                                    ]";
                        }
                        else
                        {
                            // Otherwise, serialize the current value or default to an empty array.
                            var listValue = prop.GetValue(dummyInstance);
                            testValues[prop.Name] = listValue != null
                            ? System.Text.Json.JsonSerializer.Serialize(listValue)
                            : "[]";
                        }
                    }
                    else
                    {
                        // For other types, use ToString (or customize as needed)
                        testValues[prop.Name] = prop.GetValue(dummyInstance)?.ToString() ?? string.Empty;
                    }
                }
            }
        }
    }

    private async Task RenderTestTemplate()
    {
        if (template != null)
        {
            var modelType = Type.GetType(template.ModelType);
            if (modelType != null)
            {
                // Create an instance of the model.
                var modelInstance = Activator.CreateInstance(modelType);
                if (modelInstance != null)
                {
                    foreach (var prop in modelType.GetProperties(System.Reflection.BindingFlags.Public |
                    System.Reflection.BindingFlags.Instance))
                    {
                        if (testValues.TryGetValue(prop.Name, out var value))
                        {
                            if (prop.PropertyType == typeof(string))
                            {
                                prop.SetValue(modelInstance, value);
                            }
                            else if (prop.PropertyType.IsGenericType && prop.PropertyType.GetGenericTypeDefinition() == typeof(List<>))
                            {
                                // Attempt to deserialize JSON string into the appropriate list.
                                try
                                {
                                    var deserialized = System.Text.Json.JsonSerializer.Deserialize(value, prop.PropertyType);
                                    prop.SetValue(modelInstance, deserialized);
                                }
                                catch (Exception ex)
                                {
                                    // Handle JSON errors if needed.
                                    Console.WriteLine($"Error deserializing property {prop.Name}: {ex.Message}");
                                }
                            }
                            else
                            {
                                // You can add support for additional types as needed.
                            }
                        }
                    }
                    // Render the template using the instance populated with test values.
                    renderedOutput = await RendererService.RenderTemplateAsync("template-" + template.Id, template.Content, modelInstance);
                }
            }
        }
    }
}
