@page "/email-template-details/{TemplateId:guid}"
@using Lisa.Models.Entities
@inject Lisa.Services.EmailTemplateService TemplateService
@inject Lisa.Services.EmailRendererService RendererService

<h3>Template Details</h3>

@if (template == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card">
        <div class="card-header">
            <strong>@template.Name</strong> - @template.Subject
        </div>
        <div class="card-body">
            <h5>Template Content</h5>
            <pre>@template.Content</pre>
        </div>
    </div>

    <hr />

    <h4>Test Render</h4>

    @if (testValues.Any())
    {
        @foreach (var kvp in testValues)
        {
            <div class="mb-3">
                <label>@kvp.Key:</label>
                <input type="text" value="@testValues[kvp.Key]" @onchange="(e) => testValues[kvp.Key] = e.Value?.ToString()"
                    class="form-control" />
            </div>
        }
    }
    else
    {
        <p>No test fields available for this model.</p>
    }

    <button class="btn btn-primary" @onclick="RenderTestTemplate">Render Template</button>

    @if (!string.IsNullOrEmpty(renderedOutput))
    {
        <hr />
        <h5>Rendered Output</h5>
        <div class="border p-3" style="background-color:#f8f9fa;">
            @((MarkupString)renderedOutput)
        </div>
    }
}

@code {
    [Parameter]
    public Guid TemplateId { get; set; }

    private EmailTemplate? template;
    private string renderedOutput = string.Empty;

    // A dictionary to store test input values keyed by property name.
    private Dictionary<string, string> testValues = new();

    protected override async Task OnInitializedAsync()
    {
        template = await TemplateService.GetTemplateByIdAsync(TemplateId);
        if (template != null && !string.IsNullOrWhiteSpace(template.ModelType))
        {
            // Get the model type from the stored ModelType string.
            var modelType = Type.GetType(template.ModelType);
            if (modelType != null)
            {
                // For each public property, add an entry to the dictionary.
                foreach (var prop in modelType.GetProperties(System.Reflection.BindingFlags.Public |
                System.Reflection.BindingFlags.Instance))
                {
                    // For simplicity, only handle properties of type string here.
                    // You could add support for other types (with conversion) as needed.
                    if (prop.PropertyType == typeof(string))
                    {
                        testValues[prop.Name] = string.Empty;
                    }
                }
            }
        }
    }

    private async Task RenderTestTemplate()
    {
        if (template != null)
        {
            var modelType = Type.GetType(template.ModelType);
            if (modelType != null)
            {
                // Create an instance of the model type.
                var modelInstance = Activator.CreateInstance(modelType);
                if (modelInstance != null)
                {
                    // For each property, set its value from the testValues dictionary.
                    foreach (var prop in modelType.GetProperties(System.Reflection.BindingFlags.Public |
                    System.Reflection.BindingFlags.Instance))
                    {
                        if (testValues.TryGetValue(prop.Name, out var value))
                        {
                            if (prop.PropertyType == typeof(string))
                            {
                                prop.SetValue(modelInstance, value);
                            }
                            // Additional type conversions can be added here.
                        }
                    }

                    // Render the template using the instance populated with test values.
                    renderedOutput = await RendererService.RenderTemplateAsync(
                    "template-" + template.Id, template.Content, modelInstance);
                }
            }
        }
    }
}
