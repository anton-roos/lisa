@page "/email-templates"
@using Lisa.Models.Entities
@inject Lisa.Services.EmailTemplateService TemplateService
@inject NavigationManager NavManager

<h3>Email Templates</h3>
<button class="btn btn-primary mb-3" @onclick="CreateNewTemplate">Create New Template</button>
@if (templates == null)
{
    <p><em>Loading...</em></p>
}
else if (!templates.Any())
{
    <p>No templates found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Subject</th>
                <th>Last Updated</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tmpl in templates)
            {
                <tr>
                    <td>@tmpl.Name</td>
                    <td>@tmpl.Subject</td>
                    <td>@tmpl.UpdatedAt.ToLocalTime()</td>
                    <td>
                        <button class="btn btn-primary" @onclick="() => EditTemplate(tmpl.Id)">Edit</button>
                        <button class="btn btn-secondary" @onclick="() => ViewTemplate(tmpl.Id)">Details</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<EmailTemplate>? templates;

    protected override async Task OnInitializedAsync()
    {
        templates = await TemplateService.GetAllTemplatesAsync();
    }

    void EditTemplate(Guid id) => NavManager.NavigateTo($"/email-template-manager/{id}");
    void ViewTemplate(Guid id) => NavManager.NavigateTo($"/email-template-details/{id}");
    void CreateNewTemplate() => NavManager.NavigateTo("/email-template-manager");
}
