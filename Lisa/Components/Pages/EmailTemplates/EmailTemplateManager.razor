@page "/email-template-manager/{TemplateId:guid?}"
@using Lisa.Models.Entities
@using Lisa.Models.EmailModels
@inject Lisa.Services.EmailTemplateService TemplateService
@inject NavigationManager NavManager

<h3>@(isEdit ? "Edit Template" : "Add New Template")</h3>

<EditForm Model="templateModel" OnValidSubmit="SaveTemplate">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="mb-3">
        <label>Name:</label>
        <InputText @bind-Value="templateModel.Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Subject:</label>
        <InputText @bind-Value="templateModel.Subject" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Content (HTML with Razor tokens):</label>
        <InputTextArea @bind-Value="templateModel.Content" class="form-control" rows="10" />
    </div>
    <div class="mb-3">
        <label>Model Type:</label>
        <InputSelect @bind-Value="templateModel.ModelType" class="form-control">
            @foreach (var type in availableModelTypes)
            {
                <option value="@type">@type</option>
            }
        </InputSelect>
    </div>
    <button type="submit" class="btn btn-success">Save</button>
    <button type="button" class="btn btn-secondary" @onclick="GoBack">Cancel</button>
</EditForm>

@code {
    [Parameter]
    public Guid? TemplateId { get; set; }

    private EmailTemplate templateModel = new();
    private bool isEdit => TemplateId.HasValue;

    private List<string> availableModelTypes = new List<string>
{
typeof(ProgressFeedback).FullName!,
};

    protected override async Task OnInitializedAsync()
    {
        if (TemplateId.HasValue)
        {
            var tmpl = await TemplateService.GetTemplateByIdAsync(TemplateId.Value);
            if (tmpl != null)
            {
                templateModel = tmpl;
            }
        }
    }

    private async Task SaveTemplate()
    {
        bool success;
        if (isEdit)
        {
            success = await TemplateService.UpdateTemplateAsync(templateModel);
        }
        else
        {
            success = await TemplateService.SaveTemplateAsync(templateModel.Name, templateModel.Subject, templateModel.Content,
            templateModel.ModelType);
        }
        if (success)
        {
            NavManager.NavigateTo("/email-templates");
        }
        else
        {
            // Show error message if needed
        }
    }

    private void GoBack() => NavManager.NavigateTo("/email-templates");
}
