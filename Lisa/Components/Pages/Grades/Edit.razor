@page "/grades/edit/{Id:guid}"
@using Lisa.Models.Entities
@using Lisa.Models.ViewModels
@inject SchoolService SchoolService
@inject GradeService GradeService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components

<AuthorizeView>
    <Authorized>
        <h3>Edit Grade</h3>

        @if (Grade == null)
        {
            <div class="alert alert-warning">
                Grade not found. Please check the URL or go back.
            </div>
        }
        else
        {
            <EditForm Context="edit" Model="@GradeModel" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Grade Name</label>
                    <InputText class="form-control" @bind-Value="GradeModel.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Sequence Number</label>
                    <InputNumber class="form-control" @bind-Value="GradeModel.SequenceNumber" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </EditForm>
        }
    </Authorized>
    <NotAuthorized>
        <p>You are not authorized to edit grades.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Grade? Grade;
    private GradeViewModel GradeModel = new();

    protected override async Task OnParametersSetAsync()
    {
        // Load the grade from your service:
        Grade = await GradeService.GetByIdAsync(Id);

        if (Grade != null)
        {
            // Initialize the model with existing data
            GradeModel = new GradeViewModel
            {
                Name = Grade.Name,
                SequenceNumber = Grade.SequenceNumber
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        if (Grade == null)
            return;

        // Update existing grade entity
        Grade.Name = GradeModel.Name;
        Grade.SequenceNumber = GradeModel.SequenceNumber;

        // Save changes to the database
        await GradeService.UpdateGradeAsync(Grade);

        // Navigate back to the grades list
        Navigation.NavigateTo("/grades");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/grades");
    }
}
