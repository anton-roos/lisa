@page "/grades/details/{Id:guid}"
@using Lisa.Models.Entities
@inject GradeService GradeService
@inject NavigationManager Navigation

<PageTitle>Grade Details</PageTitle>
<h3>Grade Details</h3>

@if (Grade == null)
{
    <p>Loading...</p>
}
else
{
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Grade.Name</dd>

        <dt class="col-sm-2">Sequence Number</dt>
        <dd class="col-sm-10">@Grade.SequenceNumber</dd>
        
        @if (Grade.RegisterClasses == null || !Grade.RegisterClasses.Any())
        {
            <dd class="col-sm-10">No register classes.</dd>
        }
        else
        {
            <dd class="col-sm-10">
                <ul>
                    @foreach (var rc in Grade.RegisterClasses)
                    {
                        <li>@rc.Name</li>
                    }
                </ul>
            </dd>
        }

        @if (Grade.Combinations == null || !Grade.Combinations.Any())
        {
            <dd class="col-sm-10">No combinations.</dd>
        }
        else
        {
            <dd class="col-sm-10">
                <ul>
                    @foreach (var combination in Grade.Combinations)
                    {
                        <li>@combination.Name</li>
                    }
                </ul>
            </dd>
        }
    </dl>
}

<button class="btn btn-primary" @onclick="GoBack">Back</button>

@code {
    [Parameter] public Guid Id { get; set; }
    private Grade? Grade;

    protected override async Task OnInitializedAsync()
    {
        Grade = await GradeService.GetGradeWithRegisterClassesAsync(Id);
    }
    private void GoToEditGrade()
    {
        Navigation.NavigateTo($"/grades/edit/{Id}");
    }

    private async Task DeleteGrade()
    {
        await GradeService.DeleteGradeAsync(Id);
        Navigation.NavigateTo("/grades");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/grades");
    }
}