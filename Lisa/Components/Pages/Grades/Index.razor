@page "/grades"
@using Lisa.Models.Entities
@using Lisa.Models.ViewModels
@inject SchoolService SchoolService
@inject GradeService GradeService
@inject NavigationManager Navigation
@inherits EventAwareComponentBase

<h3>Grades for @SelectedSchool?.ShortName</h3>
<button class="btn btn-primary" @onclick="GoToAddGrade">Add Grade</button>
@if (Grades?.Count == 0)
{
    <div class="alert alert-info">
        No grades found for this school.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Sequence Number</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var grade in Grades)
            {
                <tr>
                    <td>@grade.Name</td>
                    <td>@grade.SequenceNumber</td>
                    <td>
                        <button class="btn btn-primary" @onclick="() => EditGrade(grade.Id)">Edit</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private School? SelectedSchool;
    private List<Grade> Grades = new();

    protected override async Task OnInitializedAsync()
    {
        SubscribeToEvent(UiEvents.SchoolSelected);
        SelectedSchool = SchoolService.GetSelectedSchool();
        await LoadGrades();
    }

    private async Task LoadGrades()
    {
        if (SelectedSchool != null)
        {
            Grades = await GradeService.GetGradesForSchool(SelectedSchool.Id);
        }
        Grades = Grades.OrderBy(g => g.SequenceNumber).ToList();
    }

    private void GoToAddGrade()
    {
        Navigation.NavigateTo("/grades/add");
    }

    private void EditGrade(Guid id)
    {
        Navigation.NavigateTo($"/grades/edit/{id}");
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        // Handle the events and update the state
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                // Cast Payload to a School
                SelectedSchool = payload as School;
                break;
        }

        // Ensure state change
        await base.HandleEventAsync(eventName, payload);
    }
}
