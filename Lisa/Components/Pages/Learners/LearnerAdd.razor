@page "/learners/add"
@using Lisa.Models.Entities
@inject NavigationManager navigationManager
@inject LearnerService learnerService
@inject SchoolService schoolService
@inject CombinationService combinationService
@inject IToastService ToastService

<h3>Add Learner</h3>

<EditForm Context="Edit" Model="learner" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label for="Code">Code</label>
        <InputText id="Code" class="form-control" @bind-Value="learner.Code" />
    </div>

    <div>
        <label for="FirstName">First Name</label>
        <InputText id="FirstName" class="form-control" @bind-Value="learner.FirstName" />
    </div>

    <div>
        <label for="LastName">Last Name</label>
        <InputText id="LastName" class="form-control" @bind-Value="learner.LastName" />
    </div>

    <div>
        <label for="Active">Active</label>
        <InputCheckbox id="Active" @bind-Value="learner.Active" />
    </div>

    <div>
        <label for="RegisterClassId">Register Class</label>
        <InputSelect id="RegisterClassId" class="form-control" @bind-Value="learner.RegisterClassId">
            <option value="">Select Register Class</option>
            @foreach (var registerClass in registerClasses)
            {
                <option value="@registerClass.Id">@registerClass.Name</option>
            }
        </InputSelect>
    </div>

    <div>
        <label for="CareGroupId">Care Group</label>
        <InputSelect id="CareGroupId" class="form-control" @bind-Value="learner.CareGroupId">
            <option value="">Select Care Group</option>
            @foreach (var careGroup in careGroups)
            {
                <option value="@careGroup.Id">@careGroup.Name</option>
            }
        </InputSelect>
    </div>

    <div>
        <label for="SubjectCombinationId">Subject Combination</label>
        @if (combinations == null)
        {
            <p>No Combinations for the current learner</p>
        }
        else
        {
            <InputSelect id="SubjectCombinationId" class="form-control" @bind-Value="learner.CombinationId">
            <option value="">Select Subject Combination</option>
            @foreach (var subjectCombination in combinations)
            {
                <option value="@subjectCombination.Id">@subjectCombination.Name</option>
            }
        </InputSelect>
        }
        
    </div>

    <button type="submit" class="btn btn-primary">Add Learner</button>
</EditForm>

@code {
    private Learner learner = new Learner();
    private List<RegisterClass> registerClasses = new();
    private List<CareGroup> careGroups = new();
    private IEnumerable<Combination>? combinations;
    private School? SelectedSchool = new();

    protected override async Task OnInitializedAsync()
    {
        registerClasses = await learnerService.GetRegisterClasses();
        careGroups = await learnerService.GetCareGroups();
        combinations = await combinationService.GetAllAsync();
        SelectedSchool = schoolService.GetSelectedSchool();
    }

    private async Task HandleValidSubmit()
    {
        if (SelectedSchool == null)
        {
            ToastService.ShowToast(ToastIntent.Error, "Please select a school");
            return;
        }
        learner.SchoolId = SelectedSchool.Id;
        await learnerService.AddLearner(learner);
        ToastService.ShowToast(ToastIntent.Success, "Learner added successfully");
        await Task.Delay(1000);
        navigationManager.NavigateTo("/learners");
    }
}