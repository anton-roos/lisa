@page "/learners/add"
@using Lisa.Models.Entities
@using Lisa.Models.ViewModels
@using Microsoft.EntityFrameworkCore
@inject NavigationManager navigationManager
@inject LearnerService learnerService
@inject SchoolService SchoolService
@inject CombinationService combinationService
@inject RegisterClassService registerClassService
@inject SubjectService subjectService
@inherits EventAwareComponentBase
@inject ILogger<LearnerAdd> Logger
@inject LearnerService LearnerService
@inject SubjectService SubjectService
@inject IDbContextFactory<LisaDbContext> DbContextFactory

<h3>Add Learner</h3>

@if (!string.IsNullOrEmpty(AlertMessage))
{
    <div class="alert alert-@AlertType alert-dismissible fade show" role="alert">
        @AlertMessage
        <button type="button" class="btn-close" aria-label="Close" @onclick="ClearAlert"></button>
    </div>
}

<EditForm Context="Edit" Model="Learner" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="Code">Code</label>
        <InputText id="Code" class="form-control" @bind-Value="Learner.Code" />
    </div>

    <div class="mb-3">
        <label for="FirstName">First Name</label>
        <InputText id="FirstName" class="form-control" @bind-Value="Learner.FirstName" />
    </div>

    <div class="mb-3">
        <label for="LastName">Last Name</label>
        <InputText id="LastName" class="form-control" @bind-Value="Learner.LastName" />
    </div>

    <div class="mb-3">
        <label for="LastName">ID Number <span class="text-muted">(Optional)</span></label>
        <InputText id="LastName" class="form-control" @bind-Value="Learner.IdNumber" />
    </div>

    <div class="mb-3">
        <label for="LastName">Cell Number <span class="text-muted">(Optional)</span></label>
        <InputText id="LastName" class="form-control" @bind-Value="Learner.CellNumber" />
    </div>

    <div class="mb-3">
        <label for="LastName">Email Address <span class="text-muted">(Optional)</span></label>
        <InputText id="LastName" class="form-control" @bind-Value="Learner.Email" />
    </div>

    <div class="mb-3">
        <label for="Active">Active</label>
        <InputCheckbox id="Active" @bind-Value="Learner.Active" />
    </div>

    <div class="mb-3">
        <label for="CareGroupId">Care Group</label>
        <InputSelect id="CareGroupId" class="form-control" @bind-Value="Learner.CareGroupId">
            <option value="">Select Care Group</option>
            @foreach (var careGroup in CareGroups)
            {
                <option value="@careGroup.Id">@careGroup.Name</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label for="RegisterClassId">Register Class</label>
        <InputSelect class="form-select" id="RegisterClassId" ValueExpression="@(() => SelectedRegisterClassId)"
            Value="SelectedRegisterClassId" TValue="string" ValueChanged="RegisterClassSelected">

            <option value="">Select Register Class</option>
            @foreach (var registerClass in RegisterClasses!)
            {
                <option value="@registerClass.Id.ToString()">@registerClass.Name</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label for="SubjectCombinationId">Subject Combination</label>
        @if (RegisterClass == null)
        {
            <p>Select Register Class</p>
        }
        else
        {
            <div>Register Class @RegisterClass.Name</div>

            <h3>Compulsory Subjects</h3>
            @foreach (var subject in RegisterClass.CompulsorySubjects)
            {
                bool isChecked = Learner.SubjectIds.Contains(subject.Id);

                <div>
                    <input type="checkbox" checked="@isChecked" @onchange="@(() => ToggleSubject(subject.Id))" />
                    <label>@subject.Name</label>
                </div>
            }
            @if (RegisterClass.MathSelectionEnabled)
            {
                <div class="mb-8" id="math-selection">
                    <h3>Select 1</h3>
                    <div class="row justify-content-start">
                        <div class="col-3">
                            <input type="radio" id="math" name="math" value="MATH">
                            <label for="html">Mathematichs</label><br>
                        </div>
                        <div class="col-3">
                            <input type="radio" id="math-lit" name="math" value="MATL">
                            <label for="css">Mathematical Literacy</label><br>
                        </div>
                    </div>
                </div>
            }
            @if (CombinationsToChoseFrom != null)
            {
                <h3>Select exactly 1 subject from each Combination</h3>
                <div class="row">
                    @foreach (var combo in CombinationsToChoseFrom!)
                    {
                        <div class="col">
                            <h5>@combo.Name</h5>
                            @foreach (var subject in combo.Subjects)
                            {
                                // Is this subject selected in this combination?
                                bool selected = CombinationSelections.TryGetValue(combo.Id, out var chosenSubjectId)
                                && chosenSubjectId == subject.Id;

                                // Is this subject already chosen in a different combination?
                                bool disabled = IsSubjectDisabled(subject.Id, combo.Id);

                                <div>
                                    <input type="radio" name="@combo.Id" value="@subject.Id"
                                        @onclick="@(() => OnCombinationSubjectChanged(combo, subject))" checked="@selected"
                                        disabled="@disabled" />
                                    <label class="@(disabled ? "text-muted" : "")">@subject.Name</label>
                                </div>
                            }
                        </div>
                    }
                </div>

            }
            else
            {
                <p>No combinations found for this grade.</p>
            }
        }
    </div>

    <h4 class="mt-4">Parent Information</h4>

    <div class="row">
        @foreach (var parent in Parents)
        {
            <div class="col-12 col-md-6 col-lg-4 col-xl-3 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">Parent @(Parents.IndexOf(parent) + 1)</h5>

                        <div class="mb-2">
                            <label>First Name</label>
                            <InputText class="form-control" @bind-Value="parent.FirstName" />
                        </div>

                        <div class="mb-2">
                            <label>Last Name</label>
                            <InputText class="form-control" @bind-Value="parent.LastName" />
                        </div>

                        <div class="mb-2">
                            <label>Relationship</label>
                            <InputText class="form-control" @bind-Value="parent.Relationship" />
                        </div>

                        <div class="mb-2">
                            <label>Primary Email</label>
                            <InputText class="form-control" @bind-Value="parent.PrimaryEmail" />
                        </div>

                        <div class="mb-2">
                            <label>Secondary Email <span class="text-muted">(Optional)</span></label>
                            <InputText class="form-control" @bind-Value="parent.SecondaryEmail" />
                        </div>

                        <div class="mb-2">
                            <label>Primary Number</label>
                            <InputText class="form-control" @bind-Value="parent.PrimaryCellNumber" />
                        </div>

                        <div class="mb-2">
                            <label>Secondary Number</label>
                            <InputText class="form-control" @bind-Value="parent.SecondaryCellNumber" />
                        </div>

                        <div class="mb-2">
                            <label>WhatsApp Number</label>
                            <InputText class="form-control" @bind-Value="parent.WhatsAppNumber" />
                        </div>

                        <button type="button" class="btn btn-danger w-100 mt-2" @onclick="@(() => RemoveParent(parent))"> <i
                                class="bi bi-trash me-1"></i> Remove</button>
                    </div>
                </div>
            </div>
        }
    </div>

    <button type="button" class="btn btn-secondary mb-3" @onclick="AddParent"> <i class="bi bi-person-plus me-1"></i>
        Add Parent</button>

    <button type="submit" class="btn btn-primary mb-3"> <i class="bi bi-save me-1"></i> Save Learner</button>
</EditForm>

@code {
    private LearnerViewModel Learner = new();
    private List<Parent> Parents = new();
    private List<RegisterClass> RegisterClasses = new();
    private List<CareGroup> CareGroups = new();
    private IEnumerable<Combination>? Combinations;
    private School? SelectedSchool = new();
    private RegisterClass? RegisterClass;
    private string? SelectedRegisterClassId = string.Empty;
    private IEnumerable<Combination>? CombinationsToChoseFrom;
    // Key = combination.Id, Value = the subject.Id chosen in that combo
    private Dictionary<Guid, Guid> CombinationSelections = new();
    private string? AlertMessage { get; set; }
    private string AlertType { get; set; } = "success";

    protected override async Task OnInitializedAsync()
    {
        SelectedSchool = SchoolService.GetSelectedSchool();
        SubscribeToEvent(UiEvents.SchoolSelected);
        await LoadDropdowns();
        await LoadSubjects();
        Console.WriteLine("Learner Add Page Initialized");
    }

    private async Task LoadSubjects()
    {
        var masterSubjectList = await subjectService.GetAllAsync();
    }

    private void ToggleSubject(Guid subjectId)
    {
        if (Learner.SubjectIds.Contains(subjectId))
        {
            Learner.SubjectIds.Remove(subjectId);
        }
        else
        {
            Learner.SubjectIds.Add(subjectId);
        }
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        if (eventName == UiEvents.SchoolSelected)
        {
            SelectedSchool = payload as School;
            await LoadDropdowns();
            StateHasChanged();
        }

        await base.HandleEventAsync(eventName, payload);
    }

    private async Task LoadDropdowns()
    {
        if (SelectedSchool != null)
        {
            RegisterClasses = await learnerService.GetRegisterClassesBySchoolId(SelectedSchool.Id);
            Combinations = await combinationService.GetCombinationsBySchoolId(SelectedSchool.Id);
            CareGroups = await learnerService.GetCareGroupsBySchoolId(SelectedSchool.Id);
        }
        else
        {
            RegisterClasses.Clear();
            Combinations = Enumerable.Empty<Combination>();
        }
    }

    private async Task RegisterClassSelected(string e)
    {
        Learner.RegisterClassId = Guid.Parse(e!);
        RegisterClass = await registerClassService.GetByIdAsync(Learner.RegisterClassId.Value);
        Learner.SubjectIds.Clear();
        foreach (var subject in RegisterClass.CompulsorySubjects)
        {
            Learner.SubjectIds.Add(subject.Id);
        }
        CombinationsToChoseFrom = Combinations.Where(
            c => c.GradeId == RegisterClass.GradeId && 
            c.CombinationType == CombinationType.SubjectCombination);

        StateHasChanged();
    }

    private void AddParent()
    {
        Parents.Add(new Parent());
        StateHasChanged();
    }

    private void RemoveParent(Parent parent)
    {
        Parents.Remove(parent);
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        if (SelectedSchool == null)
        {
            SetAlert("danger", "Please select a school.");
            return;
        }

        var learnerId = Guid.NewGuid();

        using var _context = DbContextFactory.CreateDbContext();
        var selectedSubjects = await SubjectService.GetSubjectsByIdsAsync(Learner.SubjectIds);

        var entity = new Learner
            {
                Id = learnerId,
                Active = Learner.Active,
                CareGroupId = Learner.CareGroupId,
                CellNumber = Learner.CellNumber,
                Code = Learner.Code,
                Email = Learner.Email,
                FirstName = Learner.FirstName,
                IdNumber = Learner.IdNumber,
                LastName = Learner.LastName,
                RegisterClassId = Learner.RegisterClassId,
                SchoolId = SelectedSchool.Id
            };

        _context.Learners.Add(entity);
        await _context.SaveChangesAsync();

        foreach (var parent in Parents)
        {
            parent.LearnerId = learnerId;
            await learnerService.AddParentToLearnerAsync(parent);
        }

        SetAlert("success", "Learner and Parents added successfully.");
        await Task.Delay(1000);
        navigationManager.NavigateTo("/learners");
    }

    private void OnCombinationSubjectChanged(Combination combo, Subject newSubject)
    {
        // If there was an old subject chosen in this combo, remove it from SubjectIds:
        if (CombinationSelections.TryGetValue(combo.Id, out var oldSubjectId))
        {
            Learner.SubjectIds.Remove(oldSubjectId);
        }

        // Mark this new subject as chosen in the UI dictionary
        CombinationSelections[combo.Id] = newSubject.Id;

        // Add the new subject to Learner’s selected list:
        if (!Learner.SubjectIds.Contains(newSubject.Id))
        {
            Learner.SubjectIds.Add(newSubject.Id);
        }
    }

    private bool IsSubjectDisabled(Guid subjectId, Guid currentComboId)
    {
        // Disable if subjectId appears as the chosen subject in ANY other combination:
        return CombinationSelections.Any(kvp => kvp.Key != currentComboId && kvp.Value == subjectId);
    }

    private void SetAlert(string type, string message)
    {
        AlertType = type; // "success", "danger", "warning", etc.
        AlertMessage = message;
        StateHasChanged();
    }

    private void ClearAlert()
    {
        AlertMessage = null;
        StateHasChanged();
    }
}
