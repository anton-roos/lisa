@page "/learners"
@using Lisa.Models.Entities
@inject SchoolService SchoolService
@inject LearnerService LearnerService
@inject NavigationManager NavigationManager
@inherits EventAwareComponentBase

@if (SelectedSchool != null)
{
    <h3>Learners for @SelectedSchool.ShortName</h3>
    <div class="row mb-3">
        <div class="col-12 col-md-4 mb-2">
            <label for="gradeFilter" class="form-label">Filter by Grade</label>
            <select id="gradeFilter" class="form-select" @bind="SelectedGradeId">
                <option value="">All Grades</option>
                @if (AvailableGrades != null)
                {
                    @foreach (var grade in AvailableGrades)
                    {
                        <option value="@grade.Id">@grade.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-12 col-md-4 mb-2">
            <!-- Name Search -->
            <label for="nameSearch" class="form-label">Search by Name</label>
            <input id="nameSearch" type="text" class="form-control" @oninput="OnSearchTermChanged" @bind="SearchTerm"
                placeholder="Type name..." />
        </div>
        <div class="col-12 col-md-4 mb-2 d-flex align-items-end">
            <button class="btn btn-primary mb-3" @onclick="AddLearner">Add Learner</button>
        </div>
    </div>

    @if (FilteredLearners.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Surname</th>
                    <th>Name</th>
                    <th>Grade</th>
                    <th>Subjects Count</th>
                    <th>Combination Subjects (A to C)</th>
                    <th>Parents</th>
                    <th>Care Group</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var learner in FilteredLearners)
                {
                    <tr>
                        <td>@learner.Code</td>
                        <td>@learner.Surname</td>
                        <td>@learner.Name</td>
                        <td>@(learner.RegisterClass?.Grade?.Name ?? "Unassigned")</td>
                        <td>@learner.LearnerSubjects.Count()</td>
                        <td>

                            @foreach (var subject in learner.LearnerSubjects)
                            {
                                switch (subject.Subject.SubjectType)
                                {
                                    case SubjectType.Compulsory:
                                        <span class="badge bg-primary px-1">@subject.Subject.Code</span>
                                        break;
                                    case SubjectType.MathCombination:
                                        <span class="badge bg-success px-1">@subject.Subject.Code</span>
                                        break;
                                    case SubjectType.Combination:
                                        
                                        <span class="badge bg-danger px-1">@subject.Subject.Code</span>
                                        break;
                                    default:
                                        <span class="badge bg-light px-1s">@subject.Subject.Code</span>
                                        break;
                                }
                            }
                        </td>
                        <td>@learner.Parents.Count()</td>
                        <td>@learner.CareGroup.Name</td>
                        <ActionButtons TEntity="Learner" Entity="learner" OnView="ViewLearner" OnEdit="EditLearner"
                            OnDelete="DeleteLearner" />
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            No learners found for @SelectedSchool.ShortName with the current filters.
        </div>
    }
}
else
{
    <div class="alert alert-info">
        Please select a school to view learners.
    </div>
}

@code {
    private List<Learner> Learners = new();
    private IEnumerable<Learner> FilteredLearners => ApplyFilters();
    private School? SelectedSchool;

    private string? SelectedGradeId { get; set; }
    private string? SearchTerm { get; set; }
    private List<Grade>? AvailableGrades { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SelectedSchool = SchoolService.GetSelectedSchool();
        SubscribeToEvent(UiEvents.SchoolSelected);
        await LoadLearners();
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                SelectedSchool = payload as School;
                await LoadLearners();
                break;
        }

        await base.HandleEventAsync(eventName, payload);
    }

    private async Task LoadLearners()
    {
        SelectedSchool = SchoolService.GetSelectedSchool();
        if (SelectedSchool?.Id != null)
        {
            Learners = await LearnerService.GetLearnersBySchoolAsync(SelectedSchool.Id);

            AvailableGrades = Learners
            .Where(l => l.RegisterClass?.Grade != null)
            .Select(l => l.RegisterClass!.Grade!)
            .DistinctBy(g => g.Id)
            .ToList();
        }
        else
        {
            Learners = new List<Learner>();
            AvailableGrades = new List<Grade>();
        }
    }

    private IEnumerable<Learner> ApplyFilters()
    {
        var query = Learners.AsEnumerable();

        if (!string.IsNullOrEmpty(SelectedGradeId))
        {
            query = query.Where(l => l.RegisterClass?.Grade != null
            && l.RegisterClass.Grade.Id == Guid.Parse(SelectedGradeId));
        }

        if (!string.IsNullOrEmpty(SearchTerm))
        {
            var term = SearchTerm.Trim().ToLower();
            query = query.Where(l =>
            ($"{l.Surname} {l.Name}").ToLower().Contains(term));
        }

        return query;
    }

    private async Task OnSearchTermChanged(ChangeEventArgs e)
    {
        SearchTerm = e.Value?.ToString();
        await InvokeAsync(StateHasChanged);
    }

    private void EditLearner(Learner learner)
    {
        NavigationManager.NavigateTo($"/learners/edit/{learner.Id}");
    }

    private void ViewLearner(Learner learner)
    {
        NavigationManager.NavigateTo($"/learners/details/{learner.Id}");
    }

    private void AddLearner()
    {
        NavigationManager.NavigateTo("/learners/add");
    }

    private async Task DeleteLearner(Learner learner)
    {
        await LearnerService.DeleteLearnerAsync(learner.Id);
        await LoadLearners();
        await InvokeAsync(StateHasChanged);
    }
}
