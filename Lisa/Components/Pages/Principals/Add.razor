@page "/principals/add/"
@using Lisa.Models.ViewModels
@using Microsoft.AspNetCore.Authorization
@using Lisa.Models.Entities
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Navigation
@inject LisaDbContext DbContext
@inject UserManager<User> UserManager
@inject SchoolService SchoolService

<AuthorizeView Context="auth" Roles="@($"{Roles.SystemAdministrator}")">
    <Authorized>
        <h3>Add Principal</h3>

        <EditForm  Context="edit" Model="Principal" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label for="firstName">First Name</label>
                <InputText id="firstName" class="form-control" @bind-Value="Principal.FirstName" />
            </div>

            <div class="form-group">
                <label for="lastName">Last Name</label>
                <InputText id="lastName" class="form-control" @bind-Value="Principal.LastName" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password" class="form-control" @bind-Value="Principal.Password" />
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </EditForm>
    </Authorized>
    <NotAuthorized>
        <h3>You are not authorized to access this page.</h3>
    </NotAuthorized>
</AuthorizeView>

@code {
    private PrincipalViewModel Principal { get; set; } = new(); 
    private School? SelectedSchool;

    protected override async Task OnInitializedAsync()
    {
        SchoolService.SchoolSelected += HandleSchoolChanged;
        SelectedSchool = SchoolService.SelectedSchool;
    }

    private void HandleSchoolChanged()
    {
        SelectedSchool = SchoolService.SelectedSchool;
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            var userEntity = new Principal
            {
                FirstName = Principal.FirstName,
                LastName = Principal.LastName,
                Email = Principal.Email,
                UserName = Principal.Email,
                SchoolId = SelectedSchool.Id
            };

            var result = await UserManager.CreateAsync(userEntity, Principal.Password);
            if (result.Succeeded)
            {
                await UserManager.AddToRoleAsync(userEntity, Roles.Principal);

                Navigation.NavigateTo("/principals");
            }
            else
            {
                // Handle errors
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/principals");
    }
}
