@page "/principals"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SchoolService SchoolService

<h3>Principals</h3>

@if (CurrentSchool == null)
{
    <div class="alert alert-warning">
        No school selected. Please select a school first.
    </div>
}
else if (UsersInRole == null)
{
    <p>Loading...</p>
}
else if (UsersInRole.Count == 0)
{
    <p>No Principals found for @CurrentSchool.ShortName.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>School</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var Principal in Principals)
            {
                <tr>
                    <td>@($"{Principal.FirstName} {Principal.LastName}")</td>
                    <td>@CurrentSchool.ShortName</td>
                </tr>
            }
        </tbody>
    </table>
}

<button class="btn btn-success" @onclick="GoToAddPrincipal" disabled="@IsSchoolNotSelected">
    Add Principal
</button>

@code {
    private School? CurrentSchool;
    private List<User> UsersInRole = new();
    private List<Principal> Principals = new();
    private bool IsSchoolNotSelected => CurrentSchool == null || CurrentSchool.Id == Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        SchoolService.SchoolSelected += HandleSchoolChange;
        CurrentSchool = SchoolService.SelectedSchool;

        if (CurrentSchool != null)
        {
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        UsersInRole = await SchoolService.GetUsersByRoleAndSchoolAsync(Roles.Principal, CurrentSchool.Id);
        Principals = UsersInRole.OfType<Principal>().ToList();
    }

    private void HandleSchoolChange()
    {
        CurrentSchool = SchoolService.SelectedSchool;
        InvokeAsync(async () =>
        {
            if (CurrentSchool != null)
            {
                await LoadUsers();
            }
            StateHasChanged();
        });
    }

    private void GoToAddPrincipal()
    {
        Navigation.NavigateTo("/principals/add");
    }
}