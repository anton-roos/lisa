@page "/progress-feedback-details/{LearnerId:guid}"
@using Lisa.Models.EmailModels
@using Lisa.Models.Entities
@using System.Globalization
@using Microsoft.AspNetCore.WebUtilities
@inject ProgressFeedbackService ProgressFeedbackService
@inject NavigationManager NavigationManager
@inject UserService UserService
@inject EmailRendererService RenderService

@if (html == string.Empty)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <p class="text-muted">Loading...</p>
    </div>
}
else
{
    <div>@((MarkupString)html)</div>
}
<div class="text-center mt-4">
    <button class="btn btn-secondary btn-lg" @onclick="GoBack">Back</button>
</div>

@code {
    [Parameter]
    public Guid LearnerId { get; set; }
    private string html = string.Empty;
    private DateTime? FromDate { get; set; }
    private DateTime? ToDate { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Parse query parameters
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var queryParams = QueryHelpers.ParseQuery(uri.Query);

        // Extract from date parameter if present
        if (queryParams.TryGetValue("fromDate", out var fromDateParam) && 
            DateTime.TryParse(fromDateParam, out var parsedFromDate))
        {
            // Convert to UTC to ensure compatibility with PostgreSQL
            FromDate = DateTime.SpecifyKind(parsedFromDate, DateTimeKind.Utc);
        }

        // Extract to date parameter if present
        if (queryParams.TryGetValue("toDate", out var toDateParam) && 
            DateTime.TryParse(toDateParam, out var parsedToDate))
        {
            // Convert to UTC to ensure compatibility with PostgreSQL
            ToDate = DateTime.SpecifyKind(parsedToDate, DateTimeKind.Utc);
        }

        // Pass date parameters to the renderer service
        html = await RenderService.RenderProgressFeedbackAsync(LearnerId, FromDate, ToDate);
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/progress-feedback");
    }
}
