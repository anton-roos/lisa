@page "/register-class"
@using Lisa.Models.Entities
@inject SchoolService SchoolService
@inject RegisterClassService RegisterClassService
@inject NavigationManager NavigationManager
@inherits EventAwareComponentBase

<h3>Register Classes</h3>
<button class="btn btn-primary" @onclick="AddRegisterClass">Add Register Class</button>
@if (SelectedSchool != null && RegisterClasses.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Grade</th>
                <th>Learner Count</th>
                <th>Teacher</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var registerClass in RegisterClasses)
            {
                <tr>
                    <td>@registerClass.Name</td>
                    <td>@registerClass.Grade.Name</td>
                    <td>@registerClass.Learners.Count.ToString()</td>
                    <td>@registerClass.Teacher.LastName</td>
                    <ActionButtons TEntity="RegisterClass" Entity="registerClass" OnView="ViewRegisterClass" OnEdit="EditRegisterClass"
                        OnDelete="DeleteRegisterClass" />
                </tr>
            }
        </tbody>
    </table>
}
else if (SelectedSchool != null && !RegisterClasses.Any())
{
    <div class="alert alert-info">
        No Register Classes found for <strong>@SelectedSchool.ShortName</strong>.
    </div>
}
else
{
    <div class="alert alert-info">
        Please select a school to view its Register Classes.
    </div>
}

@code {
    private List<RegisterClass> RegisterClasses = new();
    private School? SelectedSchool;

    protected override async Task OnInitializedAsync()
    {
        SubscribeToEvent(UiEvents.SchoolSelected);
        SelectedSchool = SchoolService.GetSelectedSchool();
        if (SelectedSchool != null)
        {
            await LoadRegisterClasses(SelectedSchool.Id);
        }
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        // Handle the events and update the state
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                // Cast Payload to a School
                SelectedSchool = payload as School;
                break;
        }

        // Ensure state change
        await base.HandleEventAsync(eventName, payload);
    }

    private async Task LoadRegisterClasses(Guid schoolId)
    {
        var unfiltedRegisterClasses = await RegisterClassService.GetAllAsync();
        RegisterClasses = unfiltedRegisterClasses.Where(rc => rc.Grade.SchoolId == schoolId).ToList();
    }

    private void EditRegisterClass(RegisterClass registerClass)
    {
        NavigationManager.NavigateTo($"/register-class/edit/{registerClass.Id}");
    }

    private void ViewRegisterClass(RegisterClass registerClass)
    {
        NavigationManager.NavigateTo($"/register-class/details/{registerClass.Id}");
    }

    public async Task DeleteRegisterClass(RegisterClass registerClass)
    {
        if (registerClass != null)
        {
            await RegisterClassService.DeleteAsync(registerClass);
            await LoadRegisterClasses(SelectedSchool.Id);
            StateHasChanged();
        }
    }

    private void AddRegisterClass()
    {
        NavigationManager.NavigateTo("/register-class/add");
    }
}
