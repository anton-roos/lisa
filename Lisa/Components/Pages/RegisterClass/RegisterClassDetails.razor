@page "/register-class/details/{RegisterClassId:guid}"
@using Lisa.Models.Entities
@inject SchoolService SchoolService
@inject NavigationManager Navigation
@inject RegisterClassService RegisterClassService
@using Microsoft.AspNetCore.Components

<h3>Register Class Details</h3>

@if (RegisterClass == null)
{
    <p>Loading...</p>
}
else
{
    <dl class="row">
        <dt class="col-sm-2">Class Name</dt>
        <dd class="col-sm-10">@RegisterClass.Name</dd>

        <dt class="col-sm-2">Grade</dt>
        <dd class="col-sm-10">@RegisterClass.Grade?.Name</dd>

        <dt class="col-sm-2">Teacher</dt>
        <dd class="col-sm-10">
            @($"{RegisterClass.Teacher?.FirstName} {RegisterClass.Teacher?.LastName}")
        </dd>
    </dl>

    <h4>Enrolled Learners</h4>
    @if (RegisterClass.Learners == null || RegisterClass.Learners.Count == 0)
    {
        <p>No learners in this class.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var learner in RegisterClass.Learners)
                {
                    <tr>
                        <td>@($"{learner.FirstName} {learner.LastName}")</td>
                        <td>
                            <button class="btn btn-primary" 
                                    @onclick="() => ViewLearner(learner.Id)">
                                View Learner
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    }
        <dt>Subjects</dt>
        <dd>
            <ul>
                @if (RegisterClass.CompulsorySubjects != null)
                {
                    @foreach (var subject in RegisterClass.CompulsorySubjects)
                    {
                        <li>@subject.Name</li>
                    }
                }
            </ul>
        </dd>

    <button class="btn btn-secondary" @onclick="GoBack">Back</button>
}

@code {
    [Parameter]
    public Guid RegisterClassId { get; set; }

    private RegisterClass? RegisterClass;

    protected override async Task OnInitializedAsync()
    {
        RegisterClass = await RegisterClassService.GetByIdAsync(RegisterClassId);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/register-class");
    }

    private void ViewLearner(Guid learnerId)
    {
        Navigation.NavigateTo($"/learners/details/{learnerId}");
    }
}
