@page "/results/{ResultSetId:guid}"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject ResultService ResultService
@inject ILogger<ResultSetDetails> Logger

<PageTitle>Result Set Details</PageTitle>
<AuthorizeView Context="AuthContext"
    Roles="@($"{Roles.SystemAdministrator},{Roles.Principal},{Roles.SchoolManagement},{Roles.Administrator},{Roles.Teacher}")">
    <Authorized>
        <h3>Result Set Details</h3>

        @if (_loading)
        {
            <p>Loading...</p>
        }
        else if (_resultSet == null)
        {
            <div class="alert alert-danger">
                Result Set not found.
            </div>
        }
        else
        {
            <div class="card p-3">
                <h4>Assessment Details</h4>
                <p><strong>Assessment Topic:</strong> @_resultSet.AssessmentTopic</p>
                <p><strong>Assessment Type:</strong> @_resultSet.AssessmentType</p>
                <p><strong>Date:</strong> @_resultSet.AssessmentDate?.ToString("yyyy-MM-dd")</p>

                <h4>Results</h4>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Score</th>
                            <th>Absent?</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (_resultSet.Results != null)
            {
                foreach (var result in _resultSet.Results)
                {
                    <tr>
                        <td>@result.Learner?.Surname, @result.Learner?.Name</td>
                        <td>@(result.Absent ? "-" : result.Score?.ToString())</td>
                        <td>@(result.Absent ? "Yes" : "No")</td>
                        <td>@result.AbsentReason</td>
                    </tr>
                }
            }
            </tbody>
                </table>

                <button class="btn btn-secondary" @onclick="GoBack">Back to Results</button>
                <button class="btn btn-success" @onclick="Edit">Edit</button>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <Unauthorized />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public Guid ResultSetId { get; set; }
    private ResultSet? _resultSet;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _resultSet = await ResultService.GetByIdAsync(ResultSetId);
            _loading = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load result set with ID: {ResultSetId}", ResultSetId);
            _loading = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/results");
    private void Edit() => Navigation.NavigateTo($"/results/manager/{ResultSetId}");
}
