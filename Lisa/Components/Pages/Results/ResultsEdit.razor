@page "/results/edit/{ResultId:guid}"
@using Lisa.Models.Entities
@inject ResultService ResultService
@inject ILogger<ResultsEdit> Logger
@inject NavigationManager NavigationManager
@inject SchoolService SchoolService

<PageTitle>Edit Result</PageTitle>

@if (IsLoading)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="Result" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <!-- Display Learner Name -->
        <div class="form-group">
            <label>Learner</label>
            <div>@Result.Learner?.Surname @Result.Learner?.Name</div>
        </div>

        <!-- Display Subject from the ResultSet -->
        <div class="form-group">
            <label>Subject</label>
            <div>@Result.ResultSet?.Subject?.Name</div>
        </div>

        <!-- Input for Score (only if the learner is not absent) -->
        @if (!Result.Absent)
        {
            <div class="form-group">
                <label>Score</label>
                <InputNumber @bind-Value="Result.Score" class="form-control" min="0" max="100" step="1" />
            </div>
        }

        <!-- Input for Assessment Type stored on ResultSet -->
        <div class="form-group">
            <label>Assessment Type</label>
            <InputText @bind-Value="Result.ResultSet.AssessmentType" class="form-control" />
        </div>

        <!-- Input for Assessment Topic stored on ResultSet -->
        <div class="form-group">
            <label>Assessment Topic</label>
            <InputText @bind-Value="Result.ResultSet.AssessmentTopic" class="form-control" />
        </div>

        <!-- Checkbox for Absent -->
        <div class="form-group">
            <label for="Absent">Absent</label>
            <InputCheckbox id="Absent" @bind-Value="Result.Absent" @onchange="HandleEvent" />
        </div>

        <!-- If absent, allow entering an absent reason -->
        @if (Result.Absent)
        {
            <div class="form-group">
                <label for="AbsentReason">Absent Reason</label>
                <InputText id="AbsentReason" @bind-Value="Result.AbsentReason" class="form-control" />
            </div>
        }
        else
        {
            <div style="display:none">
                <label for="AbsentReason">Absent Reason</label>
                <InputText id="AbsentReason" @bind-Value="Result.AbsentReason" class="form-control" />
            </div>
        }

        <button type="submit" class="btn btn-primary">Save</button>
    </EditForm>
}

@code {
    [Parameter] public Guid ResultId { get; set; }
    private Result Result = new();
    private bool IsLoading = true;
    private School? SelectedSchool;

    protected override async Task OnInitializedAsync()
    {
        await LoadResult();
    }

    private async Task LoadResult()
    {
        try
        {
            IsLoading = true;
            // Ensure the ResultService loads the ResultSet and related Subject data
            Result = await ResultService.GetByIdAsync(ResultId);
            SelectedSchool = SchoolService.GetSelectedSchool();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load result.");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        await ResultService.UpdateAsync(Result);
        await InvokeAsync(StateHasChanged);
        NavigationManager.NavigateTo($"/results/{Result.Id}");
    }

    // When the Absent checkbox changes, set Score to 0 if Absent is true.
    private void HandleEvent()
    {
        if (Result.Absent)
        {
            Result.Score = 0;
            StateHasChanged();
        }
    }
}
