@page "/results/list/{schoolId:guid}/{gradeId:guid}/{subjectId:guid}"
@using Lisa.Models.Entities
@inject ResultService ResultService
@inject SchoolService SchoolService
@inject GradeService GradeService
@inject SubjectService SubjectService
@inject NavigationManager Navigation
@inject ILogger<ResultsList> Logger

<h3>Filtered Results</h3>

@if (IsLoading)
{
    <p>Loading results...</p>
}
else if (Results.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Student</th>
                <th>Subject</th>
                <th>Score</th>
                <th>Date</th>
                <th>Assessment Type</th>
                <th>Topic</th>
                <th>Created On</th>
                <th>Absent?</th>
                <th>Reason</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var result in Results)
            {
                <tr>
                    <td>@result.Learner?.FirstName @result.Learner?.LastName</td>
                    <td>@result.Subject?.Name</td>
                    <td>
                        @if (result.Absent)
                        {
                            <div>Absent</div>
                        }
                        else
                        {
                            <div>
                                @result.Score.ToString("0")
                            </div>
                        }
                    </td>
                    <td>@result.ResultDate.ToString("yyyy-MM-dd")</td>
                    <td>@result.AssessmentType</td>
                    <td>@result.AssessmentTopic</td>
                    <td>@result.CreatedAt</td>
                    <td>@(result.Absent ? "Yes" : "No")</td>
                    <td>@result.AbsentReason</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="() => EditResult(result.Id)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteResult(result.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No results found for the selected filters.
    </div>
}

@code {
    [Parameter] public Guid schoolId { get; set; }
    [Parameter] public Guid gradeId { get; set; }
    [Parameter] public Guid subjectId { get; set; }

    private List<Result> Results = new();
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadResults();
    }

    private async Task LoadResults()
    {
        try
        {
            IsLoading = true;
            Results = await ResultService.GetResultsByFiltersAsync(schoolId, gradeId, subjectId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load filtered results.");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void EditResult(Guid resultId)
    {
        Navigation.NavigateTo($"/results/edit/{resultId}");
    }

    private async Task DeleteResult(Guid resultId)
    {
        await ResultService.DeleteAsync(resultId);
        await LoadResults();
    }
}
