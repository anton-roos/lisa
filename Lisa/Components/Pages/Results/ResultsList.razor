@page "/results"
@using Lisa.Models.Entities
@inject ResultService ResultService
@inject SchoolService SchoolService
@inject SchoolGradeService SchoolGradeService
@inject SubjectService SubjectService
@inject NavigationManager Navigation
@inject UserService UserService

@inherits EventAwareComponentBase

<AuthorizeView
    Roles="@($"{Roles.SystemAdministrator},{Roles.Principal},{Roles.SchoolManagement},{Roles.Administrator},{Roles.Teacher}")">
    <Authorized>
        <PageTitle>Results</PageTitle>
        <h3>Results</h3>

        @if (_selectedSchool == null)
        {
            <div class="alert alert-info">Please select a school to view results.</div>
        }
        else if (_loading)
        {
            <p>Loading results...</p>
        }
        else
        {
            <div class="mb-3">
                <label><strong>View Results by:</strong></label>
                <div class="btn-group" role="group">
                    <input type="radio" class="btn-check" name="viewMode" id="viewByGrade" value="Grade"
                        checked="@(ViewMode == "Grade")" @onchange="@(_ => SetViewMode("Grade"))" />
                    <label class="btn btn-outline-secondary" for="viewByGrade">Grade</label>

                    <input type="radio" class="btn-check" name="viewMode" id="viewBySubject" value="Subject"
                        checked="@(ViewMode == "Subject")" @onchange="@(_ => SetViewMode("Subject"))" />
                    <label class="btn btn-outline-secondary" for="viewBySubject">Subject</label>

                    <input type="radio" class="btn-check" name="viewMode" id="viewByTeacher" value="Teacher"
                        checked="@(ViewMode == "Teacher")" @onchange="@(_ => SetViewMode("Teacher"))" />
                    <label class="btn btn-outline-secondary" for="viewByTeacher">Teacher</label>

                    <input type="radio" class="btn-check" name="viewMode" id="viewByLearner" value="Learner"
                        checked="@(ViewMode == "Learner")" @onchange="@(_ => SetViewMode("Learner"))" />
                    <label class="btn btn-outline-secondary" for="viewByLearner">Learner</label>
                </div>
            </div>

            <!-- Grade View -->
            @if (ViewMode == "Grade")
            {
                <div class="mb-3">
                    <label><strong>Select Grade:</strong></label>
                    <InputSelect class="form-select" TValue="Guid ?" Value="@_gradeId" ValueChanged="OnGradeChange"
                        ValueExpression="() => _gradeId">
                        <option value="">-- Select Grade --</option>
                        @foreach (var grade in _schoolGrades)
                        {
                            <option value="@grade.Id">@grade.SystemGrade.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="d-flex flex-column">
                    @if (GroupedResults.Any())
                    {
                        @foreach (var group in GroupedResults)
                        {
                            <div class="mb-2">
                                <h5>@group.Key</h5>
                                <div class="d-flex flex-wrap">
                                    @foreach (var set in group.Value)
                                    {
                                        @if (set is null)
                                        {
                                            continue;
                                        }

                                        <div class="me-1" type="button" @onclick="() => ViewResult(set.Id)">
                                            <Pill Color="@GetResultSetStatusColor(set)">
                                                @if (set.AssessmentDate.HasValue)
                                                {
                                                    @set.AssessmentDate.Value.ToString("dd MMM")
                                                }
                                            </Pill>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-secondary">No Results</div>
                    }
                </div>
            }

            <!-- Subject View -->
            @if (ViewMode == "Subject")
            {
                <div class="mb-3">
                    <label><strong>Select Subject:</strong></label>
                    <InputSelect class="form-select" TValue="int?" Value="@_subjectId" ValueChanged="OnSubjectChange"
                        ValueExpression="() => _subjectId">
                        <option value="">-- Select Subject --</option>
                        @foreach (var subject in _subjects)
                        {
                            <option value="@subject.Id">@subject.Name</option>
                        }
                    </InputSelect>
                </div>

                @if (_subjectId is not null)
                {
                    <div class="mb-3">
                        <label><strong>Select Grade:</strong></label>
                        <div class="d-flex flex-wrap">
                            @if (_availableGradesForSubject is not null)
                            {
                                foreach (var grade in _availableGradesForSubject)
                                {
                                    <button class="btn btn-sm @(_selectedGrades.Contains(grade) ? "btn-success" : "btn-outline-success")"
                                        @onclick="() => ToggleGradeSelection(grade)">
                                        @FormatGrade(grade)
                                    </button>
                                }
                            }
                        </div>
                    </div>
                }

                <div class="d-flex flex-column">
                    @if (GroupedResults.Any())
                    {
                        @foreach (var group in GroupedResults)
                        {
                            <div class="mb-2">
                                <h5>@group.Key</h5>
                                <div class="d-flex flex-wrap">
                                    @foreach (var set in group.Value)
                                    {
                                        @if (set is null)
                                        {
                                            continue;
                                        }

                                        <div class="me-1" type="button" @onclick="() => ViewResult(set.Id)">
                                            <Pill Color="@GetResultSetStatusColor(set)">
                                                @if (set.AssessmentDate.HasValue)
                                                {
                                                    @set.AssessmentDate.Value.ToString("dd MMM")
                                                }
                                            </Pill>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-secondary">No Results</div>
                    }
                </div>
            }

            <!-- Teacher View -->
            @if (ViewMode == "Teacher")
            {
                <div class="mb-3">
                    <label><strong>Select Teacher:</strong></label>
                    <InputSelect class="form-select" TValue="Guid ?" Value="@_teacherId" ValueChanged="OnTeacherChange"
                        ValueExpression="() => _teacherId">
                        <option value="">-- Select Teacher --</option>
                        @foreach (var teacher in _teachers)
                        {
                            <option value="@teacher.Id">@teacher.Abbreviation @teacher.Surname</option>
                        }
                    </InputSelect>
                </div>

                <div class="d-flex flex-column">
                    @if (GroupedResults.Any())
                    {
                        @foreach (var group in GroupedResults)
                        {
                            <div class="mb-2">
                                <h5>@group.Key</h5>
                                <div class="d-flex flex-wrap">
                                    @foreach (var set in group.Value)
                                    {
                                        @if (set is null)
                                        {
                                            continue;
                                        }

                                        <div class="me-1" type="button" @onclick="() => ViewResult(set.Id)">
                                            <Pill Color="@GetResultSetStatusColor(set)">
                                                @if (set.AssessmentDate.HasValue)
                                                {
                                                    @set.AssessmentDate.Value.ToString("dd MMM")
                                                }
                                            </Pill>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-secondary">No Results</div>
                    }
                </div>
            }

            @if (ViewMode == "Learner")
            {
                <div>Learner Search</div>
            }
        }
    </Authorized>
</AuthorizeView>

@code {
    private string ViewMode { get; set; } = "Grade";
    private List<ResultSet?> _resultsSet = [];
    private Dictionary<string, List<ResultSet?>> GroupedResults { get; set; } = new();
    private List<SchoolGrade> _schoolGrades = [];
    private List<Subject> _subjects = [];
    private List<User> _teachers = [];
    private List<int>? _availableGradesForSubject = [];
    private readonly HashSet<int> _selectedGrades = [];
    private bool _loading;
    private School? _selectedSchool;
    private Guid? _gradeId, _teacherId;
    private int? _subjectId;

    protected override async Task OnInitializedAsync()
    {
        SubscribeToEvent(UiEvents.SchoolSelected);
        _selectedSchool = await SchoolService.GetSelectedSchoolAsync();
        await LoadFilters();
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                if (payload is School school)
                {
                    _selectedSchool = school;
                    await LoadFilters();
                }

                break;
        }

        await base.HandleEventAsync(eventName, payload);
    }

    /// <summary>
    /// Changes the view mode and clears out selections/results.
    /// </summary>
    private void SetViewMode(string mode)
    {
        ViewMode = mode;
        _selectedGrades.Clear();
        StateHasChanged();
    }

    /// <summary>
    /// Loads result sets from the service based on the current filters.
    /// Uses a different overload for Subject view (with multi-grade filtering).
    /// </summary>
    private async Task LoadResults()
    {
        _loading = true;

        if (_selectedSchool is null)
        {
            _loading = false;
            return;
        }


        switch (ViewMode)
        {
            case "Subject":
                _resultsSet = (await ResultService.GetResultsByFiltersAsync(_selectedSchool.Id, null, _subjectId, null, null))
                .OrderBy(r => r!.AssessmentDate)
                .ToList();

                GroupedResults = _resultsSet
                .GroupBy(r => $"{r!.Subject!.Name!} - {r.SchoolGrade!.SystemGrade.Name!}")
                .ToDictionary(g => $"{g.Key}", g => g.ToList());
                break;
            case "Grade":
                _resultsSet = (await ResultService.GetResultsByFiltersAsync(_selectedSchool.Id, _gradeId, null, null, null))
                .OrderBy(r => r?.AssessmentDate)
                .ToList();

                GroupedResults = _resultsSet
                .GroupBy(r => r!.Subject!.Name)
                .ToDictionary(g => g.Key!, g => g.ToList());
                break;
            case "Teacher":
                _resultsSet = (await ResultService.GetResultsByFiltersAsync(_selectedSchool.Id, null, null, _teacherId, null))
                .OrderBy(r => r!.AssessmentDate)
                .ToList();

                GroupedResults = _resultsSet
                .GroupBy(r => new { r!.Teacher!.Abbreviation, r.Subject!.Name })
                .ToDictionary(g => $"{g.Key.Abbreviation} - {g.Key.Name}", g => g.ToList());
                break;
        }

        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Loads filter options such as grades, subjects, and teachers.
    /// </summary>
    private async Task LoadFilters()
    {
        if (_selectedSchool != null)
        {
            _schoolGrades = await SchoolGradeService.GetGradesForSchool(_selectedSchool.Id);
            _subjects = await SubjectService.GetAllAsync();
            _teachers = await UserService.GetAllByRoleAndSchoolAsync([Roles.Teacher], _selectedSchool.Id);
        }
    }

    /// <summary>
    /// Toggles the selected grade for multi-grade filtering.
    /// </summary>
    private async Task ToggleGradeSelection(int gradeId)
    {
        if (_selectedGrades.Contains(gradeId))
            _selectedGrades.Remove(gradeId);
        else
            _selectedGrades.Add(gradeId);

        await LoadResults();
    }

    /// <summary>
    /// Handles subject changes, ensuring the selected subject is stored and its available grades loaded.
    /// </summary>
    private async Task OnSubjectChange(int? value)
    {
        _subjectId = value;
        if (value.HasValue)
        {
            var subject = await SubjectService.GetByIdAsync(value.Value);
            if (subject != null) _availableGradesForSubject = subject.GradesApplicable;
        }
        else
        {
            _availableGradesForSubject?.Clear();
        }

        _selectedGrades.Clear();
        await LoadResults();
    }

    private async Task OnGradeChange(Guid? value)
    {
        _gradeId = value;
        await LoadResults();
    }

    /// <summary>
    /// Handles teacher selection changes.
    /// </summary>
    private async Task OnTeacherChange(Guid? value)
    {
        _teacherId = value;
        await LoadResults();
    }

    /// <summary>
    /// Navigates to the edit page for the given result set.
    /// </summary>
    private void EditResult(Guid resultSetId)
    {
        Navigation.NavigateTo($"results/manage/{resultSetId}");
    }

    private void ViewResult(Guid resultSetId)
    {
        Navigation.NavigateTo($"results/{resultSetId}");
    }

    /// <summary>
    /// Formats the grade value for display.
    /// </summary>
    private string FormatGrade(int grade) =>
    grade switch
    {
        -2 => "Gr RRR",
        -1 => "Gr RR",
        0 => "Gr R",
        _ => $"Gr {grade}"
    };

    private static string GetResultSetStatusColor(ResultSet set)
    {
        if (set.Status == ResultSetStatus.Draft)
        {
            return "danger";
        }
        else if (set.Status == ResultSetStatus.Submitted)
        {
            return "success";
        }
        else
        {
            return "secondary";
        }
    }

}
