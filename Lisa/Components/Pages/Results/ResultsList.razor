@page "/result-list"
@using Lisa.Models.Entities
@using Microsoft.AspNetCore.WebUtilities
@inject ResultService ResultService
@inject SchoolService SchoolService
@inject SchoolGradeService SchoolGradeService
@inject SubjectService SubjectService
@inject NavigationManager Navigation
@inject ILogger<ResultsList> Logger
@inject UserService UserService

@inherits EventAwareComponentBase

<AuthorizeView Context="AuthContext"
    Roles="@($"{Roles.SystemAdministrator},{Roles.Principal},{Roles.SchoolManagement},{Roles.Administrator}")">
    <Authorized>
        <PageTitle>Results</PageTitle>
        <h3>Results</h3>

        @if (SelectedSchool == null)
        {
            <div class="alert alert-info">Please select a school to view results.</div>
        }
        else if (Loading)
        {
            <p>Loading results...</p>
        }
        else
        {
            <div class="mb-3">
                <label><strong>View Results by:</strong></label>
                <div class="btn-group" role="group">
                    <input type="radio" class="btn-check" name="viewMode" id="viewByGrade" value="Grade"
                        checked="@(ViewMode == "Grade")" @onchange="@(e => SetViewMode("Grade"))" />
                    <label class="btn btn-outline-secondary" for="viewByGrade">Grade</label>

                    <input type="radio" class="btn-check" name="viewMode" id="viewBySubject" value="Subject"
                        checked="@(ViewMode == "Subject")" @onchange="@(e => SetViewMode("Subject"))" />
                    <label class="btn btn-outline-secondary" for="viewBySubject">Subject</label>

                    <input type="radio" class="btn-check" name="viewMode" id="viewByTeacher" value="Teacher"
                        checked="@(ViewMode == "Teacher")" @onchange="@(e => SetViewMode("Teacher"))" />
                    <label class="btn btn-outline-secondary" for="viewByTeacher">Teacher</label>
                </div>
            </div>

            <!-- Grade View -->
            @if (ViewMode == "Grade")
            {
                <div class="mb-3">
                    <label><strong>Select Grade:</strong></label>
                    <InputSelect class="form-select" TValue="Guid ?" Value="@GradeId" ValueChanged="OnGradeChange"
                        ValueExpression="() => GradeId">
                        <option value="">-- Select Grade --</option>
                        @foreach (var grade in SchoolGrades)
                        {
                            <option value="@grade.Id">@grade.SystemGrade.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="d-flex">
                    @foreach (var set in ResultsSet)
                    {
                        <div class="mt-3">
                            <div type="button" class="badge @GetResultSetStatusColor(set)" @onclick="() => EditResult(set.Id)">
                                @if (set.AssessmentDate.HasValue)
                                {
                                    @set.AssessmentDate.Value.ToString("MMM-dd")
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Subject View -->
            @if (ViewMode == "Subject")
            {
                <div class="mb-3">
                    <label><strong>Select Subject:</strong></label>
                    <InputSelect class="form-select" TValue="int?" Value="@SubjectId" ValueChanged="OnSubjectChange"
                        ValueExpression="() => SubjectId">
                        <option value="">-- Select Subject --</option>
                        @foreach (var subject in Subjects)
                        {
                            <option value="@subject.Id">@subject.Name</option>
                        }
                    </InputSelect>
                </div>

                @if (SubjectId is not null)
                {
                    <div class="mb-3">
                        <label><strong>Select Grade:</strong></label>
                        <div class="d-flex flex-wrap">
                            @foreach (var grade in AvailableGradesForSubject)
                            {
                                <button class="btn btn-sm @(SelectedGrades.Contains(grade) ? "btn-success" : "btn-outline-success")"
                                    @onclick="() => ToggleGradeSelection(grade)">
                                    @FormatGrade(grade)
                                </button>
                            }
                        </div>
                    </div>
                }

                <div class="d-flex">
                    @foreach (var set in ResultsSet)
                    {
                        <div class="mt-3">
                            <div class="badge @GetResultSetStatusColor(set)" @onclick="() => EditResult(set.Id)">
                                @if (set.AssessmentDate.HasValue)
                                {
                                    @set.AssessmentDate.Value.ToString("MMM-dd")
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Teacher View -->
            @if (ViewMode == "Teacher")
            {
                <div class="mb-3">
                    <label><strong>Select Teacher:</strong></label>
                    <InputSelect class="form-select" TValue="Guid ?" Value="@TeacherId" ValueChanged="OnTeacherChange"
                        ValueExpression="() => TeacherId">
                        <option value="">-- Select Teacher --</option>
                        @foreach (var teacher in Teachers)
                        {
                            <option value="@teacher.Id">@teacher.Abbreviation @teacher.Surname</option>
                        }
                    </InputSelect>
                </div>

                <div class="d-flex">
                    @foreach (var set in ResultsSet)
                    {
                        <div class="mt-3">
                            <div type="button" class="badge @GetResultSetStatusColor(set)" @onclick="() => EditResult(set.Id)">
                                @if (set.AssessmentDate.HasValue)
                                {
                                    @set.AssessmentDate.Value.ToString("MMM-dd")
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </Authorized>
</AuthorizeView>

@code {
    private string ViewMode { get; set; } = "Grade";
    private List<ResultSet> ResultsSet = new();
    private List<SchoolGrade> SchoolGrades = new();
    private List<Subject> Subjects = new();
    private List<User> Teachers = new();
    private List<int> AvailableGradesForSubject = new();
    private HashSet<int> SelectedGrades = new();
    private bool Loading = false;
    private School? SelectedSchool;
    private Guid? GradeId, TeacherId;
    private int? SubjectId;

    protected override async Task OnInitializedAsync()
    {
        SubscribeToEvent(UiEvents.SchoolSelected);
        SelectedSchool = SchoolService.GetSelectedSchool();
        await LoadFilters();
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                if (payload is School school)
                {
                    SelectedSchool = school;
                    await LoadFilters();
                }
                break;
        }

        await base.HandleEventAsync(eventName, payload);
    }

    /// <summary>
    /// Changes the view mode and clears out selections/results.
    /// </summary>
    private void SetViewMode(string mode)
    {
        ViewMode = mode;
        SelectedGrades.Clear();
        ResultsSet.Clear();
        StateHasChanged();
    }

    /// <summary>
    /// Loads result sets from the service based on the current filters.
    /// Uses a different overload for Subject view (with multi-grade filtering).
    /// </summary>
    private async Task LoadResults()
    {
        Loading = true;

        if (SelectedSchool is null)
        {
            Loading = false;
            return;
        }

        if (ViewMode == "Subject")
        {
            ResultsSet = (await ResultService.GetResultsByFiltersAsync(SelectedSchool.Id, null, SubjectId, null))
            .OrderBy(r => r.AssessmentDate)
            .ToList();
        }
        else if (ViewMode == "Grade")
        {
            ResultsSet = (await ResultService.GetResultsByFiltersAsync(SelectedSchool.Id, GradeId, null, null))
            .OrderBy(r => r.AssessmentDate)
            .ToList();
        }
        else if (ViewMode == "Teacher")
        {
            ResultsSet = (await ResultService.GetResultsByFiltersAsync(SelectedSchool.Id, null, null, TeacherId))
            .OrderBy(r => r.AssessmentDate)
            .ToList();
        }

        Loading = false;
        await InvokeAsync(StateHasChanged);
    }
    /// <summary>
    /// Loads filter options such as grades, subjects, and teachers.
    /// </summary>
    private async Task LoadFilters()
    {
        if (SelectedSchool != null)
        {
            SchoolGrades = await SchoolGradeService.GetGradesForSchool(SelectedSchool.Id);
            Subjects = await SubjectService.GetAllAsync();
            Teachers = await UserService.GetAllByRoleAndSchoolAsync([Roles.Teacher], SelectedSchool.Id);
        }
    }

    /// <summary>
    /// Toggles the selected grade for multi-grade filtering.
    /// </summary>
    private async Task ToggleGradeSelection(int gradeId)
    {
        if (SelectedGrades.Contains(gradeId))
            SelectedGrades.Remove(gradeId);
        else
            SelectedGrades.Add(gradeId);

        await LoadResults();
    }

    /// <summary>
    /// Handles subject changes, ensuring the selected subject is stored and its available grades loaded.
    /// </summary>
    private async Task OnSubjectChange(int? value)
    {
        SubjectId = value;
        if (value.HasValue)
        {
            var subject = await SubjectService.GetByIdAsync(value.Value);
            AvailableGradesForSubject = subject.GradesApplicable;
        }
        else
        {
            AvailableGradesForSubject.Clear();
        }
        SelectedGrades.Clear();
        await LoadResults();
    }

    private async Task OnGradeChange(Guid? value)
    {
        GradeId = value;
        await LoadResults();
    }

    /// <summary>
    /// Handles teacher selection changes.
    /// </summary>
    private async Task OnTeacherChange(Guid? value)
    {
        TeacherId = value;
        await LoadResults();
    }

    /// <summary>
    /// Navigates to the edit page for the given result set.
    /// </summary>
    private void EditResult(Guid resultSetId)
    {
        Navigation.NavigateTo($"results/manager/{resultSetId}");
    }

    /// <summary>
    /// Formats the grade value for display.
    /// </summary>
    private string FormatGrade(int grade) =>
    grade switch
    {
        -2 => "Gr RRR",
        -1 => "Gr RR",
        0 => "Gr R",
        _ => $"Gr {grade}"
    };

    private static string GetResultSetStatusColor(ResultSet set)
    {
        if (set.Status == ResultSetStatus.Draft)
        {
            return "bg-danger";
        }
        else if (set.Status == ResultSetStatus.Submitted)
        {
            return "bg-success";
        }
        else
        {
            return "bg-secondary";
        }
    }
}
