@page "/result-list"
@using Lisa.Models.Entities
@using Microsoft.AspNetCore.WebUtilities
@inject ResultService ResultService
@inject SchoolService SchoolService
@inject SchoolGradeService SchoolGradeService
@inject SubjectService SubjectService
@inject NavigationManager Navigation
@inject ILogger<ResultsList> Logger
@inject UserService UserService

@inherits EventAwareComponentBase


<AuthorizeView Context="AuthContext"
    Roles="@($"{Roles.SystemAdministrator},{Roles.Principal},{Roles.SchoolManagement},{Roles.Administrator}")">
    <Authorized>
        <PageTitle>Results</PageTitle>
        <h3>Results</h3>
        @if (SelectedSchool == null)
        {
            <div class="alert alert-info">
                Please select a school to view results.
            </div>
        }
        else if (Loading)
        {
            <p>Loading results...</p>
        }
        else
        {
            <!-- View Results By: Toggle Mode -->
            <div class="mb-3">
                <label><strong>View Results by:</strong></label>
                <div class="btn-group" role="group">
                    <input type="radio" class="btn-check" name="viewMode" id="viewByGrade" value="Grade"
                        checked="@(ViewMode == "Grade")" @onchange="@(e => SetViewMode("Grade"))" />
                    <label class="btn btn-outline-secondary" for="viewByGrade">Grade</label>

                    <input type="radio" class="btn-check" name="viewMode" id="viewBySubject" value="Subject"
                        checked="@(ViewMode == "Subject")" @onchange="@(e => SetViewMode("Subject"))" />
                    <label class="btn btn-outline-secondary" for="viewBySubject">Subject</label>

                    <input type="radio" class="btn-check" name="viewMode" id="viewByTeacher" value="Teacher"
                        checked="@(ViewMode == "Teacher")" @onchange="@(e => SetViewMode("Teacher"))" />
                    <label class="btn btn-outline-secondary" for="viewByTeacher">Teacher</label>
                </div>
            </div>

            @switch (ViewMode)
            {
                case "Grade":
                    <div class="col mb-3 mx-3">
                        <div class="row">
                            <label for="gradeDropdown">Grade</label>
                            <InputSelect class="form-select" id="gradeDropdown" TValue="string" Value="@gradeId"
                                ValueChanged="@(async (value) => await OnGradeChange(value))" ValueExpression="@(() => gradeId)">
                                <option value="">-- Select Grade --</option>
                                @foreach (var grade in SchoolGrades)
                                {
                                    <option value="@grade.Id">@grade.SystemGrade.Name</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    break;
                case "Subject":
                    <div class="col mb-3 mx-3">
                        <div class="row">
                            <label for="subjectDropdown">Subject</label>
                            <InputSelect class="form-select" id="subjectDropdown" TValue="string" Value="@subjectId"
                                ValueChanged="@(async (value) => await OnSubjectChange(value))"
                                ValueExpression="@(() => subjectId)">
                                <option value="">-- Select Subject --</option>
                                @foreach (var subject in Subjects)
                                {
                                    <option value="@subject.Id">@subject.Name</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    break;
                case "Teacher":
                    <div class="col mb-3 mx-3">
                        <div class="row">
                            <label for="teacherDropdown">Teacher</label>
                            <InputSelect class="form-select" id="teacherDropdown" TValue="string" Value="@teacherId"
                                ValueChanged="@(async (value) => await OnTeacherChange(value))"
                                ValueExpression="@(() => teacherId)">
                                <option value="">-- Select Teacher --</option>
                                @foreach (var teacher in Teachers)
                                {
                                    <option value="@teacher.Id">@teacher.Abbreviation @teacher.Surname</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    break;
            }

            @if (!string.IsNullOrWhiteSpace(gradeId))
            {

            }

            @if (!string.IsNullOrWhiteSpace(subjectId))
            {

            }

        }
    </Authorized>
    <NotAuthorized>
        <Unauthorized />
    </NotAuthorized>
</AuthorizeView>

@code {
    School? SelectedSchool { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "g")]
    public string? gradeId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "s")]
    public string? subjectId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "t")]
    public string? teacherId { get; set; }
    private string ViewMode { get; set; } = "Grade";
    private List<Result> Results = new();
    private List<SchoolGrade> SchoolGrades = new();
    private List<Subject> Subjects = new();
    private List<User> Teachers = new();
    private bool Loading = true;

    protected override async Task OnInitializedAsync()
    {
        SelectedSchool = SchoolService.GetSelectedSchool();
        SubscribeToEvent(UiEvents.SchoolSelected);

        if (SelectedSchool != null)
        {
            await LoadFilters();

            if (!string.IsNullOrWhiteSpace(gradeId) && !string.IsNullOrWhiteSpace(subjectId))
            {
                await LoadResults(null!);
            }
            else
            {
                Loading = false;
            }
        }
        else
        {
            Loading = false;
        }
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        if (eventName == UiEvents.SchoolSelected)
        {
            if (payload is School school)
            {
                SelectedSchool = school;
                await LoadFilters();
                await InvokeAsync(StateHasChanged);
            }
        }

        await base.HandleEventAsync(eventName, payload);
    }

    private void SetViewMode(string mode)
    {
        ViewMode = mode;
        StateHasChanged();
    }

    private async Task LoadFilters()
    {
        try
        {
            if (SelectedSchool != null)
            {
                SchoolGrades = await SchoolGradeService.GetGradesForSchool(SelectedSchool.Id);
                Teachers = await UserService.GetAllByRoleAndSchoolAsync([Roles.Teacher], SelectedSchool.Id);
            }
            else
            {
                Logger.LogWarning("Selected School was null when trying to load grades.");
            }
            Subjects = await SubjectService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load filters.");
        }
    }

    private async Task<GridDataProviderResult<Result>> LoadResults(GridDataProviderRequest<Result> request)
    {
        try
        {
            Loading = true;

            if (Results is null || !Results.Any())
            {
                if (SelectedSchool == null)
                {
                    Logger.LogWarning("SelectedSchool is null. Cannot load results.");
                    return new GridDataProviderResult<Result>
                    {
                        Data = new List<Result>(),
                        TotalCount = 0
                    };
                }

                if (Guid.TryParse(gradeId, out var parsedGradeId) &&
                int.TryParse(subjectId, out var parsedSubjectId))
                {
                    Results = await ResultService.GetResultsByFiltersAsync(
                    SelectedSchool.Id,
                    parsedGradeId,
                    parsedSubjectId
                    );
                }
                else
                {
                    Logger.LogWarning("Invalid gradeId or subjectId. Cannot load results.");
                    Results = new List<Result>();
                }
            }

            if (request == null)
            {
                return new GridDataProviderResult<Result>
                {
                    Data = Results,
                    TotalCount = Results.Count
                };
            }

            return request.ApplyTo(Results);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load results.");
            return new GridDataProviderResult<Result>
            {
                Data = new List<Result>(),
                TotalCount = 0
            };
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task OnGradeChange(string value)
    {
        gradeId = value;
        await UpdateQueryParameters();
    }

    private async Task OnSubjectChange(string value)
    {
        subjectId = value;
        await UpdateQueryParameters();
    }

    private async Task OnTeacherChange(string value)
    {
        teacherId = value;
        await UpdateQueryParameters();
    }

    private async Task UpdateQueryParameters()
    {
        var uri = new Uri(Navigation.Uri);
        var queryParams = new Dictionary<string, string?>
        {
            ["g"] = gradeId,
            ["s"] = subjectId,
            ["t"] = teacherId
        };

        var newUri = QueryHelpers.AddQueryString(uri.AbsolutePath, queryParams);
        Navigation.NavigateTo(newUri);

        // Force the grid to reload data
        // If your library has a built-in method to refresh the data, call that.
        await LoadResults(null!);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (SelectedSchool == null)
        {
            Loading = false;
            return;
        }

        await LoadFilters();

        if (!string.IsNullOrWhiteSpace(gradeId) && !string.IsNullOrWhiteSpace(subjectId))
        {
            await LoadResults(null!);
        }
        else
        {
            Loading = false;
        }
    }

    private void EditResult(Guid resultId)
    {
        Navigation.NavigateTo($"results/edit/{resultId}");
    }
}
