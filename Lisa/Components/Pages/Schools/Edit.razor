@page "/schools/edit/{Id:guid}"
@using Lisa.Data
@using Lisa.Services
@inject SchoolService SchoolService
@inject NavigationManager NavigationManager

<PageTitle>Edit School</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <h3>Edit School</h3>

        @if (IsLoading)
        {
            <p>Loading...</p>
        }
        else if (school == null)
        {
            <p>School not found.</p>
        }
        else
        {
            <EditForm Context="editContext" Model="school" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label for="shortName">Short Name</label>
                    <InputText id="shortName" class="form-control" @bind-Value="school.ShortName" />
                </div>

                <div class="form-group">
                    <label for="longName">Long Name</label>
                    <InputText id="longName" class="form-control" @bind-Value="school.LongName" />
                </div>

                <div class="form-group">
                    <label for="color">Color</label>
                    <InputText id="color" class="form-control" @bind-Value="school.Color" />
                </div>

                <div class="form-group">
                    <label for="schoolType">School Type</label>
                    <InputSelect id="schoolType" class="form-control" @bind-Value="school.SchoolTypeId">
                        <option value="">Select School Type</option>
                        @foreach (var type in SchoolTypes)
                        {
                            <option value="@type.Id">@type.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label for="curriculum">Curriculum</label>
                    <InputSelect id="curriculum" class="form-control" @bind-Value="school.SchoolCurriculumId">
                        <option value="">Select Curriculum</option>
                        @foreach (var curriculum in Curriculums)
                        {
                            <option value="@curriculum.Id">@curriculum.Name</option>
                        }
                    </InputSelect>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </EditForm>
        }
    </Authorized>
    <NotAuthorized>
        <h3>You are not authorized to access this page.</h3>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public Guid Id { get; set; }
    private School? school { get; set; }
    private List<SchoolType> SchoolTypes = new();
    private List<SchoolCurriculum> Curriculums = new();
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        try
        {
            // Load dropdown data
            SchoolTypes = await SchoolService.GetSchoolTypesAsync();
            Curriculums = await SchoolService.GetSchoolCurriculumsAsync();

            // Load the school details
            school = await SchoolService.GetSchoolAsync(Id);
            if (school == null)
            {
                // Navigate back if school is not found
                NavigationManager.NavigateTo("/schools");
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading school: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            await SchoolService.UpdateSchoolAsync(school!);            
            NavigationManager.NavigateTo("/schools");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error saving school: {ex.Message}");
        }
    }

    private void Cancel()
    {
        // Navigate back to the list of schools
        NavigationManager.NavigateTo("/schools");
    }
}
