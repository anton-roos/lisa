@page "/schools/add"
@using Lisa.Events
@using Lisa.Services
@using Microsoft.EntityFrameworkCore
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SchoolService SchoolService
@inject IEventBus EventBus

<AuthorizeView Context="authContext">
    <Authorized>
        <h3>Add School</h3>

        <SchoolForm School="@School" SchoolTypes="@SchoolTypes" Curriculums="@Curriculums"
            OnValidSubmitCallback="@HandleValidSubmit" OnCancelCallback="@Cancel" />
    </Authorized>
    <NotAuthorized>
        <h3>You are not authorized to access this page.</h3>
    </NotAuthorized>
</AuthorizeView>

@code {
    private School School = new();
    private List<SchoolType> SchoolTypes = new();
    private List<SchoolCurriculum> Curriculums = new();

    protected override async Task OnInitializedAsync()
    {
        SchoolTypes = await SchoolService.GetSchoolTypesAsync();
        Curriculums = await SchoolService.GetSchoolCurriculumsAsync();
        School.SmtpPort = 587;
        School.SmtpHost = "smtp.office365.com";
    }

    private async Task HandleValidSubmit()
    {
        EventBus.Publish(new AddSchoolEvent { School = School });
        await SchoolService.AddSchoolAsync(School);
        Navigation.NavigateTo("/schools");
    }

    private void Cancel()
    {
        // Navigate back to the list of schools
        Navigation.NavigateTo("/schools");
    }
}
