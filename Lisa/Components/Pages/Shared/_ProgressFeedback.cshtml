@using Lisa.Models.ViewModels
@model ProgressFeedbackViewModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <title>Progress Feedback</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        .container {
            width: 100%;
            padding-right: 1rem;
            padding-left: 1rem;
            margin-right: auto;
            margin-left: auto;
        }
        .mt-4 {
            margin-top: 1.5rem !important;
        }
        .mb-4 {
            margin-bottom: 1.5rem !important;
        }
        .shadow-sm {
            box-shadow: 0 .125rem .25rem rgba(0,0,0,.075) !important;
        }
        .card {
            position: relative;
            display: flex;
            flex-direction: column;
            min-width: 0;
            word-wrap: break-word;
            background-color: #fff;
            background-clip: border-box;
            border: 1px solid rgba(0,0,0,.125);
            border-radius: .25rem;
        }
        .card-header {
            padding: .5rem 1rem;
            margin-bottom: 0;
            background-color: rgba(0,0,0,.03);
            border-bottom: 1px solid rgba(0,0,0,.125);
        }
        .card-body {
            flex: 1 1 auto;
            padding: 1rem;
        }
        .table {
            width: 100%;
            margin-bottom: 1rem;
            color: #212529;
            border-collapse: collapse;
        }
        .table th,
        .table td {
            padding: .75rem;
            vertical-align: top;
            border-top: 1px solid #dee2e6;
        }
        .table-striped tbody tr:nth-of-type(odd) {
            background-color: rgba(0,0,0,.05);
        }
        .text-center {
            text-align: center !important;
        }
        .text-success {
            color: #198754 !important;
        }
        .text-danger {
            color: #dc3545 !important;
        }
        .text-warning {
            color: #ffc107 !important;
        }
        .fw-bold {
            font-weight: 700 !important;
        }
        .alert {
            position: relative;
            padding: .75rem 1.25rem;
            margin-bottom: 1rem;
            border: 1px solid transparent;
            border-radius: .25rem;
        }
        .alert-warning {
            color: #856404;
            background-color: #fff3cd;
            border-color: #ffeeba;
        }
    </style>
</head>
<body>
    <div class="container mt-4" style="max-width: 600px; margin: auto;">
        <h3>Progress Feedback</h3>
        <p>Dear Parent of <strong>@Model?.Feedback?.LearnerName</strong></p>
        <p>Please find below the progress feedback on the tests or assignments your child has completed, expressed as percentages out of 100.</p>
        <p>Kindly note that this is not a formal report card but rather a reflection of all assessments conducted throughout the term.</p>
        <p>
            Regards,<br />
            @foreach (var principal in Model?.Principals!)
            {
                @principal.Name @principal.Surname<br />
            }
            Principal
        </p>

        @if (Model?.Feedback?.ResultsBySubject != null && Model.Feedback.ResultsBySubject.Any(x => x.Value != null && x.Value.Any()))
        {
            foreach (var subjectGroup in Model.Feedback.ResultsBySubject.Where(x => x.Value != null && x.Value.Any()))
            {
                <div class="card mb-4 shadow-sm">
                    <div class="card-header">
                        <h4 class="mb-0">@subjectGroup.Key</h4>
                    </div>
                    <div class="card-body">
                        <table class="table table-striped text-center">
                            <thead class="table">
                                <tr>
                                    @for (int i = 0; i < 3; i++)
                                    {
                                        <th>Date</th>
                                        <th>Mark</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int totalResults = Math.Min(subjectGroup.Value.Count, 6);
                                    int rows = (int)Math.Ceiling(totalResults / 3.0);
                                }
                                @for (int row = 0; row < rows; row++)
                                {
                                    <tr>
                                        @for (int col = 0; col < 3; col++)
                                        {
                                            int index = row * 3 + col;
                                            if (index < totalResults)
                                            {
                                                var result = subjectGroup.Value[index];
                                                string markClass = !result.Score.HasValue 
                                                    ? "text-warning fw-bold"
                                                    : (result.Score.Value < 50 
                                                        ? "text-danger fw-bold" 
                                                        : "text-success fw-bold");

                                                <td>@result.ResultSet?.AssessmentDate!.Value.ToString("MM/dd")</td>
                                                <td class="@markClass">@(result.Score.HasValue ? result.Score.Value + "%" : "Absent")</td>
                                            }
                                            else
                                            {
                                                <td>&nbsp;</td>
                                                <td>&nbsp;</td>
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="alert alert-warning text-center">No results available for this student.</p>
        }
    </div>
</body>
</html>
