@page "/subject-combination/add"
@using Lisa.Models.ViewModels
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SubjectCombinationService SubjectCombinationService
@inject SubjectService SubjectService
@inject SchoolService SchoolService

<h3>Add Subject Combination</h3>

<EditForm Context="edit" Model="@NewCombination" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Combination Name -->
    <div class="mb-3">
        <label class="form-label">Name</label>
        <InputText class="form-control" @bind-Value="NewCombination.Name" />
    </div>

    <!-- Grade Dropdown -->
    <div class="mb-3">
        <label class="form-label">Grade</label>
        <select class="form-select" @bind="NewCombination.GradeId">
            <option value="">-- Select Grade --</option>
            @foreach (var grade in Grades)
            {
                <option value="@grade.Id">@grade.Name</option>
            }
        </select>
    </div>

    <!-- Subjects Multi-Select -->
    <div class="mb-3">
        <label class="form-label">Subjects</label>
        <select multiple class="form-select" @onchange="HandleSubjectSelection">
            @foreach (var subject in AllSubjects)
            {
                <option value="@subject.Id"
                        selected="@NewCombination.SubjectIds.Contains(subject.Id)">
                    @subject.Name
                </option>
            }
        </select>
        <small>Select one or more subjects (Ctrl+Click or Cmd+Click)</small>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
</EditForm>

@code {
    private SubjectCombinationViewModel NewCombination = new();
    private List<Grade> Grades = new();
    private List<Subject> AllSubjects = new();
    private School SelectedSchool = new();

    protected override async Task OnInitializedAsync()
    {
        SelectedSchool = SchoolService.SelectedSchool;
        AllSubjects = await SubjectService.GetAllAsync();
        Grades = await SchoolService.GetGradesForSchool(SelectedSchool.Id);
    }

    private async Task HandleValidSubmit()
    {
        // Build the entity from the ViewModel
        var entity = new SubjectCombination
        {
            Id = Guid.NewGuid(),
            Name = NewCombination.Name,
            GradeId = NewCombination.GradeId
        };

        // Pass in the chosen subject IDs for linking
        await SubjectCombinationService.CreateAsync(entity, NewCombination.SubjectIds);

        Navigation.NavigateTo("/subject-combination");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/subject-combination");
    }

    private void HandleSubjectSelection(ChangeEventArgs e)
    {
        // Because it's a multiple-select, e.Value can be a string[] of selected values
        if (e.Value is string[] selectedValues)
        {
            NewCombination.SubjectIds = selectedValues
                .Select(val => Guid.Parse(val))
                .ToList();
        }
    }
}
