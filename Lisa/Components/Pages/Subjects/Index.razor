@page "/subjects"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SubjectService SubjectService

<h1>Subjects</h1>

<div class="alert alert-info" role="alert">
    Subjects are shared across schools.
</div>

<div class="mb-3">
    <label class="form-label">Search Subjects</label>
    <InputText class="form-control"
               @bind-Value="searchText"
               oninput="@OnInputChange"
               placeholder="Type to filter subjects..." />
</div>

<button class="btn btn-primary" @onclick="AddSubject">Add Subject</button>

<hr />

@if (subjects == null)
{
    <p>Loading subjects...</p>
}
else if (!FilteredSubjects.Any())
{
    <p>No subjects found matching your search.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Code</th>
                <th>Description</th>
                <th style="width:150px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var subject in FilteredSubjects)
            {
                <tr>
                    <td>@subject.Name</td>
                    <td>@subject.Code</td>
                    <td>@subject.Description</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="() => EditSubject(subject.Id)">
                            Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Subject>? subjects;
    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Load subjects from your service
        subjects = await SubjectService.GetAllAsync();
        subjects = subjects.OrderBy(s => s.Name).ToList();
    }

    // Computed property returning only subjects that match the search
    private IEnumerable<Subject> FilteredSubjects
        => subjects != null
            ? subjects.Where(s =>
                string.IsNullOrWhiteSpace(searchText)
                || (s.Name != null && s.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                || (s.Code != null && s.Code.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                || (s.Description != null && s.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            )
            : Enumerable.Empty<Subject>();

    private void AddSubject()
    {
        Navigation.NavigateTo("/subjects/add");
    }

    private void EditSubject(Guid subjectId)
    {
        Navigation.NavigateTo($"/subjects/edit/{subjectId}");
    }

    private void OnInputChange(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
    }
}
