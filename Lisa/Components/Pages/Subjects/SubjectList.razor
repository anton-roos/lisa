@page "/subjects"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SubjectService SubjectService

<AuthorizeView Context="authContext" Roles="@Roles.SystemAdministrator">
    <Authorized>
        <h3>Subjects</h3>

        <button class="btn btn-primary mb-3" @onclick="AddSubject">Add Subject</button>

        <div class="alert alert-info" role="alert">
            Subjects are shared across schools.
        </div>

        <div class="mb-3">
            <label class="form-label">Search Subjects</label>
            <InputText class="form-control" @bind-Value="searchText" @oninput="OnInputChange"
                placeholder="Type to filter subjects..." />
        </div>

        <hr />

        @if (subjects == null)
        {
            <p>Loading subjects...</p>
        }
        else if (!FilteredSubjects.Any())
        {
            <p>No subjects found matching your search.</p>
        }
        else
        {
            <div class="list-group">
                @foreach (var subject in FilteredSubjects)
                {
                    <div class="list-group-item">
                        <div class="row align-items-center">
                            <div class="col-md-3 col-12 mb-2 mb-md-0">
                                <strong>@subject.Name</strong>
                            </div>
                            <div class="col-md-2 col-12 mb-2 mb-md-0">
                                @subject.Code
                            </div>
                            <div class="col-md-2 col-12 mb-2 mb-md-0">
                                <div class="d-flex flex-wrap gap-2">
                                    <Pill Color="info">
                                        @GetFirstAndLastGrade(subject)
                                    </Pill>
                                    <Pill Color="@GetPillColorForSubjectType(subject.SubjectType)">
                                        @GetPillTextForSubjectType(subject.SubjectType)
                                    </Pill>
                                </div>
                            </div>
                            <div class="col-md-4 col-12 d-flex justify-content-md-end justify-content-start">
                                <ActionButtons TEntity="Subject" Entity="subject" OnView="ViewSubject" OnEdit="EditSubject"
                                    OnDelete="DeleteSubject" />
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <Unauthorized />
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Subject>? subjects;
    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        subjects = await SubjectService.GetAllAsync();
        subjects = subjects.OrderBy(s => s.Name).ToList();
    }

    private IEnumerable<Subject> FilteredSubjects
    => subjects != null
    ? subjects
    .Where(s =>
    string.IsNullOrWhiteSpace(searchText)
    || (s.Name != null && s.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase))
    || (s.Code != null && s.Code.Contains(searchText, StringComparison.OrdinalIgnoreCase))
    || (s.Description != null && s.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase))
    )
    .OrderBy(s => s.Order)
    : Enumerable.Empty<Subject>();

    private void AddSubject()
    {
        Navigation.NavigateTo("/subjects/add");
    }

    private void ViewSubject(Subject subject)
    {
        Navigation.NavigateTo($"/subjects/details/{subject.Id}");
    }

    private void EditSubject(Subject subject)
    {
        Navigation.NavigateTo($"/subjects/edit/{subject.Id}");
    }

    private async Task DeleteSubject(Subject subject)
    {
        if (subject != null)
        {
            await SubjectService.DeleteAsync(subject.Id);
            subjects = await SubjectService.GetAllAsync();
            subjects = subjects.OrderBy(s => s.Name).ToList();
        }
    }

    private void OnInputChange(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
    }

    private string GetPillColorForSubjectType(SubjectType subjectType)
    {
        return subjectType switch
        {
            SubjectType.Compulsory => "primary",
            SubjectType.Combination => "danger",
            SubjectType.MathCombination => "success",
            _ => ""
        };
    }

    private string GetPillTextForSubjectType(SubjectType subjectType)
    {
        return subjectType switch
        {
            SubjectType.Compulsory => "Compulsory",
            SubjectType.Combination => "Combination",
            SubjectType.MathCombination => "Math",
            _ => ""
        };
    }

    /// <summary>
    /// Returns a string displaying the first and last grade in the sequence.
    /// If the first and last are the same, only a single value is returned.
    /// </summary>
    /// <param name="subject">The subject containing the applicable grades.</param>
    /// <returns>A formatted string with the first and last grade, or an empty string if none exist.</returns>
    private string GetFirstAndLastGrade(Subject subject)
    {
        if (subject?.GradesApplicable == null || !subject.GradesApplicable.Any())
        {
            return string.Empty;
        }

        // Assume that GradesApplicable is already ordered.
        int firstGrade = subject.GradesApplicable.First();
        int lastGrade = subject.GradesApplicable.Last();

        string firstGradeName = GetGradeName(firstGrade);
        string lastGradeName = GetGradeName(lastGrade);

        return firstGrade == lastGrade
        ? $"Gr {firstGradeName}"
        : $"Gr {firstGradeName} - {lastGradeName}";
    }

    private string GetGradeName(int grade) =>
    grade switch
    {
        -2 => "RRR",
        -1 => "RR",
        0 => "R",
        _ => grade.ToString()
    };
}
