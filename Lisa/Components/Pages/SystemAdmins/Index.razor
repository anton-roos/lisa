@page "/system-administrators"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SchoolService SchoolService
@inject UserService UserService

<h3>System Administrators</h3>
<button class="btn btn-primary" @onclick="GoToAddSysAdmin">
    Add System Administrator
</button>

@if (UsersInRole == null)
{
    <p>Loading...</p>
}
else if (UsersInRole.Count == 0)
{
    <p>No System Administrators found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in UsersInRole)
            {
                <tr>
                    <td>@($"{user.FirstName ?? "Unknown"} {user.LastName}")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<User> UsersInRole = new();

    protected override async Task OnInitializedAsync()
    {
        UsersInRole = await UserService.GetUsersByRoleAndSchoolAsync(Roles.SystemAdministrator);
    }

    private void GoToAddSysAdmin()
    {
        Navigation.NavigateTo("/system-administrators/add");
    }
}
