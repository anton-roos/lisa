@page "/system-administrators"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SchoolService SchoolService

<h3>System Administrators</h3>

@if (CurrentSchool == null)
{
    <div class="alert alert-info">
        The concept of a "System Administrator" may not be tied to a school. 
        But if you do link them to a school, you can display them here.
    </div>
}
else if (UsersInRole == null)
{
    <p>Loading...</p>
}
else if (UsersInRole.Count == 0)
{
    <p>No System Administrators found for @CurrentSchool.ShortName (@CurrentSchool.ShortName).</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>School</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in UsersInRole)
            {
                <tr>
                    <td>@($"{user.FirstName} {user.LastName}")</td>
                    <td>@CurrentSchool.ShortName</td>
                </tr>
            }
        </tbody>
    </table>
}

<button class="btn btn-success" @onclick="GoToAddSysAdmin" disabled="@IsSchoolNotSelected">
    Add System Administrator
</button>

@code {
    private School? CurrentSchool;
    private List<User> UsersInRole = new();
    private bool IsSchoolNotSelected => CurrentSchool == null || CurrentSchool.Id == Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        SchoolService.SchoolSelected += HandleSchoolChange;
        CurrentSchool = SchoolService.SelectedSchool;

        if (CurrentSchool != null)
        {
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        UsersInRole = await SchoolService.GetUsersByRoleAndSchoolAsync(Roles.SystemAdministrator, CurrentSchool.Id);
    }

    private void HandleSchoolChange()
    {
        CurrentSchool = SchoolService.SelectedSchool;
        InvokeAsync(async () =>
        {
            if (CurrentSchool != null)
            {
                await LoadUsers();
            }
            StateHasChanged();
        });
    }

    private void GoToAddSysAdmin()
    {
        Navigation.NavigateTo("/system-administrators/add");
    }
}
