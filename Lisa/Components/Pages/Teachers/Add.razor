@page "/teachers/add/"
@using Lisa.Models.ViewModels
@using Microsoft.AspNetCore.Authorization
@using Lisa.Models.Entities
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Navigation
@inject UserManager<User> UserManager
@inject SchoolService SchoolService

<AuthorizeView Context="authContext" Roles="@($"{Roles.SystemAdministrator},{Roles.Teacher}")">
    <Authorized>
        <h3>Add Teacher</h3>

        <EditForm Context="editContext" Model="Teacher" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label for="firstName">First Name</label>
                <InputText id="firstName" class="form-control" @bind-Value="Teacher.FirstName" />
            </div>

            <div class="form-group">
                <label for="lastName">Last Name</label>
                <InputText id="lastName" class="form-control" @bind-Value="Teacher.LastName" />
            </div>

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="Teacher.Email" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="Teacher.Email" />
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </EditForm>
    </Authorized>
    <NotAuthorized>
        <h3>You are not authorized to access this page.</h3>
    </NotAuthorized>
</AuthorizeView>

@code {
    private TeacherViewModel Teacher { get; set; } = new();
    private School SelectedSchool { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        SchoolService.SchoolSelected += HandleSchoolChanged;
        SelectedSchool = SchoolService.SelectedSchool;
    }


    private void HandleSchoolChanged()
    {
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            var TeacherModel = new Teacher
                {
                    FirstName = Teacher.FirstName,
                    Email = Teacher.Email,
                    LastName = Teacher.LastName,
                    SchoolId = SelectedSchool.Id
                };
            UserManager.CreateAsync(TeacherModel, Teacher.Password);

            Navigation.NavigateTo("/teachers");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private void Cancel()
    {
        // Navigate back to the previous page or a teachers list
        Navigation.NavigateTo("/teachers");
    }
}