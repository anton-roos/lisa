@page "/teachers/details/{Id:guid}"
@using Lisa.Models.Entities
@using Microsoft.AspNetCore.Components
@inject NavigationManager Navigation
@inject UserService UserService

<h3>Teacher Details</h3>

@if (teacher == null)
{
    <p>Loading teacher...</p>
}
else
{
    <dl class="row">
        <dt class="col-sm-2">Surname</dt>
        <dd class="col-sm-10">@teacher.Surname</dd>

        <dt class="col-sm-2">Abbreviation</dt>
        <dd class="col-sm-10">@teacher.Abbreviation</dd>

        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@teacher.Name</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@teacher.Email</dd>

        <dt class="col-sm-2">Care Groups</dt>
        <dd class="col-sm-10">
            <ul>
                @if (teacher.CareGroups == null || !teacher.CareGroups.Any())
                {
                    <li>No care groups assigned.</li>
                }
                else
                {
                    @foreach (var CareGroup in teacher.CareGroups)
                    {
                        <li>@CareGroup.Name</li>
                    }
                }
            </ul>
        </dd>

        <dt class="col-sm-2">Username</dt>
        <dd class="col-sm-10">@teacher.UserName</dd>
    </dl>

    <h4>School</h4>
    @if (teacher.School == null)
    {
        <p>No school assigned.</p>
    }
    else
    {
        <p>@teacher.School.ShortName</p>
    }

    <h4>Subjects</h4>
    @if (teacher.Subjects == null || !teacher.Subjects.Any())
    {
        <p>No subjects assigned.</p>
    }
    else
    {
        <ul>
            @foreach (var subject in teacher.Subjects)
            {
                <li>@subject.Name</li>
            }
        </ul>
    }

    <h4>Register Classes</h4>
    @if (teacher.RegisterClasses == null || !teacher.RegisterClasses.Any())
    {
        <p>No register classes.</p>
    }
    else
    {
        <ul>
            @foreach (var rc in teacher.RegisterClasses)
            {
                <li>@rc.Name (Grade: @rc.SchoolGrade?.SystemGrade.Name)</li>
            }
        </ul>
    }

    <h4>Periods</h4>
    @if (teacher.Periods == null || !teacher.Periods.Any())
    {
        <p>No periods assigned.</p>
    }
    else
    {
        <ul>
            @foreach (var period in teacher.Periods)
            {
                <li>@($"{period.StartTime} - {period.EndTime}")</li>
            }
        </ul>
    }

    <button class="btn btn-secondary" @onclick="GoBack">Back</button>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Teacher? teacher;

    protected override async Task OnInitializedAsync()
    {
        teacher = await UserService.GetByIdAsync(Id);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/teachers");
    }
}
