@page "/teachers/manage/{Id:guid?}"
@using Lisa.Models.Entities
@using Lisa.Models.ViewModels
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager Navigation
@inject UserService UserService
@inject TeacherService TeacherService
@inject SchoolService SchoolService
@inject CareGroupService CareGroupService
@inject ILogger<TeacherManager> Logger
@inherits EventAwareComponentBase

<AuthorizeView Context="AuthContext" Roles="@($"{Roles.SystemAdministrator}")">
    <Authorized>
        <h3>@(IsEdit ? "Edit Teacher" : "Add Teacher")</h3>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class='alert alert-danger'>@ErrorMessage</div>
        }

        @if (IsLoading)
        {
            <p>Loading teacher...</p>
        }
        else
        {
            <EditForm Model="@TeacherViewModel" OnValidSubmit="@HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="surname" class="form-label">Surname</label>
                    <InputText id="surname" class="form-control" @bind-Value="TeacherViewModel.Surname" />
                </div>

                <div class="mb-3">
                    <label for="abbreviation" class="form-label">Abbreviation</label>
                    <InputText id="abbreviation" class="form-control" @bind-Value="TeacherViewModel.Abbreviation" />
                </div>

                <div class="mb-3">
                    <label for="name" class="form-label">Name</label>
                    <InputText id="name" class="form-control" @bind-Value="TeacherViewModel.Name" />
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <InputText id="email" class="form-control" @bind-Value="TeacherViewModel.Email" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <InputText id="password" type="password" class="form-control" @bind-Value="TeacherViewModel.Password" />
                    @if (!IsEdit)
                    {
                        <small class="text-muted">Required for new teacher.</small>
                    }
                    else
                    {
                        <small class="text-muted">Leave blank to keep current password.</small>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Assign Care Groups</label>
                    <div>
                        @if (CareGroups == null || !CareGroups.Any())
                        {
                            <p>No care groups available to choose for this teacher.</p>
                        }
                        else
                        {
                            @foreach (var careGroup in CareGroups)
                            {
                                <div>
                                    <input class="form-check-input" type="checkbox"
                                        checked="@TeacherViewModel.SelectedCareGroupIds.Contains(careGroup.Id)"
                                        @onchange="@(() => ToggleCareGroup(careGroup.Id))" />
                                    <label>@careGroup.Name</label>
                                </div>
                            }
                        }
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    @(IsEdit ? "Save Changes" : "Add Teacher")
                </button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </EditForm>
        }
    </Authorized>
    <NotAuthorized>
        <h4>You are not authorized to access this page.</h4>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsEdit => Id.HasValue && Id.Value != Guid.Empty;
    private bool IsLoading { get; set; } = true;
    private TeacherViewModel TeacherViewModel { get; set; } = new();
    private string ErrorMessage { get; set; } = string.Empty;
    private School? SelectedSchool { get; set; }
    private IEnumerable<CareGroup>? CareGroups { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            SubscribeToEvent(UiEvents.SchoolSelected);

            SelectedSchool = SchoolService.GetSelectedSchool();
            if (SelectedSchool != null)
            {
                CareGroups = await CareGroupService.GetBySchoolAsync(SelectedSchool.Id);
            }

            if (IsEdit && Id != null)
            {
                var teacherEntity = await TeacherService.GetByIdAsync(Id.Value);
                if (teacherEntity == null)
                {
                    Navigation.NavigateTo("/teachers");
                    return;
                }

                TeacherViewModel = new TeacherViewModel
                    {
                        Id = teacherEntity.Id,
                        Surname = teacherEntity.Surname,
                        Abbreviation = teacherEntity.Abbreviation,
                        Name = teacherEntity.Name,
                        Email = teacherEntity.Email,
                        SchoolId = teacherEntity.SchoolId,
                        SelectedCareGroupIds = teacherEntity.CareGroups.Select(cg => cg.Id).ToList()
                    };
            }
            else if (SelectedSchool != null)
            {
                TeacherViewModel.SchoolId = SelectedSchool.Id;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
            Logger.LogError("Error calling OnInitializedAsync on Teacher Management Page: {ex}", ex);
        }
        finally
        {
            IsLoading = false;
        }
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                if (payload is School school)
                {
                    SelectedSchool = school;
                    if (!IsEdit)
                    {
                        TeacherViewModel.SchoolId = school.Id;
                    }
                }
                break;
        }

        await base.HandleEventAsync(eventName, payload);
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (!IsEdit)
            {
                if (string.IsNullOrWhiteSpace(TeacherViewModel.Password))
                    throw new Exception("Password is required for new teacher.");

                await TeacherService.CreateAsync(TeacherViewModel);
            }
            else
            {
                var teacherEntity = await TeacherService.GetByIdAsync(TeacherViewModel.Id);
                if (teacherEntity is null)
                    throw new Exception("Teacher not found.");

                await TeacherService.UpdateAsync(
                teacherEntity,
                TeacherViewModel.SelectedCareGroupIds,
                string.IsNullOrWhiteSpace(TeacherViewModel.Password) ? null : TeacherViewModel.Password
                );
            }

            Navigation.NavigateTo("/teachers");
        }
        catch (Exception ex)
        {
            ErrorMessage = "Error: " + ex.Message;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/teachers");
    }

    private void ToggleCareGroup(Guid careGroupId)
    {
        if (!TeacherViewModel.SelectedCareGroupIds.Remove(careGroupId))
        {
            TeacherViewModel.SelectedCareGroupIds.Add(careGroupId);
        }
    }
}
