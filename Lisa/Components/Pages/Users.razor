@page "/users"
@using Microsoft.AspNetCore.Identity
@using System.ComponentModel.DataAnnotations
@inject UserManager<User> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager NavigationManager

<h3>User Management</h3>

<div>
    <button class="btn btn-primary" @onclick="ShowAddUserForm">Add User</button>
</div>

@if (showAddUserForm)
{
    <EditForm Context="editContext" Model="@newUser" OnValidSubmit="HandleAddUser">

        <div>
            <label for="email">Email</label>
            <InputText id="email" @bind-Value="newUser.Email" class="form-control" />
            <ValidationMessage For="@(() => newUser.Email)" />
        </div>

        <div>
            <label for="password">Password</label>
            <InputText id="password" @bind-Value="newUser.Password" type="password" class="form-control" />
            <ValidationMessage For="@(() => newUser.Password)" />
        </div>

        <button type="submit" class="btn btn-primary">Add User</button>
        <button type="button" class="btn btn-secondary" @onclick="HideAddUserForm">Cancel</button>
    </EditForm>
}

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Roles</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in users)
        {
            <tr>
                <td>@user.Email</td>
                <td>@string.Join(", ", user.Roles)</td>
                <td>
                    <button class="btn btn-primary" @onclick="() => ShowEditUserForm(user)">Edit</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (showEditUserForm)
{
    <EditForm Context="editContext" Model="@editUser" OnValidSubmit="HandleEditUser">

        <div>
            <label for="email">Email</label>
            <InputText id="email" @bind-Value="editUser.Email" class="form-control" />
        </div>

        <div>
            <label for="roles">Roles</label>
            <InputSelect id="roles" @bind-Value="selectedRole">
                @foreach (var role in roles)
                {
                    <option value="@role">@role</option>
                }
            </InputSelect>
            <button type="button" @onclick="AddRoleToUser">Add Role</button>
        </div>

        <button type="submit" class="btn btn-primary">Save Changes</button>
        <button type="button" class="btn btn-secondary" @onclick="HideEditUserForm">Cancel</button>
    </EditForm>
}

@code {
    private List<UserModel> users = new();
    private List<string?> roles = new();
    private UserModel newUser = new();
    private UserModel editUser = new();
    private string? selectedRole;
    private bool showAddUserForm = false;
    private bool showEditUserForm = false;

    protected override async Task OnInitializedAsync()
    {
        roles = LoadRoles();
        users = await LoadUsers();
    }

    private async Task<List<UserModel>> LoadUsers()
    {
        var userList = new List<UserModel>();
        var userEntities = UserManager.Users.ToList();
        foreach (var user in userEntities)
        {
            var userModel = new UserModel
            {
                Id = user.Id.ToString(),
                Email = user.Email,
                Roles = await UserManager.GetRolesAsync(user)
            };
            userList.Add(userModel);
        }
        return userList;
    }

    private List<string?> LoadRoles()
    {
        return RoleManager.Roles.Select(r => r.Name).ToList();
    }

    private void ShowAddUserForm()
    {
        newUser = new UserModel();
        showAddUserForm = true;
    }

    private void HideAddUserForm()
    {
        showAddUserForm = false;
    }

    private async Task HandleAddUser()
    {
        var user = new User { UserName = newUser.Email, Email = newUser.Email };
        var result = await UserManager.CreateAsync(user, newUser.Password!);
        if (result.Succeeded)
        {
            users = await LoadUsers();
            showAddUserForm = false;
        }
        else
        {
            // Handle errors
        }
    }

    private void ShowEditUserForm(UserModel user)
    {
        editUser = user;
        showEditUserForm = true;
    }

    private void HideEditUserForm()
    {
        showEditUserForm = false;
    }

    private async Task HandleEditUser()
    {
        var user = await UserManager.FindByIdAsync(editUser.Id!);
        if (user != null)
        {
            user.Email = editUser.Email;
            user.UserName = editUser.Email;
            var result = await UserManager.UpdateAsync(user);
            if (result.Succeeded)
            {
                users = await LoadUsers();
                showEditUserForm = false;
            }
            else
            {
                // Handle errors
            }
        }
    }

    private async Task DeleteUser(string userId)
    {
        var user = await UserManager.FindByIdAsync(userId);
        if (user != null)
        {
            var result = await UserManager.DeleteAsync(user);
            if (result.Succeeded)
            {
                users = await LoadUsers();
            }
            else
            {
                // Handle errors
            }
        }
    }

    private async Task AddRoleToUser()
    {
        var user = await UserManager.FindByIdAsync(editUser.Id!);
        if (user != null && !string.IsNullOrEmpty(selectedRole))
        {
            var result = await UserManager.AddToRoleAsync(user, selectedRole);
            if (result.Succeeded)
            {
                editUser.Roles = await UserManager.GetRolesAsync(user);
            }
            else
            {
                // Handle errors
            }
        }
    }

    public class UserModel
    {
        public string? Id { get; set; }
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email address.")]
        public string? Email { get; set; }
        [Required(ErrorMessage = "Password is required.")]
        public string? Password { get; set; }
        public IList<string> Roles { get; set; } = new List<string>();
    }
}