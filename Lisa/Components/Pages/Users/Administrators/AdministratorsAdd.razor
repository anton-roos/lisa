@page "/administrators/add/"
@using Lisa.Models.ViewModels
@using Microsoft.AspNetCore.Authorization
@using Lisa.Models.Entities
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Navigation
@inject UserManager<User> UserManager
@inject SchoolService SchoolService
@inherits EventAwareComponentBase

<AuthorizeView Context="auth" Roles="@($"{Roles.SystemAdministrator},{Roles.Teacher}")">
    <Authorized>
        <h3>Add Administrator</h3>

        <EditForm Context="edit" Model="Administrator" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label for="firstName">First Name</label>
                <InputText id="firstName" class="form-control" @bind-Value="Administrator.FirstName" />
            </div>

            <div class="form-group">
                <label for="lastName">Last Name</label>
                <InputText id="lastName" class="form-control" @bind-Value="Administrator.LastName" />
            </div>

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="Administrator.Email" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="Administrator.Password" />
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
        </EditForm>
    </Authorized>
    <NotAuthorized>
        <h3>You are not authorized to access this page.</h3>
    </NotAuthorized>
</AuthorizeView>

@code {
    private AdministratorViewModel Administrator { get; set; } = new();
    private School? SelectedSchool;

    protected override async Task OnInitializedAsync()
    {
        SelectedSchool = SchoolService.GetSelectedSchool();
        SubscribeToEvent(UiEvents.SchoolSelected);
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            if (SelectedSchool == null)
            {
                throw new Exception("No Selected School while trying to add an Administrator.");
            }
            var userEntity = new Administrator
                {
                    FirstName = Administrator.FirstName,
                    LastName = Administrator.LastName,
                    Email = Administrator.Email,
                    UserName = Administrator.Email,
                    SchoolId = SelectedSchool.Id,
                };

            if (string.IsNullOrWhiteSpace(Administrator.Password))
            {
                throw new Exception("Password is required.");
            }
            
            var result = await UserManager.CreateAsync(userEntity, Administrator.Password);
            if (result.Succeeded)
            {
                await UserManager.AddToRoleAsync(userEntity, Roles.Administrator);
                Navigation.NavigateTo("/administrators");
            }
            else
            {
                // Handle errors
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }


    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        if (eventName == UiEvents.SchoolSelected)
        {
            SelectedSchool = payload as School;
        }
        await base.HandleEventAsync(eventName, payload);
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/administrators");
    }
}
