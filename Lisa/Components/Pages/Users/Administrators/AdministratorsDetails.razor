@page "/administrators/details/{Id:guid}"
@using Lisa.Models.Entities
@using Microsoft.AspNetCore.Components
@inject UserService UserService
@inject NavigationManager Navigation

<h3>Administrator Details</h3>

@if (administrator == null)
{
    <p>Loading administrator...</p>
}
else
{
    <dl class="row">
        <dt class="col-sm-2">Full Name</dt>
        <dd class="col-sm-10">@($"{administrator.FirstName} {administrator.LastName}")</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@administrator.Email</dd>

        <dt class="col-sm-2">Username</dt>
        <dd class="col-sm-10">@administrator.UserName</dd>
    </dl>

    <h4>School</h4>
    @if (administrator.School == null)
    {
        <p>No school assigned.</p>
    }
    else
    {
        <p>@administrator.School.ShortName</p>
    }

    <button class="btn btn-secondary" @onclick="GoBack">Back</button>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Administrator? administrator;

    protected override async Task OnInitializedAsync()
    {
        administrator = await UserService.GetByIdAsync<Administrator>(Id);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/administrators");
    }
}
