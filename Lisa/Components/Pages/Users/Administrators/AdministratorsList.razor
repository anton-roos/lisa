@page "/administrators"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SchoolService SchoolService
@inject UserService UserService
@inherits EventAwareComponentBase

<h3>Administrators</h3>
<button class="btn btn-primary mb-3" @onclick="GoToAddAdministrator" disabled="@(SelectedSchool == null)">
    Add Administrator
</button>

@if (SelectedSchool == null)
{
    <div class="alert alert-warning">
        No school selected. Please select a school first.
    </div>
}
else if (Administrators == null)
{
    <p>Loading...</p>
}
else if (Administrators.Count == 0)
{
    <p>No Administrators found for @SelectedSchool.ShortName.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>School</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var administrator in Administrators)
            {
                <tr>
                    <td>@($"{administrator.FirstName} {administrator.LastName}")</td>
                    <td>@SelectedSchool.ShortName</td>
                    <ActionButtons TEntity="Administrator" Entity="administrator" OnView="ViewAdministrator"
                        OnEdit="EditAdministrator" OnDelete="DeleteAdministrator" />
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private School? SelectedSchool;
    private List<Administrator> Administrators = new();

    protected override async Task OnInitializedAsync()
    {
        SelectedSchool = SchoolService.GetSelectedSchool();
        SubscribeToEvent(UiEvents.SchoolSelected);

        if (SelectedSchool != null)
        {
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        if (SelectedSchool == null)
        {
            throw new InvalidOperationException("No school selected.");
        }
        Administrators = await UserService.GetAllByRoleAndSchoolAsync<Administrator>(SelectedSchool.Id);
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        // Handle the events and update the state
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                SelectedSchool = payload as School;
                await LoadUsers();
                break;
        }

        // Ensure state change
        await base.HandleEventAsync(eventName, payload);
    }

    private void GoToAddAdministrator()
    {
        Navigation.NavigateTo("/administrators/add");
    }

    private void EditAdministrator(Administrator administrator)
    {
        Navigation.NavigateTo($"/administrators/edit/{administrator.Id}");
    }

    private void ViewAdministrator(Administrator administrator)
    {
        Navigation.NavigateTo($"/administrators/details/{administrator.Id}");
    }

    private async Task DeleteAdministrator(Administrator administrator)
    {
        var user = await UserService.GetByIdAsync<Administrator>(administrator.Id);
        if (user != null)
        {
            //await UserService.DeleteAsync(user);
            // delete logic
            await LoadUsers();
            StateHasChanged();
        }
    }
}
