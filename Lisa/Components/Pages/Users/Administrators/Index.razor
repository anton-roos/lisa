@page "/administrators"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SchoolService SchoolService
@inject UserService UserService
@inherits EventAwareComponentBase

<h3>Administrators</h3>
<button class="btn btn-success" @onclick="GoToAddAdministrator" disabled="@(SelectedSchool == null)">
    Add Administrator
</button>

@if (SelectedSchool == null)
{
    <div class="alert alert-warning">
        No school selected. Please select a school first.
    </div>
}
else if (UsersInRole == null)
{
    <p>Loading...</p>
}
else if (UsersInRole.Count == 0)
{
    <p>No Administrators found for @SelectedSchool.ShortName.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>School</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Administrators)
            {
                <tr>
                    <td>@($"{user.FirstName} {user.LastName}")</td>
                    <td>@SelectedSchool.ShortName</td>
                    <td>
                        <button class="btn btn-primary" @onclick="() => ViewAdministrator(user.Id)">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="btn btn-secondary" @onclick="() => EditAdministrator(user.Id)">
                            <i class="bi bi-pencil-fill"></i>
                        </button>
                        <button class="btn btn-danger"
                            @onclick="async () => { await DeleteAdministrator(user.Id); }">
                            <i class="bi bi-trash3-fill"></i></button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private School? SelectedSchool;
    private List<User> UsersInRole = new();
    private List<Administrator> Administrators = new();

    protected override async Task OnInitializedAsync()
    {
        SubscribeToEvent(UiEvents.SchoolSelected);
        SelectedSchool = SchoolService.GetSelectedSchool();

        if (SelectedSchool != null)
        {
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        UsersInRole = await UserService.GetUsersByRoleAndSchoolAsync(Roles.Administrator, SelectedSchool.Id);
        Administrators = UsersInRole.Select(u => (Administrator)u).ToList();
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        // Handle the events and update the state
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                // Cast Payload to a School
                SelectedSchool = payload as School;
                break;
        }

        // Ensure state change
        await base.HandleEventAsync(eventName, payload);
    }

    private void GoToAddAdministrator()
    {
        Navigation.NavigateTo("/administrators/add");
    }

    private void EditAdministrator(Guid id)
    {
        Navigation.NavigateTo($"/administrators/edit/{id}");
    }

    private void ViewAdministrator(Guid id)
    {
        Navigation.NavigateTo($"/administrators/details/{id}");
    }

    private async Task DeleteAdministrator(Guid id)
    {
        var user = await UserService.GetByIdAsync<Administrator>(id);
        if (user != null)
        {
            //await UserService.DeleteAsync(user);
            // delete logic
            await LoadUsers();
            StateHasChanged();
        }
    }
}
