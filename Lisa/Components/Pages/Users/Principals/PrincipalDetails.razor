@page "/principals/details/{Id:guid}"
@using Lisa.Models.Entities
@inject UserService UserService

<h3>Principal Details</h3>

@if (Principal == null)
{
    <p>Loading principal...</p>
}
else
{
    <dl class="row">
        <dt class="col-sm-2">Surname</dt>
        <dd class="col-sm-10">@Principal.Surname</dd>

        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Principal.Name</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Principal.Email</dd>

        <dt class="col-sm-2">Username</dt>
        <dd class="col-sm-10">@Principal.UserName</dd>

        <dt class="col-sm-2">School</dt>
        <dd class="col-sm-10">@Principal.School?.ShortName</dd>
    </dl>
}


@code {
    [Parameter]
    public Guid Id { get; set; }
    private Principal? Principal;
    protected override async Task OnInitializedAsync()
    {
        Principal = await UserService.GetByIdAsync<Principal>(Id);
    }
}
