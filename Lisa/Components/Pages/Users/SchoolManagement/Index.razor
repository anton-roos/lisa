@page "/school-management"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SchoolService SchoolService
@inject UserService UserService
@inherits EventAwareComponentBase

<h3>School Management</h3>
<button class="btn btn-primary" @onclick="AddSchoolManagement" disabled="@(SelectedSchool == null)">
    Add School Management
</button>
@if (SelectedSchool == null)
{
    <div class="alert alert-warning">
        No school selected. Please select a school first.
    </div>
}
else if (SchoolManagements == null)
{
    <p>Loading...</p>
}
else if (SchoolManagements.Count == 0)
{
    <p>No School Management users found for @SelectedSchool.ShortName (@SelectedSchool.ShortName).</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>School</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var schoolManagement in SchoolManagements)
            {
                <tr>
                    <td>@($"{schoolManagement.FirstName} {schoolManagement.LastName}")</td>
                    <td>@SelectedSchool.ShortName</td>
                    <ActionButtons TEntity="SchoolManagement" Entity="schoolManagement" OnView="ViewSchoolManagement" OnEdit="EditSchoolManagement"
                        OnDelete="DeleteSchoolManagement" />
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private School? SelectedSchool;
    private List<SchoolManagement>? SchoolManagements;

    protected override async Task OnInitializedAsync()
    {
        SubscribeToEvent(UiEvents.SchoolSelected);
        SelectedSchool = SchoolService.GetSelectedSchool();

        if (SelectedSchool != null)
        {
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        SchoolManagements = await UserService.GetAllByRoleAndSchoolAsync<SchoolManagement>(SelectedSchool.Id);
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        // Handle the events and update the state
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                // Cast Payload to a School
                SelectedSchool = payload as School;
                break;
        }

        // Ensure state change
        await base.HandleEventAsync(eventName, payload);
    }

    private void AddSchoolManagement()
    {
        Navigation.NavigateTo("/school-management/add");
    }

    private void EditSchoolManagement(SchoolManagement schoolManagement)
    {
        Navigation.NavigateTo($"/school-management/edit/{schoolManagement.Id}");
    }

    private void ViewSchoolManagement(SchoolManagement schoolManagement)
    {
        Navigation.NavigateTo($"/school-management/details/{schoolManagement.Id}");
    }

    private async Task DeleteSchoolManagement(SchoolManagement schoolManagement)
    {
        await UserService.DeleteAsync<SchoolManagement>(schoolManagement.Id);
        SchoolManagements = await UserService.GetAllByRoleAndSchoolAsync<SchoolManagement>(SelectedSchool.Id);
        await InvokeAsync(StateHasChanged);
    }
}
