@page "/teachers"
@using Lisa.Components.Layout
@using Lisa.Data
@using Lisa.Models.Entities
@using Lisa.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject NavigationManager NavigationManager
@inject SchoolService SchoolService
@inherits EventAwareComponentBase
@inject UserService UserService

<PageTitle>Teachers</PageTitle>

<AuthorizeView Context="authContext" Roles="@($"{Roles.SystemAdministrator},{Roles.Teacher}")">
    <Authorized>
        @if (IsLoading)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="mb-4">
                <h3>Teachers for @SelectedSchool.ShortName</h3>
                <button class="btn btn-primary" @onclick="AddTeacher">Add Teacher</button>
                @if (Teachers == null)
                {
                    <p>Loading...</p>
                }
                else if (!Teachers.Any())
                {
                    <div class="alert alert-info">
                        No teachers found for <strong>@SelectedSchool.ShortName</strong>.
                    </div>
                }
                else
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var teacher in Teachers)
                            {
                                <tr>
                                    <td>@teacher.FirstName @teacher.LastName</td>
                                    <td>@teacher.Email</td>
                                    <ActionButtons TEntity="Teacher" Entity="teacher" OnView="ViewTeacher" OnEdit="EditTeacher"
                                        OnDelete="DeleteTeacher" />
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <p>You are not authorized to view this page.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Lisa.Models.Entities.Teacher>? Teachers;
    private Teacher NewTeacher = new Teacher();
    private School? SelectedSchool;
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        SubscribeToEvent(UiEvents.SchoolSelected);
        SubscribeToEvent(UiEvents.SchoolsUpdated);
        SelectedSchool = SchoolService.GetSelectedSchool();




        if (SelectedSchool != null)
        {
            Teachers = await UserService.GetAllByRoleAndSchoolAsync<Teacher>(SelectedSchool.Id);
        }

        IsLoading = false;
    }

    public async Task LoadTeachers()
    {
        Teachers = await UserService.GetAllByRoleAndSchoolAsync<Teacher>(SelectedSchool.Id);
    }

    protected override async Task HandleEventAsync(string eventName, object? payload)
    {
        // Handle the events and update the state
        switch (eventName)
        {
            case UiEvents.SchoolSelected:
                // Cast Payload to a School
                SelectedSchool = payload as School;
                await LoadTeachers();
                break;
            case UiEvents.TeachersUpdated:
                await LoadTeachers();
                break;
            case UiEvents.SchoolsUpdated:
                SelectedSchool = SchoolService.GetSelectedSchool();
                await LoadTeachers();
                break;
        }

        // Ensure state change
        await base.HandleEventAsync(eventName, payload);
    }

    private async Task DeleteTeacher(Teacher teacher)
    {
        IsLoading = true;
        await UserService.DeleteAsync<Teacher>(teacher.Id);
        IsLoading = false;
    }

    private void AddTeacher()
    {
        NavigationManager.NavigateTo("/teachers/add");
    }
    private void EditTeacher(Teacher teacher)
    {
        NavigationManager.NavigateTo($"/teachers/edit/{teacher.Id}");
    }

    private void ViewTeacher(Teacher teacher)
    {
        NavigationManager.NavigateTo($"/teachers/details/{teacher.Id}");
    }
}