@page "/teachers/edit/{Id:guid}"
@using Lisa.Models.Entities
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@inject TeacherService TeacherService
@inject SchoolService SchoolService
@inject NavigationManager Navigation

<h3>Edit Teacher</h3>

@if (teacher == null)
{
    <p>Loading teacher...</p>
}
else
{
    <EditForm Context="edit" Model="@teacher" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <!-- First Name -->
        <div class="mb-3">
            <label class="form-label">First Name</label>
            <InputText class="form-control" @bind-Value="teacher.FirstName" />
        </div>

        <!-- Last Name -->
        <div class="mb-3">
            <label class="form-label">Last Name</label>
            <InputText class="form-control" @bind-Value="teacher.LastName" />
        </div>

        <!-- Email -->
        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="teacher.Email" />
        </div>

        <!-- (Optional) School Dropdown -->
        <div class="mb-3">
            <label class="form-label">School</label>
            <select class="form-select" @bind="teacher.SchoolId">
                <option value="">-- Select School --</option>
                @if (Schools != null)
                {
                    @foreach (var school in Schools)
                    {
                        <option value="@school.Id">@school.ShortName</option>
                    }
                }
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
    </EditForm>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Teacher? teacher;
    private List<School> Schools = new();

    protected override async Task OnInitializedAsync()
    {
        teacher = await TeacherService.GetByIdAsync(Id);

        if (teacher == null)
        {
            Navigation.NavigateTo("/teachers");
            return;
        }

        Schools = await SchoolService.GetAllAsync();
    }

    private async Task HandleValidSubmit()
    {
        if (teacher == null) return;

        teacher.UserName = teacher.Email;

        await TeacherService.UpdateAsync(teacher);

        Navigation.NavigateTo("/teachers");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/teachers");
    }
}
