@page "/users"
@using Lisa.Models.Entities
@inject NavigationManager Navigation
@inject SchoolService SchoolService
@inject UserService UserService
@inherits EventAwareComponentBase

<AuthorizeView Context="auth" Roles="@($"{Roles.SystemAdministrator}")">
    <Authorized>
        <h3>Users</h3>
        <button class="btn btn-primary mb-3" @onclick="GoToAddUser" disabled="@(SelectedSchool == null)">
            Add User
        </button>

        @if (SelectedSchool == null)
        {
            <div class="alert alert-warning">
                No school selected. Please select a school first.
            </div>
        }
        else if (Users == null)
        {
            <p>Loading...</p>
        }
        else if (Users.Count == 0)
        {
            <p>No users found for @SelectedSchool.ShortName.</p>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Surname</th>
                        <th>Abbreviation</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Users)
                    {
                        <tr>
                            <td>@user.Surname</td>
                            <td>@user.Abbreviation</td>
                            <td>@user.Name</td>
                            <td>@user.Email</td>
                            <td>@string.Join(", ", user.Roles)</td>
                            <td>
                                <button class="btn btn-secondary btn-sm" @onclick="() => EditUser(user.Id)">Edit</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteUser(user)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </Authorized>
    <NotAuthorized>
        <Unauthorized />
    </NotAuthorized>
</AuthorizeView>

@code {
    private School? SelectedSchool;
    private List<User>? Users;

    protected override async Task OnInitializedAsync()
    {
        SelectedSchool = SchoolService.GetSelectedSchool();
        SubscribeToEvent(UiEvents.SchoolSelected);

        if (SelectedSchool != null)
        {
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        if (SelectedSchool == null)
        {
            throw new InvalidOperationException("No school selected.");
        }
        Users = await UserService.GetAllUsersBySchoolAsync(SelectedSchool.Id);
    }

    private void GoToAddUser()
    {
        Navigation.NavigateTo("/users/manage");
    }

    private void EditUser(Guid userId)
    {
        Navigation.NavigateTo($"/users/manage/{userId}");
    }

    private async Task DeleteUser(User user)
    {
        await UserService.DeleteAsync(user.Id);
        await LoadUsers();
        StateHasChanged();
    }
}
