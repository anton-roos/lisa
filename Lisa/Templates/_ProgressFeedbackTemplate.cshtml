@using Lisa.Models.EmailModels
@using Lisa.Models.ViewModels
@model IEnumerable<ProgressFeedback>

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <title>Progress Feedback</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        @@page { margin: 1cm; }

        .learner-section {
            page-break-after: always;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        thead { display: table-header-group; }
        tr, td, th { page-break-inside: avoid; }

        th, td {
            padding: 0.75rem;
            border-top: 1px solid #dee2e6;
        }

        h3, h4 { page-break-after: avoid; }
    </style>
</head>
<body style="margin:0; padding:0; font-family: Arial, sans-serif;">

@foreach (var progressFeedback in Model)
{
    var firstResult = progressFeedback.ResultsBySubject?
        .SelectMany(x => x.Value)?.FirstOrDefault();
    var isAchievementRating = firstResult?.Learner?.RegisterClass?.SchoolGrade?.SystemGrade?.AchievementLevelRating ?? false;

    <div class="learner-section" style="margin:1rem auto; max-width:600px;">

        <h3 style="margin:0 0 1rem 0;">Progress Feedback</h3>
        <table style="margin-bottom:1rem;">
            <tr><th>Name</th><td>@progressFeedback.LearnerName</td></tr>
            <tr><th>From</th><td>{{fromDate}}</td></tr>
            <tr><th>To</th><td>{{toDate}}</td></tr>
        </table>

        @if (progressFeedback?.ResultsBySubject != null && progressFeedback.ResultsBySubject.Any(x => x.Value != null && x.Value.Any()))
        {
            foreach (var subjectGroup in progressFeedback.ResultsBySubject.Where(x => x.Value != null && x.Value.Any()))
            {
                <table style="margin-bottom:1.5rem; border:1px solid #ccc;">
                    <thead>
                        <tr>
                            <th colspan="6" style="background-color:#f8f9fa;">@subjectGroup.Key</th>
                        </tr>
                        <tr>
                            @for (var i = 0; i < 3; i++)
                            {
                                <th>Date</th>
                                <th>@(isAchievementRating ? "Level" : "Mark")</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var totalResults = Math.Min(subjectGroup.Value.Count, 6);
                            var rows = (int)Math.Ceiling(totalResults / 3.0);
                        }
                        @for (var row = 0; row < rows; row++)
                        {
                            var rowStyle = (row % 2 == 0) ? "background-color:#f9f9f9;" : "";
                            <tr style="@rowStyle">
                                @for (var col = 0; col < 3; col++)
                                {
                                    var index = row * 3 + col;
                                    if (index < totalResults)
                                    {
                                        var result = subjectGroup.Value[index];

                                        <!-- Date -->
                                        <td>
                                            @(result.ResultSet?.AssessmentDate?.ToString("MM/dd") ?? "-")
                                        </td>

                                        <!-- Score -->
                                        
                                            var color = result.Score == null ? "#ffc107" :
                                                        result.Score < 50 ? "#dc3545" : "#198754";

                                            string text;
                                            if (result.Score == null)
                                                text = "Absent";
                                            else if (isAchievementRating)
                                                text = result.Score.ToString();
                                            else
                                                text = result.Score.Value + "%";
                                        
                                        <td style="color:@color; font-weight:bold;">@text</td>
                                    }
                                    else
                                    {
                                        <td>&nbsp;</td><td>&nbsp;</td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
        else
        {
            <p style="color:#856404; background:#fff3cd; padding:0.75rem; border:1px solid #ffeeba; text-align:center;">
                No results available for this learner.
            </p>
        }

    </div>
}
</body>
</html>
